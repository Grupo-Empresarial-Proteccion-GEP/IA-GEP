                                        <option value="Cédula de Ciudadanía">Cédula de Ciudadanía</option>
                                        <option value="Tarjeta de Identidad">Tarjeta de Identidad</option>
                                        <option value="PEP">PEP</option>
                                        <option value="Permiso por Protección Temporal">Permiso Temporal</option>
                                        <option value="NIT">NIT</option>
                                    </select>

                                    <InputText class="form-control mb-2" placeholder="Número de documento" @bind-Value="NumeroDoc_E" />
                                    <InputText class="form-control mb-2" placeholder="Dirección" @bind-Value="Direccion_E" />
                                    <InputText class="form-control mb-2" placeholder="Teléfono" @bind-Value="Telefono_E" />
                                    <InputText class="form-control mb-2" placeholder="Correo" @bind-Value="Correo_E" />
