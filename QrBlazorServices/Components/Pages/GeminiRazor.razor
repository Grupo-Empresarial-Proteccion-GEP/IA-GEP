    private async Task SendToGemini()
    {
        cargando = true;

        var tieneArchivo = !string.IsNullOrWhiteSpace(fileContent);
        var datosCompletos = !string.IsNullOrWhiteSpace(Ciudad)
        || !string.IsNullOrWhiteSpace(Receptor)
        || !string.IsNullOrWhiteSpace(Direccion_R)
        || !string.IsNullOrWhiteSpace(Documento_R)
        || !string.IsNullOrWhiteSpace(NumeroDoc_R)
        || !string.IsNullOrWhiteSpace(Telefono_R)
        || !string.IsNullOrWhiteSpace(Correo_R)
        || !string.IsNullOrWhiteSpace(Emisor)
        || !string.IsNullOrWhiteSpace(Direccion_E)
        || !string.IsNullOrWhiteSpace(Documento_E)
        || !string.IsNullOrWhiteSpace(NumeroDoc_E)
        || !string.IsNullOrWhiteSpace(Telefono_E)
        || !string.IsNullOrWhiteSpace(Correo_E)
        || !string.IsNullOrWhiteSpace(Asunto);

        string opcionesTexto = string.Join("\n", opcionesSeleccionadas);

        string promptFinal;

        if (datosCompletos)
        {
            promptFinal = $@"
Redacta un documento formalsegun su tipo: {TipoDocumento} y teniendo en cuenta la informacion adicional:{UserPrompt} con la siguiente información:
Ciudad: {Ciudad}

Fecha: {DateTime.Now:dd 'de' MMMM 'del' yyyy}
Nombre del receptor: {Receptor}
Dirección receptor: {Direccion_R}
Documento receptor: {Documento_R}
Número Documento receptor: {NumeroDoc_R}
Teléfono receptor: {Telefono_R}
Correo receptor: {Correo_R}

Nombre del emisor: {Emisor}
Dirección emisor: {Direccion_E}
Documento emisor: {Documento_E}
Número Documento emisor: {NumeroDoc_E}
Teléfono emisor: {Telefono_E}
Correo emisor: {Correo_E}

Asunto: {Asunto}

{contenidoAuxiliar}

contenido documento {fileContent}

Por favor genera el documento como HTML usando etiquetas como <strong>, <p>, <ul>, <li>, <br>, <h2>, etc. No uses Markdown.";
        }
        else
        {
            // Si no hay datos completos, también puedes asignar un valor a promptFinal
            var contenidoAdicional = "";

            if (!string.IsNullOrWhiteSpace(UserPrompt))
                contenidoAdicional += $"Instrucciones del usuario: {UserPrompt}\n";

           // if (!string.IsNullOrWhiteSpace(UserPrompt))
             //   contenidoAdicional += $"Archivo Cargado: {fileContent}\n";


            promptFinal = $@"
{contenidoAdicional}
Por favor genera la respuesta como HTML usando etiquetas como <strong>, <p>, <ul>, <li>, <br>, <h2>, etc. No uses Markdown.";

        }

        if (!string.IsNullOrWhiteSpace(contenidoAuxiliar))        
        {
        var contenidoAdicional = "";
        contenidoAdicional += $"Sugerencia del usuario: \n{contenidoAuxiliar}\n";

            promptFinal = $@"
        {contenidoAdicional}
        Por favor genera el documento en base a la sugerencia seleccionada {contenidoAuxiliar} 
        como HTML usando etiquetas como <strong>, <p>, <ul>, <li>, <br>, <h2>, etc. No uses Markdown.";
        }

        
        try
        {
            int intentos = 0;
            int maxIntentos = 5;
            int esperaMs = 2000; // 2 segundos

            while (intentos < maxIntentos)
            {
                try
                {
                    ResponseText = await ChatService.SendMessageAsync(promptFinal);
                    break;

                }
                catch (HttpRequestException ex)
                {
                    if (ex.Message.Contains("503"))
                    {
                        intentos++;
                        if (intentos == maxIntentos)
                        {
                            ResponseText = "El servicio de IA está sobrecargado. Intenta nuevamente más tarde.";
                            break;
                        }

                        await Task.Delay(esperaMs);
                        esperaMs *= 2; // backoff exponencial
                    }
                    else
                    {
                        ResponseText = $"Se produjo un error inesperado: {ex.Message}";
                        break;
                    }
                }
            }
            mostrarHtml = true;
        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }
        finally
        {
            cargando = false;
            mostrarSugerencias = false;
  
        }
    }

