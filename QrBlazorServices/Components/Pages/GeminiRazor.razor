@code {
    private string userInput = "";
    private bool isHistorialVisible = false;
    private string HistorialStyle => isHistorialVisible ? "display: block;" : "display: none;";

    private async Task EnviarMensaje()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            await ChatService.SendMessageAsync(userInput);
            userInput = "";
        }
    }

    private async Task CheckEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await EnviarMensaje();
    }

    private void ToggleHistorialVisibility()
    {
        isHistorialVisible = !isHistorialVisible;
    }
}

