    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {

        // Pequeño retraso para que Blazor tenga tiempo de renderizar
        await Task.Delay(100);


        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLower();

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10_000_000).CopyToAsync(ms);

        if (ext == ".pdf")
        {
            fileContent = FileParser.ExtractTextFromPdf(ms);
        }
        else if (ext == ".docx")
        {
            fileContent = FileParser.ExtractTextFromDocx(ms);
        }
        else if (ext == ".txt")
        {
            ms.Position = 0;
            using var reader = new StreamReader(ms);
            fileContent = await reader.ReadToEndAsync();
        }

    }
        
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private async Task SendResumenDesdeArchivo()
    {

        try
        {
            if (string.IsNullOrWhiteSpace(fileContent))
            {
                ResponseText = "<p><strong>No se ha podido leer el archivo.</strong></p>";
                return;
            }

            string promptResumen = $@"
Este es el contenido de un archivo cargado. Por favor, analiza el texto y redacta <strong>exactamente cuatro recomendaciones distintas
para continuar con el documento.

Las recomendaciones deben redactarse exclusivamente en formato de enumeración ordinal o cardinal, no con viñetas. Cada recomendación debe estar
claramente diferenciada dentro del texto. Además, cada una debe ser breve y directa (no más de 4 o 5 líneas).

Usa etiquetas HTML como <p>, <strong> o <em>, pero <strong>no uses</strong> <ul>, <ol> ni <li>, y no uses Markdown.

Contenido del documento:
{fileContent}";


            // Enviar la solicitud para obtener la respuesta
            ResponseText = await ChatService.SendMessageAsync(promptResumen);
            mostrarHtml = false;

            string textoSinDuplicados = EliminarDuplicadosConCheckboxes(ResponseText);

            // Extraer todas las frases entre <p> o <li> o líneas separadas manualmente
            var matches = Regex.Matches(ResponseText, "<li>(.*?)</li>|<p>(.*?)</p>", RegexOptions.IgnoreCase);

            // Unir todos los grupos y limpiar etiquetas HTML adicionales
            opcionesGeneradas = matches
                .Select(m => string.IsNullOrEmpty(m.Groups[1].Value) ? m.Groups[2].Value : m.Groups[1].Value)
                .Select(o => Regex.Replace(o, "<.*?>", "").Trim()) // elimina etiquetas HTML
                .Distinct() // evita duplicados
                .ToList();


        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }

        finally
        {
            cargantwo = false;
            // 🔄 Resetear el input después de generar las opciones y antes del siguiente render
            inputFileKey = Guid.NewGuid().ToString();
            mostrarSugerencias = true;

        }

    }

