    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task BuscarClientePorDocumento()
    {
        buscandoCliente = true;

        try
        {
            if (string.IsNullOrWhiteSpace(nombreBuscado))
            {
                mensaje = "Por favor ingrese un número de documento para buscar.";
                return;
            }

            string documento = nombreBuscado.Replace("'", "''");
            string condicion = $"NumeroDeDocumento = '{documento}'";
            string campos = "Nombre, TipoDeDocumento, NumeroDeDocumento, Direccion, Telefono, Correo";

            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Clientes", campos, condicion, 18);

            if (resultado != null && resultado.Rows.Count > 0)
            {
                var fila = resultado.Rows[0];

                Emisor = fila["Nombre"].ToString();
                Documento_E = fila["TipoDeDocumento"].ToString();
                NumeroDoc_E = fila["NumeroDeDocumento"].ToString();
                Direccion_E = fila["Direccion"].ToString();
                Telefono_E = fila["Telefono"].ToString();
                Correo_E = fila["Correo"].ToString();

                mensaje = "Cliente encontrado.";
            }
            else
            {
                mensaje = "No se encontró ningún cliente con ese documento.";
                Emisor = Documento_E = NumeroDoc_E = Direccion_E = Telefono_E = Correo_E = string.Empty;
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error al buscar cliente: {ex.Message}";
        }
        finally
        {
            buscandoCliente = false;
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task<int> GuardarSesionConversacionAsync(string tipoDocumento, string asunto)
    {
        DataTable tabla = new DataTable("SesionesConversacion");
        tabla.Columns.Add("Id", typeof(int));
        tabla.Columns.Add("Usuario", typeof(string));
        tabla.Columns.Add("FechaInicio", typeof(DateTime));
        tabla.Columns.Add("TipoDocumento", typeof(string));
        tabla.Columns.Add("Asunto", typeof(string));

        var fila = tabla.NewRow();
        fila["Id"] = 0;
        fila["Usuario"] = DBNull.Value; // ← Usuario no necesario
        fila["FechaInicio"] = DateTime.Now;
        fila["TipoDocumento"] = tipoDocumento ?? "";
        fila["Asunto"] = asunto ?? "";

        tabla.Rows.Add(fila);

        string id = await _servicioUsuario.InsertarFilaDevuelveConsecutivoAsync(tabla, "SesionesConversacion", 18);
        return int.TryParse(id, out int sesionId) ? sesionId : 0;
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task GuardarMensajeConversacionAsync(int sesionId, string rol, string contenido)
    {
        DataTable tablaHistorial = new DataTable("HistorialConversaciones");
        tablaHistorial.Columns.Add("Id", typeof(int));
        tablaHistorial.Columns.Add("SesionId", typeof(int));
        tablaHistorial.Columns.Add("Fecha", typeof(DateTime));
        tablaHistorial.Columns.Add("Rol", typeof(string));
        tablaHistorial.Columns.Add("Contenido", typeof(string));

        DataRow fila = tablaHistorial.NewRow();
        fila["Id"] = 0;
        fila["SesionId"] = sesionId;
        fila["Fecha"] = DateTime.Now;
        fila["Rol"] = rol ?? "";
        fila["Contenido"] = contenido ?? "";

        tablaHistorial.Rows.Add(fila);

        await _servicioUsuario.InsertarTablaAsync(tablaHistorial, "HistorialConversaciones", 18);
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task<List<string>> ObtenerRespuestasAnterioresAsync(string tipoDoc)
    {
        string consulta = $@"
        SELECT TOP 3 Contenido FROM HistorialConversaciones
        WHERE Rol = 'assistant'
        AND SesionId IN (
            SELECT Id FROM SesionesConversacion
            WHERE TipoDocumento = '{tipoDoc}'
        )
        ORDER BY Fecha DESC";

        var tabla = await _servicioUsuario.TraerConsultaAsync(consulta, 18);
        var respuestas = new List<string>();

        foreach (DataRow row in tabla.Rows)
        {
            respuestas.Add(row["Contenido"].ToString());
        }

        return respuestas;
    }

