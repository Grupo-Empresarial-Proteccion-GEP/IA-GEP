    </div>

</EditForm>

@if (showModal)
{
    <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
                 background-color: rgba(0, 0, 0, 0.5); display: flex;
                 justify-content: center; align-items: center; z-index: 9999;">
        <div style="background: white; padding: 20px; border-radius: 10px; width: 80%; max-height: 80vh; overflow-y: auto; box-shadow: 0 0 10px #000;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5><!--📚--> Historial de Chat </h5>
                <button class="btn btn-sm btn-danger" @onclick="() => showModal = false">X</button>
            </div>

            @if (ChatService.ChatHistory?.Any() == true)
            {
                @foreach (var mensaje in ChatService.ChatHistory)
                {
                    <div class="p-3 border rounded bg-light shadow-sm mb-2">
                        @if (mensaje.Role == "user")
                        {
                            <p class="fw-bold text-primary">🧑‍💻 Tú:</p>
                            <p>@LimpiarInstrucciones(mensaje.Content)</p>
                        }
                        else if (mensaje.Role == "assistant")
                        {
                            <p class="fw-bold text-success">🤖 Asistente:</p>

                            <div @onclick="() => SeleccionarRespuesta(mensaje.Content)" style="cursor: pointer;">
                                @((MarkupString)ExtraerContenidoHtml(LimpiarInstrucciones(mensaje.Content)))
                                <div class="text-end text-muted small"><em>📎 Click para volver a mostrar</em></div>
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No hay historial disponible.</p>
            }
        </div>
    </div>
}

