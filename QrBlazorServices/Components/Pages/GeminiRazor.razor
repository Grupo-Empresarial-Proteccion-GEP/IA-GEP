    private void SeleccionarRespuesta(string contenido)
    {
        ResponseText = contenido;
        mostrarSugerencias = false;
        showModal = false; // ✅ Cierra el modal inmediatamente
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private string LimpiarInstrucciones(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return string.Empty;

        // Dividir en líneas
        var lineas = texto.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

        var instrucciones = new[]
        {
        "usa etiquetas como",
        "genera la respuesta como html",
        "formatea como html",
        "no uses markdown",
        "responde en formato html",
        "por favor responde en html",
        "Instrucciones del usuario:",
        "Archivo Cargado:"

    };


        // Filtrar líneas que parecen instrucciones
        var contenidoFiltrado = lineas
            .Where(linea => !instrucciones.Any(instr => linea.ToLower().Contains(instr)))
            .ToList();

        return string.Join("\n", contenidoFiltrado).Trim();
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private string ExtraerContenidoHtml(string respuesta)
    {
        if (string.IsNullOrEmpty(respuesta)) return string.Empty;

        var inicio = respuesta.IndexOf("<body>");
        var fin = respuesta.IndexOf("</body>");
        if (inicio != -1 && fin != -1)
        {
            return respuesta.Substring(inicio + 6, fin - inicio - 6); // 6 = length de "<body>"
        }

        return respuesta;
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    public class OpcionCheckbox
    {
        public string Texto { get; set; }
        public bool Seleccionada { get; set; }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    void OnCheckboxChanged(string opcion, bool isChecked)
    {
        // Agrega o elimina la opción seleccionada de la lista
        if (isChecked)
        {
            if (!opcionesSeleccionadas.Contains(opcion))
                opcionesSeleccionadas.Add(opcion);
        }
        else
        {
            if (opcionesSeleccionadas.Contains(opcion))
                opcionesSeleccionadas.Remove(opcion);
        }

        // Después de actualizar la selección, guardamos las opciones seleccionadas
        GuardarSeleccionadas();
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private void GuardarSeleccionadas()
    {
        // Unimos las opciones seleccionadas en un solo string
        var seleccionadas = opcionesSeleccionadas;

        // Si hay opciones seleccionadas, formateamos el texto
        if (seleccionadas.Any())
        {
            contenidoAuxiliar = "\n" + string.Join("\n", seleccionadas);
        }
        else
        {
            contenidoAuxiliar = "";
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    public static string EliminarDuplicadosConCheckboxes(string texto)
    {
        // Expresión regular para capturar solo las opciones numeradas dentro de <li> o <p>
        var matches = Regex.Matches(texto, @"<li>\s*(\d+\.)\s(.*?)</li>|<p>\s*(\d+\.)\s(.*?)</p>", RegexOptions.IgnoreCase);

        var únicas = new HashSet<string>();
        var resultado = new List<string>();

        // Extraer las opciones numeradas, eliminar duplicados y generar checkboxes
        foreach (Match match in matches)
        {
            string opcion = match.Groups[2].Value.Trim();
            if (!string.IsNullOrEmpty(opcion) && !únicas.Contains(opcion))
            {
                únicas.Add(opcion);

                // Crear checkbox HTML para cada opción
                string checkboxHtml = $"<input type='checkbox' id='{opcion.Replace(" ", "_")}' name='opcion' value='{opcion}'><label for='{opcion.Replace(" ", "_")}'> {opcion}</label><br>";
                resultado.Add(checkboxHtml);
            }
        }

        // Unir las opciones con checkboxes en un solo string HTML
        return string.Join("\n", resultado);
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {

        // Pequeño retraso para que Blazor tenga tiempo de renderizar
        await Task.Delay(100);


        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLower();

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10_000_000).CopyToAsync(ms);

        if (ext == ".pdf")
        {
            fileContent = FileParser.ExtractTextFromPdf(ms);
        }
        else if (ext == ".docx")
        {
            fileContent = FileParser.ExtractTextFromDocx(ms);
        }
        else if (ext == ".txt")
        {
            ms.Position = 0;
            using var reader = new StreamReader(ms);
            fileContent = await reader.ReadToEndAsync();
        }

    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task SendResumenDesdeArchivo()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(fileContent))
            {
                ResponseText = "<p><strong>No se ha podido leer el archivo.</strong></p>";
                return;
            }

            // Traer la plantilla desde la tabla Prompts
            string condicion = "Nombre = 'ResumenDesdeArchivo'";
            string campos = "Plantilla";
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Prompts", campos, condicion, 18);

            if (resultado == null || resultado.Rows.Count == 0)
            {
                ResponseText = "<p><strong>No se encontró el prompt configurado.</strong></p>";
                return;
            }

            // Obtener la plantilla y reemplazar el marcador
            string plantillaPrompt = resultado.Rows[0]["Plantilla"].ToString();
            string promptFinal = plantillaPrompt.Replace("{fileContent}", fileContent);

            // Enviar a IA
            ResponseText = await ChatService.SendMessageAsync(promptFinal);
            mostrarHtml = false;

            // Procesar respuesta
            string textoSinDuplicados = EliminarDuplicadosConCheckboxes(ResponseText);

            var matches = Regex.Matches(ResponseText, "<li>(.*?)</li>|<p>(.*?)</p>", RegexOptions.IgnoreCase);

            opcionesGeneradas = matches
                .Select(m => string.IsNullOrEmpty(m.Groups[1].Value) ? m.Groups[2].Value : m.Groups[1].Value)
                .Select(o => Regex.Replace(o, "<.*?>", "").Trim())
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }
        finally
        {
            cargantwo = false;
            inputFileKey = Guid.NewGuid().ToString();
            mostrarSugerencias = true;
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task SimularEscritura(string textoCompleto)
    {
        textoParcial = "";
        mostrarHtml = true;

        foreach (char letra in textoCompleto)
        {
            textoParcial += letra;
            StateHasChanged();
            await Task.Delay(1); // Puedes ajustar la velocidad aquí
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    private async Task SendToGemini()
    {
        cargando = true;

        try
        {
            // 1. Obtener la plantilla
            string condicion = "Nombre = 'GenerarDocumentoFormal'";
            string campos = "Plantilla";
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Prompts", campos, condicion, 18);

            if (resultado == null || resultado.Rows.Count == 0)
            {
                ResponseText = "<p><strong>No se encontró el prompt configurado.</strong></p>";
                return;
            }

            string plantillaPrompt = resultado.Rows[0]["Plantilla"].ToString();

            // 2. Construir el prompt
            string promptFinal = plantillaPrompt
                .Replace("{TipoDocumento}", TipoDocumento)
                .Replace("{UserPrompt}", UserPrompt ?? "")
                .Replace("{Ciudad}", Ciudad ?? "")
                .Replace("{Fecha}", DateTime.Now.ToString("dd 'de' MMMM 'del' yyyy"))
                .Replace("{Receptor}", Receptor ?? "")
                .Replace("{Direccion_R}", Direccion_R ?? "")
                .Replace("{Documento_R}", Documento_R ?? "")
                .Replace("{NumeroDoc_R}", NumeroDoc_R ?? "")
                .Replace("{Telefono_R}", Telefono_R ?? "")
                .Replace("{Correo_R}", Correo_R ?? "")
                .Replace("{Emisor}", Emisor ?? "")
                .Replace("{Direccion_E}", Direccion_E ?? "")
                .Replace("{Documento_E}", Documento_E ?? "")
                .Replace("{NumeroDoc_E}", NumeroDoc_E ?? "")
                .Replace("{Telefono_E}", Telefono_E ?? "")
                .Replace("{Correo_E}", Correo_E ?? "")
                .Replace("{Asunto}", Asunto ?? "")
                .Replace("{contenidoAuxiliar}", contenidoAuxiliar ?? "")
                .Replace("{fileContent}", fileContent ?? "");

            // 3. Obtener retroalimentación de respuestas anteriores
            var respuestasPrevias = await ObtenerRespuestasAnterioresAsync(TipoDocumento);

            if (respuestasPrevias.Any())
            {
                var contextoBuilder = new StringBuilder();
                contextoBuilder.AppendLine("Ten en cuenta estas respuestas anteriores para mantener coherencia:\n");

                foreach (var r in respuestasPrevias)
                {
                    contextoBuilder.AppendLine($"<blockquote>{r}</blockquote>\n");
                }

                promptFinal = contextoBuilder.ToString() + "\n\n" + promptFinal;
            }

            // 4. Si no hay datos suficientes, usar prompt básico
            if (string.IsNullOrWhiteSpace(Ciudad + Emisor + Receptor + fileContent))
            {
                promptFinal = $"Instrucciones del usuario: {UserPrompt}\n\nPor favor genera la respuesta como HTML usando etiquetas como <strong>, <p>, <ul>, <li>, <br>, <h2>, etc. No uses Markdown.";
            }

            // 5. Guardar sesión y mensajes
            int sesionId = await GuardarSesionConversacionAsync(TipoDocumento, Asunto);
            await GuardarMensajeConversacionAsync(sesionId, "user", promptFinal);

            // 6. Enviar a IA con reintentos
            int intentos = 0;
            int maxIntentos = 5;
            int esperaMs = 2000;

            while (intentos < maxIntentos)
            {
                try
                {
                    ResponseText = await ChatService.SendMessageAsync(promptFinal);
                    await GuardarMensajeConversacionAsync(sesionId, "assistant", ResponseText);
                    break;
                }
                catch (HttpRequestException ex)
                {
                    if (ex.Message.Contains("503"))
                    {
                        intentos++;
                        if (intentos == maxIntentos)
                        {
                            ResponseText = "El servicio de IA está sobrecargado. Intenta nuevamente más tarde.";
                            break;
                        }

                        await Task.Delay(esperaMs);
                        esperaMs *= 2;
                    }
                    else
                    {
                        ResponseText = $"Se produjo un error inesperado: {ex.Message}";
                        break;
                    }
                }
            }

            mostrarHtml = true;
        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }
        finally
        {
            cargando = false;
            mostrarSugerencias = false;
        }
    }

