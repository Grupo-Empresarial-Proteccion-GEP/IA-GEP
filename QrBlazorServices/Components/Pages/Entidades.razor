@page "/registro"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject NavigationManager Navigation
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Data
@using Radzen
@using Radzen.Blazor

<RadzenTemplateForm Data="@entidad" Submit="@GuardarEntidad" TItem="Entidad">
    <div class="p-4">
        <RadzenFieldset Text="Registro de Entidades" Style="border-radius: 12px;">
            <div class="row">
                <!-- Columna 1 -->
                <div class="col-md-6">
                    <RadzenLabel Text="Entidad " /> 
                    <RadzenTextBox Name="Nombre" @bind-Value="entidad.Nombre" Placeholder="Nombre de la entidad" Class="w-100 mb-3" />

                    <RadzenDropDown Name="TipoEntidad" Placeholder="Tipo de Entidad"
                                    @bind-Value="entidad.Tipo" Class="w-100 mb-3"
                                    Data="@tiposEntidad" />
                    <RadzenDropDown Name="TipoDocumento" Placeholder="Tipo de Documento"
                                    @bind-Value="entidad.TipoDocumento" Class="w-100 mb-3"
                                    Data="@tiposDocumento" />

                    <RadzenTextBox Name="NumeroDocumento" @bind-Value="entidad.NumeroDocumento" Placeholder="Número de Documento" Class="w-100 mb-3" />
                    <RadzenTextBox Name="Departamento" @bind-Value="entidad.Departamento" Placeholder="Departamento" Class="w-100 mb-3" />

                    <RadzenTextBox Name="Ciudad" @bind-Value="entidad.Ciudad" Placeholder="Ciudad" Class="w-100 mb-3" />
                    <RadzenTextBox Name="Direccion" @bind-Value="entidad.Direccion" Placeholder="Dirección" Class="w-100 mb-3" />
                    <RadzenTextBox Name="Telefono" @bind-Value="entidad.Telefono" Placeholder="Teléfono" Class="w-100 mb-3" />
                    <RadzenTextBox Name="Correo" @bind-Value="entidad.Correo" Placeholder="Correo Electrónico" Class="w-100 mb-3" />
                </div>

                <!-- Columna 2 -->
                <div class="col-md-6">
                    <RadzenLabel Text="Servicios" />
               
                    <RadzenTextBox @bind-Value="nuevoServicio" Placeholder="Servicios Ej: Capacitación" Class="w-100 mb-3" />

                    <RadzenButton Icon="add_circle" Text="Agregar Servicio" Click="@AgregarServicio" ButtonStyle="ButtonStyle.Secondary"/>
                    
                    <ul class="mt-2">
                        @foreach (var s in listaServicios)
                        {
                            <li>
                                @s
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                              Click="@(args => EliminarServicio(s))" />
                            </li>
                        }
                    </ul>

                    <RadzenLabel Text="Subdivisiones (opcional)"class="mt-3" />
                    <RadzenTextBox @bind-Value="subdiv.NombreSubdiv" Placeholder="Nombre subdivisión" Class="w-100 mb-2" />
                    <RadzenTextBox @bind-Value="subdiv.Ciudad" Placeholder="Ciudad" Class="w-100 mb-2" />
                    <RadzenTextBox @bind-Value="subdiv.Direccion" Placeholder="Dirección" Class="w-100 mb-2" />
                    <RadzenTextBox @bind-Value="subdiv.Telefono" Placeholder="Teléfono" Class="w-100 mb-2" />
                    <RadzenTextBox @bind-Value="subdiv.Correo" Placeholder="Correo" Class="w-100 mb-2" />
                    <RadzenTextBox @bind-Value="subdiv.Responsable" Placeholder="Responsable" Class="w-100 mb-2" />
                    <RadzenButton Icon="add_circle" Text="Agregar Subdivisión" Click="@AgregarSubdiv" ButtonStyle="ButtonStyle.Secondary" />

                    <ul class="mt-2">
                        @foreach (var sd in listaSubdiv)
                        {
                            <li>
                                @sd.NombreSubdiv - @sd.Ciudad
                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                              Click="@(args => EliminarSubdiv(sd))" />
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <RadzenButton Text="Registrar entidad" ButtonStyle="ButtonStyle.Success" Type="Submit" Style="margin-top: 20px;" />
            <RadzenButton Text="Inicio" ButtonStyle="ButtonStyle.Primary" Click="@IrAInicio" Style="margin-left: 10px;" />





        </RadzenFieldset>



        @if (!string.IsNullOrWhiteSpace(mensaje))
        {
            <RadzenAlert Severity="AlertSeverity.Success" Style="margin-top: 20px;">@mensaje</RadzenAlert>
        }
    </div>
</RadzenTemplateForm>

@code {
    private Entidad entidad = new();
    private string nuevoServicio = "";
    private List<string> listaServicios = new();
    private Subdivision subdiv = new();
    private List<Subdivision> listaSubdiv = new();
    private string mensaje;

    private List<string> tiposEntidad = new() { "Entidad Pública", "Entidad Privada", "Entidad Mixta", "Entidad Sin Ánimo de Lucro" };
    private List<string> tiposDocumento = new() { "Cédula de Ciudadanía", "Tarjeta de Identidad", "PEP", "Permiso por Protección Temporal", "NIT" };

    public class Entidad
    {
        public string Nombre { get; set; }
        public string Tipo { get; set; }
        public string TipoDocumento { get; set; }
        public string NumeroDocumento { get; set; }
        public string Departamento { get; set; }
        public string Ciudad { get; set; }
        public string Direccion { get; set; }
        public string Telefono { get; set; }
        public string Correo { get; set; }
    }

    public class Subdivision
    {
        public string NombreSubdiv { get; set; }
        public string Ciudad { get; set; }
        public string Direccion { get; set; }
        public string Telefono { get; set; }
        public string Correo { get; set; }
        public string Responsable { get; set; }
    }

    private void AgregarServicio()
    {
        if (!string.IsNullOrWhiteSpace(nuevoServicio))
        {
            listaServicios.Add(nuevoServicio);
            nuevoServicio = string.Empty;
        }
    }

    private void EliminarServicio(string servicio)
    {
        listaServicios.Remove(servicio);
    }

    private void AgregarSubdiv()
    {
        if (!string.IsNullOrWhiteSpace(subdiv.NombreSubdiv))
        {
            listaSubdiv.Add(subdiv);
            subdiv = new Subdivision();
        }
    }

    private void EliminarSubdiv(Subdivision s)
    {
        listaSubdiv.Remove(s);
    }

    private async Task GuardarEntidad()
    {
        try
        {
            DataTable tablaEntidad = new("Entidades");
            tablaEntidad.Columns.Add("Id", typeof(int));
            tablaEntidad.Columns.Add("Nombre", typeof(string));
            tablaEntidad.Columns.Add("TipoEntidad", typeof(string));
            tablaEntidad.Columns.Add("TipoDocumento", typeof(string));
            tablaEntidad.Columns.Add("NumeroDocumento", typeof(string));
            tablaEntidad.Columns.Add("Departamento", typeof(string));
            tablaEntidad.Columns.Add("Ciudad", typeof(string));
            tablaEntidad.Columns.Add("Direccion", typeof(string));
            tablaEntidad.Columns.Add("Telefono", typeof(string));
            tablaEntidad.Columns.Add("Correo", typeof(string));

            var fila = tablaEntidad.NewRow();
            fila["Id"] = 0;
            fila["Nombre"] = entidad.Nombre;
            fila["TipoEntidad"] = entidad.Tipo;
            fila["TipoDocumento"] = entidad.TipoDocumento;
            fila["NumeroDocumento"] = entidad.NumeroDocumento;
            fila["Departamento"] = entidad.Departamento;
            fila["Ciudad"] = entidad.Ciudad;
            fila["Direccion"] = entidad.Direccion;
            fila["Telefono"] = entidad.Telefono;
            fila["Correo"] = entidad.Correo;
            tablaEntidad.Rows.Add(fila);

            await ServicioUsuario.InsertarTablaAsync(tablaEntidad, "Entidades", 18);

            var resultado = await ServicioUsuario.TraerConsultaAsync("SELECT TOP 1 Id FROM Entidades ORDER BY Id DESC", 18);
            int entidadId = Convert.ToInt32(resultado.Rows[0]["Id"]);

            DataTable tablaServicios = new("Servicios");
            tablaServicios.Columns.Add("Id", typeof(int));
            tablaServicios.Columns.Add("EntidadId", typeof(int));
            tablaServicios.Columns.Add("ServicioBrindado", typeof(string));

            foreach (var servicio in listaServicios)
            {
                var row = tablaServicios.NewRow();
                row["Id"] = 0;
                row["EntidadId"] = entidadId;
                row["ServicioBrindado"] = servicio;
                tablaServicios.Rows.Add(row);
            }

            await ServicioUsuario.InsertarTablaAsync(tablaServicios, "Servicios", 18);

            DataTable tablaSubdiv = new("Subdivisiones");
            tablaSubdiv.Columns.Add("Id", typeof(int));
            tablaSubdiv.Columns.Add("EntidadId", typeof(int));
            tablaSubdiv.Columns.Add("NombreSubdiv", typeof(string));
            tablaSubdiv.Columns.Add("Ciudad", typeof(string));
            tablaSubdiv.Columns.Add("Direccion", typeof(string));
            tablaSubdiv.Columns.Add("Telefono", typeof(string));
            tablaSubdiv.Columns.Add("Correo", typeof(string));
            tablaSubdiv.Columns.Add("Responsable", typeof(string));

            foreach (var sd in listaSubdiv)
            {
                var row = tablaSubdiv.NewRow();
                row["Id"] = 0;
                row["EntidadId"] = entidadId;
                row["NombreSubdiv"] = sd.NombreSubdiv;
                row["Ciudad"] = sd.Ciudad;
                row["Direccion"] = sd.Direccion;
                row["Telefono"] = sd.Telefono;
                row["Correo"] = sd.Correo;
                row["Responsable"] = sd.Responsable;
                tablaSubdiv.Rows.Add(row);
            }

            await ServicioUsuario.InsertarTablaAsync(tablaSubdiv, "Subdivisiones", 18);

            mensaje = "✅ Entidad registrada exitosamente con servicios y subdivisiones.";
            entidad = new(); listaServicios.Clear(); listaSubdiv.Clear();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error: {ex.Message}";
        }
    }

    private void IrAInicio() => Navigation.NavigateTo("/rs");

    private List<EntidadVisual> entidades = new();

    public class EntidadVisual
    {
        public int Id { get; set; }
        public string Nombre { get; set; }
        public string TipoEntidad { get; set; }
        public string TipoDocumento { get; set; }
        public string NumeroDocumento { get; set; }
        public string Departamento { get; set; }
        public string Ciudad { get; set; }
        public string Direccion { get; set; }
        public string Telefono { get; set; }
        public string Correo { get; set; }
        public DateTime FechaRegistro { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var dt = await ServicioUsuario.TraerConsultaAsync("SELECT * FROM Entidades ORDER BY FechaRegistro DESC", 18);

        foreach (DataRow row in dt.Rows)
        {
            entidades.Add(new EntidadVisual
                {
                    Id = Convert.ToInt32(row["Id"]),
                    Nombre = row["Nombre"].ToString(),
                    TipoEntidad = row["TipoEntidad"].ToString(),
                    TipoDocumento = row["TipoDocumento"].ToString(),
                    NumeroDocumento = row["NumeroDocumento"].ToString(),
                    Departamento = row["Departamento"].ToString(),
                    Ciudad = row["Ciudad"].ToString(),
                    Direccion = row["Direccion"].ToString(),
                    Telefono = row["Telefono"].ToString(),
                    Correo = row["Correo"].ToString(),
                    FechaRegistro = Convert.ToDateTime(row["FechaRegistro"])
                });
        }
    }

    void OnRowSelect(EntidadVisual entidad)
    {
        // Puedes navegar o abrir un modal
        Console.WriteLine($"Seleccionaste: {entidad.Nombre}");
    }
}
