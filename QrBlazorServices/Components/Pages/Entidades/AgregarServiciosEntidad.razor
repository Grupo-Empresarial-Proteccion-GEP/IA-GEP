@page "/agregar-servicios/{EntidadId:int}"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject NavigationManager Navigation
@using System.Data
@using Radzen
@using Radzen.Blazor
@rendermode InteractiveServer
@using QrBlazorServices.Clases

@using QrBlazorServices




<h3 class="mb-4">Agregar Servicios y Subdivisiones a la Entidad @EntidadId</h3>

<RadzenRow>
    <!-- Columna izquierda: Servicios -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Servicios">
            <RadzenLabel Text="Servicios" />

            <RadzenFormField Text="Servicios Ej: Capacitación" Class="w-100 mb-2">
                <RadzenTextBox @bind-Value="nuevoServicio" Placeholder="Servicios Ej: Capacitación" Class="w-50" />
            </RadzenFormField>

            <RadzenButton Icon="add_circle" Text="Agregar Servicio" Shade="Shade.Lighter" Click="@AgregarServicio" ButtonStyle="ButtonStyle.Secondary" />

            <ul class="mt-2">
                @foreach (var s in listaServicios)
                {
                    <li>
                        @s
                        <RadzenButton Icon="close" Shade="Shade.Lighter" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                      Click="@(args => EliminarServicio(s))" />
                    </li>
                }
            </ul>
        </RadzenFieldset>
    </RadzenColumn>

    <!-- Columna derecha: Subdivisiones -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Nombre Del Departamento" Style="margin-top: 0;">

            <RadzenLabel Text="Nombre Del Departamento (opcional)" class="mt-3" />

            <RadzenFormField Text="Nombre Del Departamento" Class="w-100 mb-1">
                <RadzenTextBox @bind-Value="subdiv.NombreSubdiv" Placeholder="Nombre Del Departamento" Class="w-100" />
            </RadzenFormField>

            <RadzenFormField Text="Ciudad" Class="w-100 mb-1">
                <RadzenTextBox @bind-Value="subdiv.Ciudad" Placeholder="Ciudad" Class="w-50" />
            </RadzenFormField>

            <RadzenFormField Text="Dirección" Class="w-100 mb-1">
                <RadzenTextBox @bind-Value="subdiv.Direccion" Placeholder="Dirección" Class="w-50" />
            </RadzenFormField>

            <RadzenFormField Text="Teléfono" Class="w-100 mb-1">
                <RadzenTextBox @bind-Value="subdiv.Telefono" Placeholder="Teléfono" Class="w-50" />
            </RadzenFormField>

            <RadzenFormField Text="Correo" Class="w-100 mb-1">
                <RadzenTextBox @bind-Value="subdiv.Correo" Placeholder="Correo" Class="w-50" />
            </RadzenFormField>

            <RadzenFormField Text="Contacto" Class="w-100 mb-2">
                <RadzenTextBox @bind-Value="subdiv.Responsable" Placeholder="Contacto" Class="w-100" />
            </RadzenFormField>


            <RadzenButton Icon="add_circle" Text="Agregar Departamento" Click="@AgregarSubdiv" Shade="Shade.Lighter" ButtonStyle="ButtonStyle.Secondary" />

            <ul class="mt-2">
                @foreach (var sd in listaSubdiv)
                {
                    <li>
                        @sd.NombreSubdiv - @sd.Ciudad
                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Shade="Shade.Lighter"
                                      Click="@(args => EliminarSubdiv(sd))" />
                    </li>
                }
            </ul>
        </RadzenFieldset>
    </RadzenColumn>
</RadzenRow>

<!-- Botones de acción debajo del grid -->
<div class="mt-4">
    <RadzenButton Text="Guardar Todo" ButtonStyle="ButtonStyle.Success" Click="@GuardarTodo" Shade="Shade.Lighter" />
    <RadzenButton Text="Volver" ButtonStyle="ButtonStyle.Secondary" Click="@Volver" Style="margin-left: 10px;" Shade="Shade.Lighter" />
</div>


@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <RadzenAlert Severity="AlertSeverity.Info" Style="margin-top: 20px;">@mensaje</RadzenAlert>
}


@code {
    [Parameter] public int EntidadId { get; set; }

    private string nuevoServicio = "";
    private List<string> listaServicios = new();

    private Subdivision subdiv = new();
    private List<Subdivision> listaSubdiv = new();

    private string mensaje;


    protected override async Task OnInitializedAsync()
    {
        await CargarServiciosYSubdivisiones();
    }

    private async Task CargarServiciosYSubdivisiones()
    {
        try
        {
            // Servicios existentes
            var dtServicios = await ServicioUsuario.TraerConsultaAsync($"SELECT * FROM Servicios WHERE EntidadId = {EntidadId}", 18);
            listaServicios = dtServicios.Rows.Cast<DataRow>()
                .Select(row => row["ServicioBrindado"].ToString()).ToList();

            // Subdivisiones existentes
            var dtSubdiv = await ServicioUsuario.TraerConsultaAsync($"SELECT * FROM Subdivisiones WHERE EntidadId = {EntidadId}", 18);
            listaSubdiv = dtSubdiv.Rows.Cast<DataRow>().Select(row => new Subdivision
                {
                    NombreSubdiv = row["NombreSubdiv"].ToString(),
                    Ciudad = row["Ciudad"].ToString(),
                    Direccion = row["Direccion"].ToString(),
                    Telefono = row["Telefono"].ToString(),
                    Correo = row["Correo"].ToString(),
                    Responsable = row["Responsable"].ToString()
                }).ToList();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al cargar datos existentes: {ex.Message}";
        }
    }

    private void AgregarServicio()
    {
        if (!string.IsNullOrWhiteSpace(nuevoServicio))
        {
            listaServicios.Add(nuevoServicio);
            nuevoServicio = string.Empty;
        }
    }

    private void EliminarServicio(string servicio)
    {
        listaServicios.Remove(servicio);
    }

    private void AgregarSubdiv()
    {
        if (!string.IsNullOrWhiteSpace(subdiv.NombreSubdiv))
        {
            listaSubdiv.Add(subdiv);
            subdiv = new Subdivision();
        }
    }

    private void EliminarSubdiv(Subdivision s)
    {
        listaSubdiv.Remove(s);
    }

    private async Task GuardarTodo()
    {
        try
        {
            // 🔄 Eliminar servicios y subdivisiones anteriores
            await ServicioUsuario.TraerConsultaAsync($"DELETE FROM Servicios WHERE EntidadId = {EntidadId}", 18);
            await ServicioUsuario.TraerConsultaAsync($"DELETE FROM Subdivisiones WHERE EntidadId = {EntidadId}", 18);

            // Guardar nuevos servicios
            if (listaServicios.Any())
            {
                DataTable tablaServicios = new("Servicios");
                tablaServicios.Columns.Add("Id", typeof(int));
                tablaServicios.Columns.Add("EntidadId", typeof(int));
                tablaServicios.Columns.Add("ServicioBrindado", typeof(string));

                foreach (var s in listaServicios)
                {
                    var row = tablaServicios.NewRow();
                    row["Id"] = 0;
                    row["EntidadId"] = EntidadId;
                    row["ServicioBrindado"] = s;
                    tablaServicios.Rows.Add(row);
                }

                await ServicioUsuario.InsertarTablaAsync(tablaServicios, "Servicios", 18);
            }

            // Guardar nuevas subdivisiones
            if (listaSubdiv.Any())
            {
                DataTable tablaSubdiv = new("Subdivisiones");
                tablaSubdiv.Columns.Add("Id", typeof(int));
                tablaSubdiv.Columns.Add("EntidadId", typeof(int));
                tablaSubdiv.Columns.Add("NombreSubdiv", typeof(string));
                tablaSubdiv.Columns.Add("Ciudad", typeof(string));
                tablaSubdiv.Columns.Add("Direccion", typeof(string));
                tablaSubdiv.Columns.Add("Telefono", typeof(string));
                tablaSubdiv.Columns.Add("Correo", typeof(string));
                tablaSubdiv.Columns.Add("Responsable", typeof(string));

                foreach (var sd in listaSubdiv)
                {
                    var row = tablaSubdiv.NewRow();
                    row["Id"] = 0;
                    row["EntidadId"] = EntidadId;
                    row["NombreSubdiv"] = sd.NombreSubdiv;
                    row["Ciudad"] = sd.Ciudad;
                    row["Direccion"] = sd.Direccion;
                    row["Telefono"] = sd.Telefono;
                    row["Correo"] = sd.Correo;
                    row["Responsable"] = sd.Responsable;
                    tablaSubdiv.Rows.Add(row);
                }

                await ServicioUsuario.InsertarTablaAsync(tablaSubdiv, "Subdivisiones", 18);
            }

            mensaje = "✅ Cambios guardados correctamente.";
            listaServicios.Clear();
            listaSubdiv.Clear();

            // Recargar para ver datos actualizados
            await CargarServiciosYSubdivisiones();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error: {ex.Message}";
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo("/entidades");
    }
}
<!--Version Funcional 18/08-->