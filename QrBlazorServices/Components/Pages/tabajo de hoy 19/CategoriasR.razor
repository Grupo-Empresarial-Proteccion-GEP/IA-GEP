    private int? ObtenerNodoCategoriaIdFinal()
    {
        int? nodoId = null;

        // 1. Buscar en niveles dinámicos (si existen)
        if (nivelesDinamicos != null && nivelesDinamicos.Any())
        {
            for (int i = nivelesDinamicos.Count - 1; i >= 0; i--)
            {
                var nivel = nivelesDinamicos[i];
                if (nivel.NodoSeleccionadoId.HasValue)
                {
                    nodoId = nivel.NodoSeleccionadoId;
                    var nodo = todosNodos.FirstOrDefault(n => n.Id == nodoId);
                    Console.WriteLine($"✅ Nodo seleccionado final: {nodo?.Nombre} (ID: {nodo?.Id})");
                    return nodoId;
                }
            }
        }

        // 2. Si no se encontró en niveles dinámicos, usar el nodo raíz seleccionado
        if (nodoSeleccionadoId.HasValue)
        {
            nodoId = nodoSeleccionadoId;
            var nodo = todosNodos.FirstOrDefault(n => n.Id == nodoId);
            Console.WriteLine($"✅ Nodo seleccionado raíz: {nodo?.Nombre} (ID: {nodo?.Id})");
            return nodoId;
        }

        // 3. Ningún nodo válido encontrado
        Console.WriteLine("❌ No se encontró NodoCategoriaId válido ni en niveles dinámicos ni en nodo raíz.");
        return null;
    }

