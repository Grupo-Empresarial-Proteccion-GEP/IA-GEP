    async Task CargarDocumentos()
    {
        documentos.Clear();

        var dtDocumentos = await ServicioUsuario.TraerTablaAsync("Documento", IdAplicacion);
        var dtRelacion = await ServicioUsuario.TraerTablaAsync("DocumentoCategoria", IdAplicacion);
        var dtSubcategorias = await ServicioUsuario.TraerTablaAsync("SubCategoria", IdAplicacion);
        var dtCategorias = await ServicioUsuario.TraerTablaAsync("Categoria", IdAplicacion);
        var dtNodos = await ServicioUsuario.TraerTablaAsync("NodoCategoria", IdAplicacion);
        var dtPlantillas = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);

        var subcategorias = dtSubcategorias.AsEnumerable().Select(r => new SubCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            CategoriaId = Convert.ToInt32(r["CategoriaId"])
        }).ToList();

        var categorias = dtCategorias.AsEnumerable().Select(r => new Categoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var nodos = dtNodos.AsEnumerable().Select(r => new NodoCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var plantillas = dtPlantillas.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString(),
            Referencia = r.Table.Columns.Contains("Referencia") ? r["Referencia"]?.ToString() : null
        }).ToList();

        var relaciones = dtRelacion.AsEnumerable().ToList();

        documentos = dtDocumentos.AsEnumerable().Select(doc =>
        {
            int id = Convert.ToInt32(doc["Id"]);

            var relacion = relaciones.FirstOrDefault(r => Convert.ToInt32(r["DocumentoId"]) == id);
            var subCatId = relacion != null ? Convert.ToInt32(relacion["SubCategoriaId"]) : 0;
            var nodoId = relacion != null && relacion["NodoCategoriaId"] != DBNull.Value
                            ? Convert.ToInt32(relacion["NodoCategoriaId"]) : 0;

            var subcategoria = subcategorias.FirstOrDefault(s => s.Id == subCatId);
            var categoria = categorias.FirstOrDefault(c => c.Id == subcategoria?.CategoriaId);
            var nodo = nodos.FirstOrDefault(n => n.Id == nodoId);

            Plantilla plantilla = null;
            if (doc.Table.Columns.Contains("PlantillaId") && doc["PlantillaId"] != DBNull.Value)
            {
                int idPlantilla = Convert.ToInt32(doc["PlantillaId"]);
                plantilla = plantillas.FirstOrDefault(p => p.Id == idPlantilla);
            }

            return new DocumentoExtendido
            {
                Id = id,
                Nombre = doc["Nombre"].ToString(),
                Referencia = plantilla?.Referencia ?? "",
                NombrePlantilla = plantilla?.NombreArchivo ?? "",
                FechaCreacion = doc["FechaCreacion"] == DBNull.Value ? DateTime.MinValue : Convert.ToDateTime(doc["FechaCreacion"]),
                Categoria = categoria?.Nombre ?? "",
                SubCategoria = subcategoria?.Nombre ?? "",
                Nodo = nodo?.Nombre ?? ""
            };
        }).ToList();
    }

    async Task EliminarDocumento(int id)
    {
        try
        {
            await ServicioUsuario.EliminarListadeLlavesAsync("DocumentoCategoria", "DocumentoId", id.ToString(), IdAplicacion);
            await ServicioUsuario.EliminarListadeLlavesAsync("Documento", "Id", id.ToString(), IdAplicacion);

            mensajes2 = "✅ Documento eliminado correctamente.";
            await CargarDocumentos();
        }
        catch (Exception ex)
        {
            mensajes2 = $"❌ Error al eliminar documento: {ex.Message}";
        }
    }

