@page "/Documentos"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject AccesoDatos.AccesoDatosSoapClient ServicioSoap
@inject DialogService dialogService
@rendermode InteractiveServer
@using System.Data
@using Radzen
@using Radzen.Blazor
@using QrBlazorServices.Clases

@inject NavigationManager Navigation
@inject NotificationService notificationService


    @page "/rdocumento/{Id:int}"
@inject NavigationManager Navigation


<h3 class="mb-3">Gestión de Arbol Categorias</h3>

<RadzenRow>
    <!-- Columna izquierda -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Visualizador De Arbol Categorias">

            <RadzenFieldset Text="@tituloSubnodos">


                <RadzenTree Data="@nodosRaiz"
                            Style="max-height: 450px; overflow-y: auto;"
                            Change="@(args => SeleccionarNodoDesdeArbol(args.Value as NodoCategoria))">
                    <RadzenTreeLevel TextProperty="Nombre" ChildrenProperty="Hijos" />
                </RadzenTree>
        </RadzenFieldset>
            

        <RadzenFieldset Text="@((editando ? "Editar Categoria" : "Nuevo Categoria"))">

                <RadzenDropDown Data="@nodosExistentes.Where(n => n.Id != nuevoNodo.Id).ToList()"
                                @bind-Value="nuevoNodo.PadreId"
                                TextProperty="Nombre"
                                ValueProperty="Id"
                                Placeholder="(Opcional) Categoria Padre"
                                AllowClear="true"
                                Class="w-100 mb-2" />

                <RadzenTextBox @bind-Value="nuevoNodo.Nombre" Placeholder="Nombre de la categoria" Class="w-100 mb-2" />

                <RadzenCheckBox @bind-Value="nuevoNodo.EsCategoria" /> <label class="ms-2">¿Es categoría principal?</label>
                <div class="d-flex flex-wrap gap-2 mt-2">

                    <RadzenButton Text="Guardar"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="@GuardarNodo"
                                  Icon="" />

                    @if (editando)
                    {
                        <RadzenButton Text="Cancelar"
                                      ButtonStyle="ButtonStyle.Secondary"
                                      Click="@CancelarEdicion" />
                    }
                    else if (nodoSeleccionado != null)
                    {
                        <RadzenButton Text="Editar nodo"
                                      ButtonStyle="ButtonStyle.Warning"
                                      Icon=""
                                      Click="@(() => CargarNodoParaEditar(nodoSeleccionado))" />

                        <RadzenButton Text="Eliminar nodo"
                                      ButtonStyle="ButtonStyle.Danger"
                                      Icon=""
                                      Click="@(() => EliminarNodo(nodoSeleccionado))" />
                    }
                </div>

        </RadzenFieldset>

        <RadzenFieldset Text="Cargar / Editar Plantilla" Style="max-width: 100%;">
                <RadzenTextBox @bind-Value="plantilla.NombreArchivo"
                               Placeholder="Nombre de la plantilla"
                               Class="w-100 mb-3" />

                <RadzenTextBox @bind-Value="plantilla.Version"
                               Placeholder="Versión"
                               Class="w-100 mb-3" />

                <RadzenTextBox @bind-Value="plantilla.Referencia"
                               Placeholder="Referencia"
                               Class="w-100 mb-3" />

                <RadzenDropDown @bind-Value="plantilla.Estado"
                                Data="@estadosDisponibles"
                                Placeholder="Seleccione el estado"
                                AllowCustom="true"
                                Class="w-100 mb-3" />

                <InputFile OnChange="OnFileUpload"
                           accept=".docx,.pdf,.txt"
                           class="form-control mb-3" />

                <div class="mb-3">
                    <RadzenButton Text="Nueva Plantilla"
                                  Icon="save"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="AgregarPlantilla"
                                  Class="me-2" />

                    <RadzenButton Text="Actualizar"
                                  Icon="edit"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Click="ActualizarPlantilla"
                                  Disabled="@string.IsNullOrWhiteSpace(rutaSeleccionada)"
                                  Class="me-2" />

                    <RadzenButton Text="Eliminar"
                                  Icon="delete"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Click="EliminarPlantilla"
                                  Disabled="@string.IsNullOrWhiteSpace(rutaSeleccionada)" />
                </div>

                @if (!string.IsNullOrEmpty(mensaje2))
                {
                    <div class="alert @(mensaje2.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                        @mensaje2
                    </div>
                }
            </RadzenFieldset>
        </RadzenFieldset>
</RadzenColumn>

    <!-- Columna derecha -->
    <RadzenColumn Width="6">
        <RadzenFieldset>
            <!--///////////////////////////////////////////////////////////////////////////////////////////-->
            <RadzenFieldset Text="Datos del Documento" Style="max-width: 100%;">
            <RadzenFieldset>
                <RadzenTextBox @bind-Value="documento.Nombre"
                               Placeholder="Nombre del documento"
                               Name="Nombre"
                               Class="w-100 mb-3" />

                <RadzenDropDown @bind-Value="documento.PlantillaId"
                                Data="@plantillas"
                                TextProperty="NombreArchivo"
                                ValueProperty="Id"
                                Placeholder="Seleccione plantilla"
                                Class="w-100 mb-3" />
                
                <div class="">


                <RadzenButton Text="@(DocumentoId.HasValue ? "Actualizar Documento" : "Registrar Documento")"
                              Icon="@(DocumentoId.HasValue ? "refresh" : "save")"
                              ButtonStyle="@(DocumentoId.HasValue ? ButtonStyle.Warning : ButtonStyle.Success)"
                              Click="@GuardarDocumento"
                              Class="me-2" />

                <RadzenButton Text="@(DocumentoId.HasValue ? "Cancelar edición" : "Documentos Registrados")"
                              Icon="arrow_back"
                              ButtonStyle="ButtonStyle.Primary"
                              Click="@(() => {
                                  if (DocumentoId.HasValue)
                                  {
                                      CancelarEdicion2();
                                  }
                                  else
                                  {
                                      IrAInicio();
                                  }
                              })"
                              Style="margin-left: 10px;" />


                </div>

                @if (!string.IsNullOrEmpty(mensajes))
                {
                    <div class="alert @(mensajes.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                        @mensajes
                    </div>
                }

            </RadzenFieldset>
    </RadzenFieldset>
            <!--///////////////////////////////////////////////////////////////////////////////////////////-->
            <!--///////////////////////////////////////////////////////////////////////////////////////////-->

            <RadzenFieldset Text="Documentos Arbol Documental">
            <RadzenDataGrid Data="@documentos" TItem="DocumentoExtendido" AllowPaging="true" PageSize="3"
                            AllowSorting="true"
                            FilterMode="FilterMode.Simple"
                            ShowPagingSummary="true"
                            >
                <Columns>
                        <!--<RadzenDataGridColumn TItem="DocumentoExtendido" Property="Id" Title="ID" />-->
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nombre" Title="Nombre" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Referencia" Title="Referencia" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="NombrePlantilla" Title="Plantilla" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Categoria" Title="Categoría" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="SubCategoria" Title="Subcategoría" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nodo" Title="Nodo Final" />
                        <!--<RadzenDataGridColumn TItem="DocumentoExtendido" Property="FechaCreacion" Title="Creación" FormatString="{0:yyyy-MM-dd}" />-->
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Title="Acciones">
                        <Template Context="doc">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Style="margin-right: 5px;" ButtonStyle="ButtonStyle.Info"
                                          Click="() => EditarDocumento(doc.Id)" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                          Click="() => EliminarDocumento(doc.Id)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
			</RadzenFieldset>

            <!--///////////////////////////////////////////////////////////////////////////////////////////-->
            <!--///////////////////////////////////////////////////////////////////////////////////////////-->
            <!-- DataGrid de plantillas -->
        <RadzenFieldset Text="Plantillas Documentos">
         
                        <RadzenDataGrid TItem="Plantilla" Data="@listaPlantillas" RowSelect="OnSeleccionarDesdeGrid"
                            AllowPaging="true" PageSize="3"
                            AllowSorting="true"
                            FilterMode="FilterMode.Simple"
                            ShowPagingSummary="true"
                            >
                <Columns>
                    <RadzenDataGridColumn TItem="Plantilla" Property="Id" Title="ID" Width="50px" />
                    <RadzenDataGridColumn TItem="Plantilla" Property="NombreArchivo" Title="Nombre" />
                    <RadzenDataGridColumn TItem="Plantilla" Property="Version" Title="Versión" />
                    <RadzenDataGridColumn TItem="Plantilla" Property="Referencia" Title="Referencia" />
                    <RadzenDataGridColumn TItem="Plantilla" Property="Estado" Title="Estado" />
                    <RadzenDataGridColumn TItem="Plantilla" Title="Acción">
                        <Template Context="data">
                            <RadzenButton Icon="visibility" Size="ButtonSize.Small" Click="@(() => showModal = true)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenFieldset>
	</RadzenFieldset>
</RadzenColumn>
</RadzenRow>

@if (showModal)
{
    <div style="
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background-color: rgba(0, 0, 0, 0.5);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 9999;">

        <div style="
                    background: white;
                    padding: 20px;
                    border-radius: 10px;
                    width: 90%;
                    max-width: 1000px;
                    max-height: 90vh;
                    overflow-y: auto;
                    box-shadow: 0 0 10px rgba(0,0,0,0.5);">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="m-0">📄 Vista previa del documento</h5>
                <button class="btn btn-sm btn-danger" @onclick="() => showModal = false">X</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(rutaSeleccionada) &&
                    rutaSeleccionada.StartsWith("data:application/pdf", StringComparison.OrdinalIgnoreCase))
            {
                <iframe src="@rutaSeleccionada"
                        width="100%" height="600px"
                        style="border: 1px solid #ccc; border-radius: 8px;" />
            }
            else
            {
                <p class="text-danger">⚠️ El archivo seleccionado no es un PDF válido.</p>
            }
        </div>
    </div>
}


@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <RadzenAlert Severity="AlertSeverity.Info" Style="margin-top: 15px;">@mensaje</RadzenAlert>
}


@if (!string.IsNullOrEmpty(nombreSeleccionado))
{
    <RadzenAlert Style="margin-bottom: 10px;" Severity="Info">
        <b>@tipoSeleccionado</b>: <i>@nombreSeleccionado</i>
    </RadzenAlert>
}


@if (!string.IsNullOrEmpty(mensajes2))
{
    <div class="alert @(mensajes2.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
        @mensajes2
    </div>
}

@code {



    string mensajes;
    string mensajes2;
    bool esNuevo = true;
    int IdAplicacion = 18;
    private string mensaje;
    private string? mensaje2;
    Plantilla plantilla = new();
    Documento documento = new();
    string tipoSeleccionado = "";
    private bool editando = false;
    private bool showModal = false;
    string nombreSeleccionado = "";
    private string? rutaSeleccionada;
    List<Plantilla> plantillas = new();
    List<Categoria> categorias = new();
    private int? plantillaSeleccionadaId;
    [Parameter] public int Id { get; set;}
    List<NodoCategoria> ListaNodos = new(); // debe contener TODA la estructura
    List<NodoCategoria> todosNodos = new();
    private NodoCategoria nuevoNodo = new();
    List<Plantilla> listaPlantillas = new();
    private NodoCategoria? nodoSeleccionado;
    List<NodoCategoria> nodosFiltrados = new();
    List<DocumentoExtendido> documentos = new();
    [Parameter] public int? NodoId { get; set; }
    List<NodoSeleccion> nivelesDinamicos = new();
    List<SubCategoria> todasSubcategorias = new();
    private List<NodoCategoria> nodosRaiz = new();
    [Parameter] public int? DocumentoId { get; set; }
    List<SubCategoria> subcategoriasFiltradas = new();
    List<NodoCategoria> jerarquiaSeleccionada = new();
    private List<NodoCategoria> nodosExistentes = new();

    List<string> estadosDisponibles = new() { "Activa", "Inactiva", "Obsoleta", "En revisión" };
    private string tituloSubnodos => $"Arbol De la Categoria {nodoSeleccionado?.Nombre ?? "..."}";

    int? nodoJerarquicoSeleccionadoId,
    categoriaSeleccionadaId,
    subCategoriaSeleccionadaId,
    nodoSeleccionadoId,
    nodoNivel1Id,
    nodoNivel2Id,
    nodoNivel3Id,
    nodoSeleccionadoFinalId;


    protected override async Task OnInitializedAsync()
    {
        nuevoNodo = new NodoCategoria(); // <-- esto es clave para que EditForm y validadores no fallen
        await CargarNodos();
        await CargarPlantillas2();
        await CargarPlantillas();
        await CargarCategorias();
        await CargarSubcategorias();
        await CargarNodos2();
        await CargarDocumentos();
        await CargarDocumento();

        if (NodoId.HasValue)
        {
            nodoSeleccionadoFinalId = NodoId.Value;
            await CargarJerarquiaDesdeNodo(nodoSeleccionadoFinalId.Value);
        }

        if (DocumentoId.HasValue)
        {
            await CargarDocumentoParaEditar(DocumentoId.Value);
        }
    }


    private async Task CargarNodos()
    {
        nodosExistentes.Clear();
        nodosRaiz.Clear();

        var dt = await ServicioUsuario.TraerConsultaAsync("SELECT Id, Nombre, PadreId, EsCategoria FROM NodoCategoria", 18);

        nodosExistentes = dt.Rows.Cast<DataRow>().Select(row => new NodoCategoria
        {
            Id = Convert.ToInt32(row["Id"]),
            Nombre = row["Nombre"].ToString() ?? "",
            PadreId = row["PadreId"] != DBNull.Value ? Convert.ToInt32(row["PadreId"]) : (int?)null,
            EsCategoria = Convert.ToBoolean(row["EsCategoria"])
        }).ToList();

        var nodosPadres = nodosExistentes.Where(n => n.PadreId == null).ToList();

        foreach (var raiz in nodosPadres)
        {
            nodosRaiz.Add(ConstruirJerarquia(raiz));
        }
    }

    private NodoCategoria ConstruirJerarquia(NodoCategoria nodo)
    {
        nodo.Hijos = nodosExistentes.Where(n => n.PadreId == nodo.Id).Select(ConstruirJerarquia).ToList();
        return nodo;
    }

    private async Task GuardarNodo()
    {
        if (string.IsNullOrWhiteSpace(nuevoNodo.Nombre))
        {
            notificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Error,
            Summary = "Campo requerido",
            Detail = "El nombre del nodo no puede estar vacío.",
            Duration = 4000
        });
            return;
        }

        try
        {
            // 🧱 Crear tabla NodoCategoria
            var tablaNodo = new DataTable("NodoCategoria");
            tablaNodo.Columns.Add("Id", typeof(int));
            tablaNodo.Columns.Add("Nombre", typeof(string));
            tablaNodo.Columns.Add("PadreId", typeof(int));
            tablaNodo.Columns.Add("EsCategoria", typeof(bool));

            var rowNodo = tablaNodo.NewRow();
            rowNodo["Id"] = nuevoNodo.Id;
            rowNodo["Nombre"] = nuevoNodo.Nombre;
            rowNodo["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId : DBNull.Value;
            rowNodo["EsCategoria"] = nuevoNodo.EsCategoria;
            tablaNodo.Rows.Add(rowNodo);

            if (editando)
            {
                await ServicioUsuario.ActualizarFilasAsync(tablaNodo, 18);
                mensaje = "✅ Nodo actualizado correctamente.";

                var nodoAnterior = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.Id);
                if (nodoAnterior != null)
                {
                    // 🔄 Cambio de Subcategoría → Categoría
                    if (!nodoAnterior.EsCategoria && nuevoNodo.EsCategoria)
                    {
                        var tablaCat = new DataTable("Categoria");
                        tablaCat.Columns.Add("Id", typeof(int));
                        tablaCat.Columns.Add("Nombre", typeof(string));
                        tablaCat.Columns.Add("PadreId", typeof(int));

                        var rowCat = tablaCat.NewRow();
                        rowCat["Id"] = nuevoNodo.Id;
                        rowCat["Nombre"] = nuevoNodo.Nombre;
                        rowCat["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId.Value : DBNull.Value;
                        tablaCat.Rows.Add(rowCat);

                        await ServicioUsuario.InsertarTablaAsync(tablaCat, "Categoria", 18);

                        // También podrías eliminar de SubCategoria si existía antes
                        var eliminarSub = new DataTable("SubCategoria");
                        eliminarSub.Columns.Add("Id", typeof(int));
                        var rowDel = eliminarSub.NewRow();
                        rowDel["Id"] = nuevoNodo.Id;
                        eliminarSub.Rows.Add(rowDel);
                        await ServicioUsuario.EliminarFilaAsync(eliminarSub, 18);
                    }

                    // 🔄 Cambio de Categoría → Subcategoría (esto es raro pero posible)
                    else if (nodoAnterior.EsCategoria && !nuevoNodo.EsCategoria && nuevoNodo.PadreId.HasValue)
                    {
                        // Insertar en SubCategoria
                        var padre = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.PadreId.Value);
                        if (padre != null && padre.EsCategoria)
                        {
                            var nombreEscapadoInterno = padre.Nombre.Replace("'", "''");
                            var consultaSql = $@"
                    SELECT Id FROM Categoria WHERE Nombre = '{nombreEscapadoInterno}'";
                            var dtCategoria = await ServicioUsuario.TraerConsultaAsync(consultaSql, 18);

                            if (dtCategoria.Rows.Count > 0)
                            {
                                int categoriaId = Convert.ToInt32(dtCategoria.Rows[0]["Id"]);

                                var tablaSub = new DataTable("SubCategoria");
                                tablaSub.Columns.Add("Id", typeof(int));
                                tablaSub.Columns.Add("CategoriaId", typeof(int));
                                tablaSub.Columns.Add("Nombre", typeof(string));

                                var rowSub = tablaSub.NewRow();
                                rowSub["Id"] = nuevoNodo.Id;
                                rowSub["CategoriaId"] = categoriaId;
                                rowSub["Nombre"] = nuevoNodo.Nombre;
                                tablaSub.Rows.Add(rowSub);

                                await ServicioUsuario.InsertarTablaAsync(tablaSub, "SubCategoria", 18);
                            }
                        }

                        // También podrías eliminar de Categoria si existía antes
                        var eliminarCat = new DataTable("Categoria");
                        eliminarCat.Columns.Add("Id", typeof(int));
                        var rowCatDel = eliminarCat.NewRow();
                        rowCatDel["Id"] = nuevoNodo.Id;
                        eliminarCat.Rows.Add(rowCatDel);
                        await ServicioUsuario.EliminarFilaAsync(eliminarCat, 18);
                    }
                }
            }


            else
            {
                await ServicioUsuario.InsertarTablaAsync(tablaNodo, "NodoCategoria", 18);
                mensaje = "✅ Nodo guardado correctamente.";

                // Recuperar el nuevo ID insertado
                var nombreEscapado = nuevoNodo.Nombre.Replace("'", "''");
                var dtNuevoNodo = await ServicioUsuario.TraerConsultaAsync($@"
                SELECT TOP 1 Id FROM NodoCategoria
                WHERE Nombre = '{nombreEscapado}'
                ORDER BY Id DESC", 18);

                if (dtNuevoNodo.Rows.Count > 0)
                {
                    nuevoNodo.Id = Convert.ToInt32(dtNuevoNodo.Rows[0]["Id"]);
                }
                else
                {
                    throw new Exception("No se pudo recuperar el ID del nuevo nodo.");
                }

                // 🔵 1. Si es Categoría, insertar también en Categoria
                if (nuevoNodo.EsCategoria)
                {
                    var tablaCat = new DataTable("Categoria");
                    tablaCat.Columns.Add("Id", typeof(int));
                    tablaCat.Columns.Add("Nombre", typeof(string));
                    tablaCat.Columns.Add("PadreId", typeof(int));

                    var rowCat = tablaCat.NewRow();
                    rowCat["Id"] = nuevoNodo.Id;
                    rowCat["Nombre"] = nuevoNodo.Nombre;
                    rowCat["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId.Value : DBNull.Value;
                    tablaCat.Rows.Add(rowCat);

                    await ServicioUsuario.InsertarTablaAsync(tablaCat, "Categoria", 18);
                }

                // 🟡 2. Si NO es categoría y tiene padre...
                else if (nuevoNodo.PadreId.HasValue)
                {
                    var padre = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.PadreId.Value);
                    if (padre != null && padre.EsCategoria)
                    {
                        // Buscar ID real de Categoria con el mismo nombre que el nodo padre
                        var nombreEscapadoInterno = padre.Nombre.Replace("'", "''");
                        var consultaSql = $@"
    SELECT Id FROM Categoria WHERE Nombre = '{nombreEscapadoInterno}'";
                        var dtCategoria = await ServicioUsuario.TraerConsultaAsync(consultaSql, 18);



                        if (dtCategoria.Rows.Count == 0)
                            throw new Exception($"❌ El padre con Id {padre.Id} no existe en la tabla Categoria.");

                        int categoriaId = Convert.ToInt32(dtCategoria.Rows[0]["Id"]);

                        // Insertar en SubCategoria
                        var tablaSub = new DataTable("SubCategoria");
                        tablaSub.Columns.Add("Id", typeof(int));
                        tablaSub.Columns.Add("CategoriaId", typeof(int));
                        tablaSub.Columns.Add("Nombre", typeof(string));

                        var rowSub = tablaSub.NewRow();
                        rowSub["Id"] = 0;
                        rowSub["CategoriaId"] = categoriaId;
                        rowSub["Nombre"] = nuevoNodo.Nombre;
                        tablaSub.Rows.Add(rowSub);

                        await ServicioUsuario.InsertarTablaAsync(tablaSub, "SubCategoria", 18);
                    }
                }
            }

            nuevoNodo = new();
            editando = false;
            await CargarNodos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al guardar nodo: {ex.Message}";
        }
    }

    private async Task<bool> ExisteCategoria(int idCategoria)
    {
        var dt = await ServicioUsuario.TraerConsultaAsync($"SELECT COUNT(*) AS Total FROM Categoria WHERE Id = {idCategoria}", 18);
        return Convert.ToInt32(dt.Rows[0]["Total"]) > 0;
    }

    private async Task EliminarNodo(NodoCategoria nodo)
    {
        try
        {
            if (nodosExistentes.Any(n => n.PadreId == nodo.Id))
            {
                mensaje = "❌ No se puede eliminar un nodo que tiene hijos.";
                return;
            }

            var tabla = new DataTable("NodoCategoria");
            tabla.Columns.Add("Id", typeof(int));
            var row = tabla.NewRow();
            row["Id"] = nodo.Id;
            tabla.Rows.Add(row);

            await ServicioUsuario.EliminarFilaAsync(tabla, 18);
            mensaje = "✅ Nodo eliminado correctamente.";
            await CargarNodos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al eliminar nodo: {ex.Message}";
        }
    }

    private void CargarNodoParaEditar(NodoCategoria nodo)
    {
        nuevoNodo = new NodoCategoria
        {
            Id = nodo.Id,
            Nombre = nodo.Nombre,
            PadreId = nodo.PadreId,
            EsCategoria = nodo.EsCategoria
        };
        editando = true;
    }

    private void CancelarEdicion()
    {
        nuevoNodo = new();
        editando = false;
    }

    private async Task SeleccionarNodo(NodoCategoria nodo)
    {
        nodoSeleccionado = nodo;
    }

    private void PrepararNuevaCategoria()
    {
        nuevoNodo = new NodoCategoria
        {
            Id = 0,
            Nombre = "",
            PadreId = null,
            EsCategoria = true
        };

        editando = false;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////

    async Task CargarPlantillas()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);
        plantillas = ds.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString()
        }).ToList();
