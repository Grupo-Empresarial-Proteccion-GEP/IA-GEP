<EditForm Model="@this" OnValidSubmit="SendToGemini">
    <div class="p-4" style="background-color: #f5f5f5; transform: scale(0.80); transform-origin: top center;">
        <RadzenCard Style="padding: 20px;">
            <div class="text-center mb-4">
                <h6 class="fw-bold fs-6">📄 Generador Inteligente de Documentos</h6>
            </div>

            <div class="row gy-4">
                <!-- COLUMNA IZQUIERDA -->
                <div class="col-lg-6">
                    <RadzenFieldset Text="Buscar Usuario">
                        <div class="d-flex gap-2">
                            <RadzenTextBox Placeholder="Buscar por documento" Style="width: 100%; margin-bottom: 10px;" @bind-Value="nombreBuscado" />
                            <RadzenButton Icon="search" Shade="Shade.Lighter" Click="@BuscarClientePorDocumento" Style="width: 20%; margin-bottom: 10px;" Disabled="@buscandoCliente" />
                        </div>
                    </RadzenFieldset>

                    <div class="row">

                        <!-- Receptor -->
                        <div class="col-md-6">
                            <RadzenFieldset Text="Entidad">

                                <RadzenDropDown @bind-Value="entidadSeleccionadaId"
                                                Data="@entidades"
                                                TextProperty="Nombre"
                                                ValueProperty="Id"
                                                Placeholder="Seleccione una entidad"
                                                Change="@OnEntidadSeleccionada"
                                                AllowFiltering="true"
                                                Class="w-100 mb-2" />

                                <RadzenDropDown @bind-Value="subdivisionSeleccionadaId"
                                                Data="@subdivisiones"
                                                TextProperty="NombreSubdiv"
                                                ValueProperty="Id"
                                                Placeholder="Seleccione una subdivisión"
                                                Disabled="@(!entidadSeleccionadaId.HasValue)"
                                                Class="w-100 mb-2" />

                                <RadzenDropDown @bind-Value="servicioSeleccionadoId"
                                                Data="@servicios"
                                                TextProperty="ServicioBrindado"
                                                ValueProperty="Id"
                                                Placeholder="Seleccione un servicio"
                                                Disabled="@(!entidadSeleccionadaId.HasValue)"
                                                Class="w-100 mb-2" />


                                <RadzenFieldset Text="Configuracion Adicional">


                                    <RadzenDropDown @bind-Value="documentoSeleccionadoId"
                                                    Data="@documentosDisponibles"
                                                    TextProperty="NombreCompleto"
                                                    ValueProperty="DocumentoId"
                                                    Change="OnDocumentoSeleccionado"
                                                    Placeholder="Selecciona un documento"
                                                    Style="width: 100%; margin-bottom: 10px;" />


                                                      
                                    <RadzenDropDown Placeholder="Seleccionar IA" @bind-Value="IASeleccionada" Data="@iasDisponibles" Style="width: 100%; margin-bottom: 10px;"
                                                    Change="@(value => CambiarIA(value?.ToString()))" />
                                </RadzenFieldset>
                            </RadzenFieldset>


                        </div>

                        <!-- Emisor -->
                        <div class="col-md-6">
                            <RadzenFieldset Text="Cliente">
                                <RadzenTextBox Placeholder="Nombre" @bind-Value="Emisor" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenDropDown Placeholder="Tipo de documento" @bind-Value="Documento_E" Data="@tiposDocumento" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Número de documento" @bind-Value="NumeroDoc_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Dirección" @bind-Value="Direccion_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Teléfono" @bind-Value="Telefono_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Correo" @bind-Value="Correo_E" Style="width: 100%; margin-bottom: 10px;" />
                            </RadzenFieldset>
                        </div>
                    </div>



                    <RadzenFieldset Text="Descripción para la IA">

                        <RadzenTextArea @bind-Value="UserPrompt" Placeholder="Describe claramente qué quieres generar o analizar..." Style="width: 100%; min-height: 385px;" />
                    </RadzenFieldset>
                </div>

                <!-- COLUMNA DERECHA -->
                <div class="col-lg-6 d-flex flex-column">
                    <RadzenFieldset Text="Adjuntar archivo">
                        <InputFile OnChange="HandleFileSelected" @key="inputFileKey" class="form-control mb-3" disabled="@cargantwo" />
                        <div class="d-flex gap-3 mt-3 justify-content-end">
                            <RadzenButton Icon="done_all" Text="Generar" Shade="Shade.Lighter" Click="@EnviarYLimpiarDespues" Disabled="@cargando" ButtonStyle="ButtonStyle.Success" Style="width: 20%; margin-bottom: 10px;" />
                            <RadzenButton Icon="chrome_reader_mode" Text="Analizar" Shade="Shade.Lighter" Click="@EnviarYLimpiarDespues2" Disabled="@cargantwo" ButtonStyle="ButtonStyle.Warning" Style="width: 20%; margin-bottom: 10px;" />
                        </div>
                    </RadzenFieldset>

                    <RadzenFieldset Text="Resultado" Style="margin-top: 1.5rem; flex-grow: 1;">
                        <div style="height:680px; overflow-y: auto; border: 1px solid #ccc; padding: 10px;">
                            @if (opcionesGeneradas?.Any() == true && mostrarSugerencias)
                            {
                                <p><strong>Sugerencias Generadas:</strong></p>
                                @foreach (var opcion in opcionesGeneradas)
                                {
                                    <RadzenCheckBox TValue="bool" ValueChanged="(val => OnCheckboxChanged(opcion, val))" /> @opcion

                                    <br />
                                }
                            }
                            else if (!string.IsNullOrWhiteSpace(ResponseText))
                            {
                                <div contenteditable="true" @ref="editorRef" @onblur="ActualizarTextoEditable">
                                    @((MarkupString)ResponseText)
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Aún no hay contenido generado.</p>
                            }
                        </div>
                    </RadzenFieldset>

                    <div class="d-flex gap-3 mt-3 justify-content-end">
                        <RadzenButton Text="Descargar" Shade="Shade.Lighter" Click="@DescargarDocSimple" Icon="download" Style="width: 20%; margin-bottom: 10px;" ButtonStyle="ButtonStyle.Success" />
                        <RadzenButton Text="Historial" Shade="Shade.Lighter" Click="@(() => showModal = true)"  Icon="history" Style="width: 20%; margin-bottom: 10px;" ButtonStyle="ButtonStyle.Warning" />
                    </div>
                </div>
            </div>
        </RadzenCard>
    </div>
</EditForm>

