    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private string LimpiarInstrucciones(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) return string.Empty;

        // 1. Eliminar bloques Markdown ``` ``` de cualquier tipo
        texto = Regex.Replace(texto, @"```[\s\S]*?```", "", RegexOptions.Multiline | RegexOptions.IgnoreCase);

        // 2. Eliminar etiquetas <pre>, <code>
        texto = Regex.Replace(texto, @"<pre[\s\S]*?</pre>", "", RegexOptions.IgnoreCase);
        texto = Regex.Replace(texto, @"<code[\s\S]*?</code>", "", RegexOptions.IgnoreCase);

        // 3. Frases o patrones a eliminar (instrucciones y contenido repetitivo)
        var instrucciones = new[]
        {
        "usa etiquetas como",
        "genera la respuesta como html",
        "formatea como html",
        "no uses markdown",
        "responde en formato html",
        "por favor responde en html",
        "instrucciones del usuario:",
        "archivo cargado:",
        "el contenido debe estar completamente redactado como si fuera un documento final",
        "ten en cuenta estas respuestas anteriores para mantener coherencia",
        "no uses bloques de código ni markdown",
        "--- ?? el contenido debe estar completamente redactado como",
        ", , ,1q, etc. No uses bloques de código ni markdown.",
        "Usa etiquetas HTML (<p>, <strong>, <h2>, <br>, etc.)."
    };

        // 4. Eliminar líneas que contengan alguna de las frases anteriores
        var lineas = texto.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
        var contenidoFiltrado = lineas
            .Where(linea =>
                !instrucciones.Any(instr =>
                    linea.ToLowerInvariant().Contains(instr.ToLowerInvariant())
                )
            )
            .ToList();

        return string.Join("\n", contenidoFiltrado).Trim();
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private string ExtraerContenidoHtml(string respuesta)
    {
        if (string.IsNullOrEmpty(respuesta)) return string.Empty;

        var inicio = respuesta.IndexOf("<body>");
        var fin = respuesta.IndexOf("</body>");
        if (inicio != -1 && fin != -1)
        {
            return respuesta.Substring(inicio + 6, fin - inicio - 6); // 6 = length de "<body>"
        }

        return respuesta;
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
