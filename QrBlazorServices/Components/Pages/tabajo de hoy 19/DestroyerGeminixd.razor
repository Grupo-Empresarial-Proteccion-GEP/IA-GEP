    private async Task CargarEntidades()
    {
        var dt = await ServicioUsuario.TraerTablaAsync("Entidades", IdAplicacion);
        entidades = dt.AsEnumerable().Select(row => new Entidad
        {
            Id = Convert.ToInt32(row["Id"]),
            Nombre = row["Nombre"]?.ToString(),
            TipoDocumento = row["TipoDocumento"]?.ToString(),
            NumeroDocumento = row["NumeroDocumento"]?.ToString(),
            Direccion = row["Direccion"]?.ToString(),
            Telefono = row["Telefono"]?.ToString(),
            Correo = row["Correo"]?.ToString(),
            Ciudad = row["Ciudad"]?.ToString(),
            Departamento = row["Departamento"]?.ToString(),
            TipoEntidadId = Convert.ToInt32(row["TipoEntidadId"]) // ya lo tienes
        }).ToList();
    }

    private async Task OnEntidadSeleccionada(object value)
    {
        entidadSeleccionadaId = (int?)value;

        var entidad = entidades.FirstOrDefault(e => e.Id == entidadSeleccionadaId);
        if (entidad != null)
        {
            Receptor = entidad.Nombre;
            Documento_R = entidad.TipoDocumento;
            NumeroDoc_R = entidad.NumeroDocumento;
            Direccion_R = entidad.Direccion;
            Telefono_R = entidad.Telefono;
            Correo_R = entidad.Correo;
        }

        await CargarServicios();
        await CargarSubdivisiones();

        // Selección automática del primer servicio y subdivisión
        var servicio = servicios.FirstOrDefault();
        var subdiv = subdivisiones.FirstOrDefault();

        servicioSeleccionadoId = servicio?.Id;
        subdivisionSeleccionadaId = subdiv?.Id;

        // ✅ Asignar información adicional del servicio
        Servicio_R = servicio?.ServicioBrindado;
        DireccionServicio_R = entidad?.Direccion; // o puede venir de otro lado si aplica

        // ✅ Asignar información adicional de la subdivisión
        Subdiv_R = subdiv?.NombreSubdiv;
        Responsable_R = subdiv?.Responsable;
        DireccionSubdiv_R = subdiv?.Direccion;
        TelefonoSubdiv_R = subdiv?.Telefono;
        CorreoSubdiv_R = subdiv?.Correo;
    }

    private async Task CargarServicios()
    {
        var dt = await ServicioUsuario.TraerConsultaAsync(
            $"SELECT * FROM Servicios WHERE EntidadId = {entidadSeleccionadaId}", IdAplicacion);

        servicios = dt.AsEnumerable().Select(r => new Servicio
        {
            Id = Convert.ToInt32(r["Id"]),
            EntidadId = Convert.ToInt32(r["EntidadId"]),
            ServicioBrindado = r["ServicioBrindado"].ToString()
        }).ToList();
    }

    private async Task CargarSubdivisiones()
    {
        var dt = await ServicioUsuario.TraerConsultaAsync(
            $"SELECT * FROM Subdivisiones WHERE EntidadId = {entidadSeleccionadaId}", IdAplicacion);

        subdivisiones = dt.AsEnumerable().Select(r => new Subdivision
        {
            Id = Convert.ToInt32(r["Id"]),
            EntidadId = Convert.ToInt32(r["EntidadId"]),
            NombreSubdiv = r["NombreSubdiv"].ToString(),
            Ciudad = r["Ciudad"].ToString(),
            Direccion = r["Direccion"].ToString(),
            Telefono = r["Telefono"].ToString(),
            Correo = r["Correo"].ToString(),
            Responsable = r["Responsable"].ToString()
        }).ToList();
    }

