@if (showModal)
{
    <div style="
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex; justify-content: center; align-items: center;
        z-index: 9999;">

        <div style="
            background: white;
            padding: 20px;
            border-radius: 10px;
            width: 60%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
            box-sizing: border-box;
            ">
            <!-- Encabezado -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="m-0">📚 Historial de Chat</h5>
                <button class="btn btn-sm btn-danger" @onclick="() => showModal = false">X</button>
            </div>

            <!-- Contenido del historial -->
            @if (ChatService.ChatHistory?.Any() == true)
            {
                <div class="d-flex flex-column gap-3">
                    @foreach (var mensaje in ChatService.ChatHistory)
                    {
                        <div class="p-3 border rounded bg-light shadow-sm">
                            @if (mensaje.Role == "user")
                            {
                                <p class="fw-bold text-primary mb-1">🧑‍💻 Tú:</p>
                                <p class="mb-0">@LimpiarInstrucciones(mensaje.Content)</p>
                            }
                            else if (mensaje.Role == "assistant")
                            {
                                <p class="fw-bold text-success mb-1">🤖 Asistente:</p>
                                <div style="cursor: pointer;"
                                     @onclick="() => SeleccionarRespuesta(mensaje.Content)">
                                    @((MarkupString)ExtraerContenidoHtml(LimpiarInstrucciones(mensaje.Content)))
                                    <div class="text-end text-muted small"><em>📎 Click para volver a mostrar</em></div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted">No hay historial disponible.</p>
            }
        </div>
    </div>
}


