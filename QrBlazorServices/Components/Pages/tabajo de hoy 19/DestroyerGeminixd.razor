    private async Task CargarDocumentosParaSeleccion()
    {
        var sql = @"
SELECT
    d.Id AS DocumentoId,
    d.Nombre AS NombreDocumento,
    c.Nombre AS Categoria,
    sc.Nombre AS SubCategoria,
    nc.Nombre AS Nodo,
    p.Referencia,
    p.Version,
    p.Estado,
    p.RutaArchivo
FROM Documento d
LEFT JOIN DocumentoCategoria dc ON d.Id = dc.DocumentoId
LEFT JOIN SubCategoria sc ON dc.SubCategoriaId = sc.Id
LEFT JOIN Categoria c ON sc.CategoriaId = c.Id
LEFT JOIN NodoCategoria nc ON dc.NodoCategoriaId = nc.Id
LEFT JOIN Plantilla p ON d.PlantillaId = p.Id

    ";

        var dt = await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);

        documentosDisponibles = dt.AsEnumerable().Select(r => new DocumentoSeleccion
        {
            DocumentoId = Convert.ToInt32(r["DocumentoId"]),
            Nombre = r["NombreDocumento"]?.ToString() ?? "",
            Categoria = r["Categoria"]?.ToString() ?? "-",
            SubCategoria = r["SubCategoria"]?.ToString() ?? "-",
            Nodo = r["Nodo"]?.ToString() ?? "-",
            Referencia = r["Referencia"]?.ToString() ?? "",
            Version = r["Version"]?.ToString() ?? "",
            Estado = r["Estado"]?.ToString() ?? "",
            RutaArchivo = r["RutaArchivo"]?.ToString() ?? ""
        }).ToList();

    }

    private DocumentoSeleccion? documentoSeleccionado;
    private async Task OnDocumentoSeleccionado(object value)
    {
        if (value is null)
            return;

        if (int.TryParse(value.ToString(), out int id))
        {
            documentoSeleccionadoId = id;
            documentoSeleccionado = documentosDisponibles.FirstOrDefault(d => d.DocumentoId == id);

            if (documentoSeleccionado is not null)
            {
                Asunto = documentoSeleccionado.Nombre;
                TipoDocumento = documentoSeleccionado.Nombre; 
            }

        }
    }


