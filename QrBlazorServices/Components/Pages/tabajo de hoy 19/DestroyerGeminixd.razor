    public class OpcionCheckbox
    {
        public string Texto { get; set; }
        public bool Seleccionada { get; set; }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    void OnCheckboxChanged(string opcion, bool isChecked)
    {
        // Agrega o elimina la opción seleccionada de la lista
        if (isChecked)
        {
            if (!opcionesSeleccionadas.Contains(opcion))
                opcionesSeleccionadas.Add(opcion);
        }
        else
        {
            if (opcionesSeleccionadas.Contains(opcion))
                opcionesSeleccionadas.Remove(opcion);
        }

        // Después de actualizar la selección, guardamos las opciones seleccionadas
        GuardarSeleccionadas();
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private void GuardarSeleccionadas()
    {
        // Unimos las opciones seleccionadas en un solo string
        var seleccionadas = opcionesSeleccionadas;

        // Si hay opciones seleccionadas, formateamos el texto
        if (seleccionadas.Any())
        {
            contenidoAuxiliar = "\n" + string.Join("\n", seleccionadas);
        }
        else
        {
            contenidoAuxiliar = "";
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    public static string EliminarDuplicadosConCheckboxes(string texto)
    {
        // Expresión regular para capturar solo las opciones numeradas dentro de <li> o <p>
        var matches = Regex.Matches(texto, @"<li>\s*(\d+\.)\s(.*?)</li>|<p>\s*(\d+\.)\s(.*?)</p>", RegexOptions.IgnoreCase);

        var únicas = new HashSet<string>();
        var resultado = new List<string>();

        // Extraer las opciones numeradas, eliminar duplicados y generar checkboxes
        foreach (Match match in matches)
        {
            string opcion = match.Groups[2].Value.Trim();
            if (!string.IsNullOrEmpty(opcion) && !únicas.Contains(opcion))
            {
                únicas.Add(opcion);

                // Crear checkbox HTML para cada opción
                string checkboxHtml = $"<input type='checkbox' id='{opcion.Replace(" ", "_")}' name='opcion' value='{opcion}'><label for='{opcion.Replace(" ", "_")}'> {opcion}</label><br>";
                resultado.Add(checkboxHtml);
            }
        }

        // Unir las opciones con checkboxes en un solo string HTML
        return string.Join("\n", resultado);
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {

        // Pequeño retraso para que Blazor tenga tiempo de renderizar
        await Task.Delay(100);


        var file = e.File;
        var ext = Path.GetExtension(file.Name).ToLower();

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10_000_000).CopyToAsync(ms);

        if (ext == ".pdf")
        {
            fileContent = FileParser.ExtractTextFromPdf(ms);
        }
        else if (ext == ".docx")
        {
            fileContent = FileParser.ExtractTextFromDocx(ms);
        }
        else if (ext == ".txt")
        {
            ms.Position = 0;
            using var reader = new StreamReader(ms);
            fileContent = await reader.ReadToEndAsync();
        }

    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private async Task SendResumenDesdeArchivo()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(fileContent))
            {
                ResponseText = "<p><strong>No se ha podido leer el archivo.</strong></p>";
                return;
            }

            // Traer la plantilla desde la tabla Prompts
            string condicion = "Nombre = 'ResumenDesdeArchivo'";
            string campos = "Plantilla";
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Prompts", campos, condicion, 18);

            if (resultado == null || resultado.Rows.Count == 0)
            {
                ResponseText = "<p><strong>No se encontró el prompt configurado.</strong></p>";
                return;
            }

            // Obtener la plantilla y reemplazar el marcador
            string plantillaPrompt = resultado.Rows[0]["Plantilla"].ToString();
            string promptFinal = plantillaPrompt.Replace("{fileContent}", fileContent);

            // Enviar a IA
            ResponseText = await ChatService.SendMessageAsync(promptFinal);
            mostrarHtml = false;

            // Procesar respuesta
            string textoSinDuplicados = EliminarDuplicadosConCheckboxes(ResponseText);

            var matches = Regex.Matches(ResponseText, "<li>(.*?)</li>|<p>(.*?)</p>", RegexOptions.IgnoreCase);

            opcionesGeneradas = matches
                .Select(m => string.IsNullOrEmpty(m.Groups[1].Value) ? m.Groups[2].Value : m.Groups[1].Value)
                .Select(o => Regex.Replace(o, "<.*?>", "").Trim())
                .Distinct()
                .ToList();
        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }
        finally
        {
            cargantwo = false;
            inputFileKey = Guid.NewGuid().ToString();
            mostrarSugerencias = true;
        }
    }

    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private async Task SimularEscritura(string textoCompleto)
    {
        textoParcial = "";
        mostrarHtml = true;

        foreach (char letra in textoCompleto)
        {
            textoParcial += letra;
            StateHasChanged();
            await Task.Delay(1); // Puedes ajustar la velocidad aquí
        }
    }

