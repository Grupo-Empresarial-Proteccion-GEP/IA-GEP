    private async Task BuscarClientePorDocumento()
    {
        buscandoCliente = true;

        try
        {
            if (string.IsNullOrWhiteSpace(nombreBuscado))
            {
                mensaje = "Por favor ingrese un número de documento para buscar.";
                return;
            }

            string documento = nombreBuscado.Replace("'", "''");
            string condicion = $"NumeroDeDocumento = '{documento}'";
            string campos = "Nombre, TipoDeDocumento, NumeroDeDocumento, Direccion, Telefono, Correo";

            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Clientes", campos, condicion, 18);

            if (resultado != null && resultado.Rows.Count > 0)
            {
                var fila = resultado.Rows[0];

                Emisor = fila["Nombre"].ToString();
                Documento_E = fila["TipoDeDocumento"].ToString();
                NumeroDoc_E = fila["NumeroDeDocumento"].ToString();
                Direccion_E = fila["Direccion"].ToString();
                Telefono_E = fila["Telefono"].ToString();
                Correo_E = fila["Correo"].ToString();

                mensaje = "Cliente encontrado.";
            }
            else
            {
                mensaje = "No se encontró ningún cliente con ese documento.";
                Emisor = Documento_E = NumeroDoc_E = Direccion_E = Telefono_E = Correo_E = string.Empty;
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error al buscar cliente: {ex.Message}";
        }
        finally
        {
            buscandoCliente = false;
        }
    }

