    private async Task BuscarNodo()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda))
            return;

        LimpiarResaltado(nodosRaiz); 

        var nodoEncontrado = BuscarNodoPorNombre(nodosRaiz, textoBusqueda.Trim());

        if (nodoEncontrado != null)
        {
            nodoIdEncontrado = nodoEncontrado.Id;
            ExpandirRutaHastaNodo(nodoIdEncontrado);
            await InvokeAsync(StateHasChanged);
        }
        else
        {
            mensaje = "❌ Nodo no encontrado.";
        }
    }

    private NodoCategoria BuscarNodoPorNombre(List<NodoCategoria> nodos, string texto)
    {
        foreach (var nodo in nodos)
        {
            if (nodo.NombreOriginal.Contains(texto, StringComparison.OrdinalIgnoreCase))
            {
                nodo.EsNodoBuscado = true;
                nodo.Nombre = $"👉 {nodo.NombreOriginal}";
                return nodo;
            }

            var encontrado = BuscarNodoPorNombre(nodo.Hijos, texto);
            if (encontrado != null)
                return encontrado;
        }
        return null;
    }

    private void LimpiarResaltado(List<NodoCategoria> nodos)
    {
        foreach (var nodo in nodos)
        {
            if (nodo.EsNodoBuscado)
            {
                nodo.EsNodoBuscado = false;
                nodo.Nombre = nodo.NombreOriginal; 
            }

            if (nodo.Hijos?.Any() == true)
                LimpiarResaltado(nodo.Hijos);
        }
    }

