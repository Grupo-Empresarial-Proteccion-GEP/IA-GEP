                // 🔄 Actualizar relación DocumentoCategoria
                if (subCategoriaSeleccionadaId.HasValue)
                {
                    await ServicioUsuario.EliminarListadeLlavesAsync("DocumentoCategoria", "DocumentoId", DocumentoId.Value.ToString(), IdAplicacion);

                    var dtRelacion = await ServicioUsuario.TraerEsquemaTablaAsync("DocumentoCategoria", IdAplicacion);
                    var filaRelacion = dtRelacion.NewRow();

                    filaRelacion["DocumentoId"] = DocumentoId.Value;
                    filaRelacion["SubCategoriaId"] = subCategoriaSeleccionadaId.Value;
                    filaRelacion["NodoCategoriaId"] = nodoCategoriaIdFinal.HasValue ? nodoCategoriaIdFinal.Value : (object)DBNull.Value;

                    dtRelacion.Rows.Add(filaRelacion);
                    await ServicioUsuario.InsertarTablaAsync(dtRelacion, "DocumentoCategoria", IdAplicacion);
                }

                mensaje = "✅ Documento actualizado correctamente.";
                await CargarDocumentos();
            }
            else
            {
                // ✅ NUEVO REGISTRO
                var dtDocumento = await ServicioUsuario.TraerEsquemaTablaAsync("Documento", IdAplicacion);
                var fila = dtDocumento.NewRow();

                fila["Nombre"] = documento.Nombre.Trim();
                fila["PlantillaId"] = documento.PlantillaId ?? 0;
                fila["FechaCreacion"] = DateTime.Now;

                dtDocumento.Rows.Add(fila);
                await ServicioUsuario.InsertarTablaAsync(dtDocumento, "Documento", IdAplicacion);

                // 📌 Obtener ID recién insertado
                var consecutivo = await ServicioUsuario.TraerUltimoConsecutivoAsync("Documento", IdAplicacion);
                int nuevoDocumentoId = Convert.ToInt32(consecutivo.Rows[0][0]);

                // ➕ Insertar relación DocumentoCategoria
                var dtRelacion = await ServicioUsuario.TraerEsquemaTablaAsync("DocumentoCategoria", IdAplicacion);
                var filaRelacion = dtRelacion.NewRow();

                filaRelacion["DocumentoId"] = nuevoDocumentoId;
                filaRelacion["SubCategoriaId"] = subCategoriaSeleccionadaId.HasValue ? subCategoriaSeleccionadaId.Value : (object)DBNull.Value;
                filaRelacion["NodoCategoriaId"] = nodoCategoriaIdFinal.HasValue ? nodoCategoriaIdFinal.Value : (object)DBNull.Value;

                dtRelacion.Rows.Add(filaRelacion);
                await ServicioUsuario.InsertarTablaAsync(dtRelacion, "DocumentoCategoria", IdAplicacion);


                mensaje = "✅ Documento registrado correctamente.";
                documento = new(); // limpia el formulario
                await CargarDocumentos();
            }
        Console.WriteLine($"🧾 NodoCategoriaIdFinal recibido: {nodoCategoriaIdFinal}");
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al guardar documento: {ex.Message}";
        }

    }

   
    private int? ObtenerNodoCategoriaIdFinal()
{
    int? nodoId = null;

    // 1. Buscar en niveles dinámicos (si existen)
    if (nivelesDinamicos != null && nivelesDinamicos.Any())
    {
        for (int i = nivelesDinamicos.Count - 1; i >= 0; i--)
        {
            var nivel = nivelesDinamicos[i];
            if (nivel.NodoSeleccionadoId.HasValue)
            {
                nodoId = nivel.NodoSeleccionadoId;
                var nodo = todosNodos.FirstOrDefault(n => n.Id == nodoId);
                Console.WriteLine($"✅ Nodo final desde nivelesDinamicos: {nodo?.Nombre} (ID: {nodo?.Id})");
                return nodoId;
            }
        }
    }

    // 2. Fallback a nodoSeleccionadoId manualmente asignado
    if (nodoSeleccionadoId.HasValue)
    {
        var nodo = todosNodos.FirstOrDefault(n => n.Id == nodoSeleccionadoId.Value);
        Console.WriteLine($"✅ Nodo final desde nodoSeleccionadoId: {nodo?.Nombre} (ID: {nodo?.Id})");
        return nodoSeleccionadoId;
    }

    // 3. Nada válido
    Console.WriteLine("❌ No se encontró NodoCategoriaId válido en nivelesDinamicos ni en nodoSeleccionadoId.");
    return null;
}



