    async Task GuardarDocumentoYRama()
    {

        mensaje = string.Empty;

        if (string.IsNullOrWhiteSpace(nombreComun))
            mensaje += "❌ Debes escribir un nombre para la rama y el documento.\n";

        if (!documento.PlantillaId.HasValue || documento.PlantillaId.Value == 0)
            mensaje += "❌ Debes seleccionar una plantilla para el documento.\n";

        // ✅ DETENER si hay errores
        if (!string.IsNullOrEmpty(mensaje))
            return;

        nuevoNodo.Nombre = nombreComun;
        documento.Nombre = nombreComun;

        await GuardarNodo();

        var nombreEscapado = nombreComun.Replace("'", "''");
        var dtNodoReciente = await ServicioUsuario.TraerConsultaAsync($@"
            SELECT TOP 1 * FROM NodoCategoria 
            WHERE Nombre = '{nombreEscapado}'
            ORDER BY Id DESC", 18);

        if (dtNodoReciente.Rows.Count > 0)
        {
            nodoSeleccionadoId = Convert.ToInt32(dtNodoReciente.Rows[0]["Id"]);
            Console.WriteLine($"✅ Nodo creado y confirmado con ID: {nodoSeleccionadoId}");

            documento.NodoCategoriaId = nodoSeleccionadoId;
        }
        else
        {
            mensaje = "⚠️ No se encontró el nodo recién creado desde la base de datos.";
            return;
        }

        await CargarNodos2();
        await CargarSubcategorias();

        nivelesDinamicos ??= new List<NodoSeleccion>();
        nivelesDinamicos.Clear();
        nivelesDinamicos.Add(new NodoSeleccion
        {
            NodoSeleccionadoId = nodoSeleccionadoId
        });

        var actual = todosNodos.FirstOrDefault(n => n.Id == nodoSeleccionadoId);
        subCategoriaSeleccionadaId = null;

        while (actual != null)
        {
            var sub = todasSubcategorias.FirstOrDefault(s =>
                s.Nombre.Trim().Equals(actual.Nombre.Trim(), StringComparison.OrdinalIgnoreCase));

            if (sub != null)
            {
                subCategoriaSeleccionadaId = sub.Id;
                FiltrarNodos(sub.Id);
                Console.WriteLine($"✅ SubCategoría encontrada: {sub.Nombre} (ID: {sub.Id})");
                break;
            }

            if (actual.PadreId == 0)
            {
                Console.WriteLine($"🟨 Nodo '{actual.Nombre}' es una categoría raíz. No se buscarán más subcategorías.");
                break;
            }

            actual = todosNodos.FirstOrDefault(n => n.Id == actual.PadreId);
        }

        if (!subCategoriaSeleccionadaId.HasValue)
        {
            var nodoRaiz = todosNodos.FirstOrDefault(n => n.Id == nodoSeleccionadoId);
            if (nodoRaiz != null && nodoRaiz.PadreId == 0 && nodoRaiz.EsCategoria)
            {
                Console.WriteLine($"✅ Nodo raíz '{nodoRaiz.Nombre}' detectado. Se permite continuar sin subcategoría.");
            }
            else
            {
                mensaje = $"⚠️ No se encontró ninguna subcategoría válida en la jerarquía ascendente desde el nodo ID: {nodoSeleccionadoId}";
                return;
            }
        }

        Console.WriteLine($"🧪 Verificación antes de guardar: NodoCategoriaIdFinal={documento.NodoCategoriaId}, SubCategoriaId={subCategoriaSeleccionadaId}");

        await GuardarDocumento();
    }

    private async Task GuardarNodo()
    {
        if (string.IsNullOrWhiteSpace(nuevoNodo.Nombre))
        {
            notificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Error,
            Summary = "Campo requerido",
            Detail = "El nombre del nodo no puede estar vacío.",
            Duration = 4000
        });
            return;
        }

        try
        {
            var tablaNodo = new DataTable("NodoCategoria");
            tablaNodo.Columns.Add("Id", typeof(int));
            tablaNodo.Columns.Add("Nombre", typeof(string));
            tablaNodo.Columns.Add("PadreId", typeof(int));
            tablaNodo.Columns.Add("EsCategoria", typeof(bool));

            var rowNodo = tablaNodo.NewRow();
            rowNodo["Id"] = nuevoNodo.Id;
            rowNodo["Nombre"] = nuevoNodo.Nombre;
            rowNodo["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId : DBNull.Value;
            rowNodo["EsCategoria"] = nuevoNodo.EsCategoria;
            tablaNodo.Rows.Add(rowNodo);

            if (editando)
            {
                await ServicioUsuario.ActualizarFilasAsync(tablaNodo, 18);
                mensaje = "✅ Nodo actualizado correctamente.";

                var nodoAnterior = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.Id);
                if (nodoAnterior != null)
                {

                    if (!nodoAnterior.EsCategoria && nuevoNodo.EsCategoria)
                    {
                        var tablaCat = new DataTable("Categoria");
                        tablaCat.Columns.Add("Id", typeof(int));
                        tablaCat.Columns.Add("Nombre", typeof(string));
                        tablaCat.Columns.Add("PadreId", typeof(int));

                        var rowCat = tablaCat.NewRow();
                        rowCat["Id"] = nuevoNodo.Id;
                        rowCat["Nombre"] = nuevoNodo.Nombre;
                        rowCat["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId.Value : DBNull.Value;
                        tablaCat.Rows.Add(rowCat);

                        await ServicioUsuario.InsertarTablaAsync(tablaCat, "Categoria", 18);

                        var consultaDependencias = $@"SELECT COUNT(*) FROM Documento WHERE PlantillaId = {nuevoNodo.Id}";
                        var resultado = await ServicioUsuario.TraerConsultaAsync(consultaDependencias, 18);
                        int cantidad = Convert.ToInt32(resultado.Rows[0][0]);

                        if (cantidad == 0)
                        {
                            var eliminarSub = new DataTable("SubCategoria");
                            eliminarSub.Columns.Add("Id", typeof(int));
                            var rowDel = eliminarSub.NewRow();
                            rowDel["Id"] = nuevoNodo.Id;
                            eliminarSub.Rows.Add(rowDel);
                            await ServicioUsuario.EliminarFilaAsync(eliminarSub, 18);
                        }
                        else
                        {
                            mensaje += $" ⚠ No se eliminó SubCategoría porque tiene documentos relacionados.";
                        }
                    }

                    // 🔄 Cambio de Categoría → Subcategoría
                    else if (nodoAnterior.EsCategoria && !nuevoNodo.EsCategoria && nuevoNodo.PadreId.HasValue)
                    {
                        var padre = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.PadreId.Value);
                        if (padre != null && padre.EsCategoria)
                        {
                            var nombreEscapadoInterno = padre.Nombre.Replace("'", "''");
                            var consultaSql = $@"SELECT Id FROM Categoria WHERE Nombre = '{nombreEscapadoInterno}'";
                            var dtCategoria = await ServicioUsuario.TraerConsultaAsync(consultaSql, 18);

                            if (dtCategoria.Rows.Count > 0)
                            {
                                int categoriaId = Convert.ToInt32(dtCategoria.Rows[0]["Id"]);

                                var tablaSub = new DataTable("SubCategoria");
                                tablaSub.Columns.Add("Id", typeof(int));
                                tablaSub.Columns.Add("CategoriaId", typeof(int));
                                tablaSub.Columns.Add("Nombre", typeof(string));

                                var rowSub = tablaSub.NewRow();
                                rowSub["Id"] = nuevoNodo.Id;
                                rowSub["CategoriaId"] = categoriaId;
                                rowSub["Nombre"] = nuevoNodo.Nombre;
                                tablaSub.Rows.Add(rowSub);

                                await ServicioUsuario.InsertarTablaAsync(tablaSub, "SubCategoria", 18);
                            }
                        }

                        // 🔐 Validar dependencias antes de eliminar Categoria
                        var consultaDependencias = $@"SELECT COUNT(*) FROM Documento WHERE PlantillaId = {nuevoNodo.Id}";
                        var resultado = await ServicioUsuario.TraerConsultaAsync(consultaDependencias, 18);
                        int cantidad = Convert.ToInt32(resultado.Rows[0][0]);

                        if (cantidad == 0)
                        {
                            var eliminarCat = new DataTable("Categoria");
                            eliminarCat.Columns.Add("Id", typeof(int));
                            var rowCatDel = eliminarCat.NewRow();
                            rowCatDel["Id"] = nuevoNodo.Id;
                            eliminarCat.Rows.Add(rowCatDel);
                            await ServicioUsuario.EliminarFilaAsync(eliminarCat, 18);
                        }
                        else
                        {
                            mensaje += $" ⚠ No se eliminó Categoría porque tiene documentos relacionados.";
                        }
                    }
                }
            }

            else
            {
                await ServicioUsuario.InsertarTablaAsync(tablaNodo, "NodoCategoria", 18);
                mensaje = "✅ Nodo guardado correctamente.";

                var nombreEscapado = nuevoNodo.Nombre.Replace("'", "''");
                var dtNuevoNodo = await ServicioUsuario.TraerConsultaAsync($@"
                SELECT TOP 1 Id FROM NodoCategoria
                WHERE Nombre = '{nombreEscapado}'
                ORDER BY Id DESC", 18);

                if (dtNuevoNodo.Rows.Count > 0)
                {
                    nuevoNodo.Id = Convert.ToInt32(dtNuevoNodo.Rows[0]["Id"]);
                    Console.WriteLine($"✅ Nodo creado con ID: {nuevoNodo.Id}");
                }
                else
                {
                    throw new Exception("No se pudo recuperar el ID del nuevo nodo.");
                }


                if (nuevoNodo.EsCategoria)
                {
                    var tablaCat = new DataTable("Categoria");
                    tablaCat.Columns.Add("Id", typeof(int));
                    tablaCat.Columns.Add("Nombre", typeof(string));
                    tablaCat.Columns.Add("PadreId", typeof(int));

                    var rowCat = tablaCat.NewRow();
                    rowCat["Id"] = nuevoNodo.Id;
                    rowCat["Nombre"] = nuevoNodo.Nombre;
                    rowCat["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId.Value : DBNull.Value;
                    tablaCat.Rows.Add(rowCat);

                    await ServicioUsuario.InsertarTablaAsync(tablaCat, "Categoria", 18);
                    Console.WriteLine($"📁 Categoría '{nuevoNodo.Nombre}' creada.");
                }
                else if (nuevoNodo.PadreId.HasValue)
                {

                    var padre = nodosExistentes.FirstOrDefault(n => n.Id == nuevoNodo.PadreId.Value);
                    if (padre != null && padre.EsCategoria)
                    {
                        var nombreEscapadoPadre = padre.Nombre.Replace("'", "''");
                        var dtCategoria = await ServicioUsuario.TraerConsultaAsync(
                            $@"SELECT Id FROM Categoria WHERE Nombre = '{nombreEscapadoPadre}'", 18);

                        if (dtCategoria.Rows.Count == 0)
                        {
                            throw new Exception($"❌ El nodo padre con ID {padre.Id} no existe en la tabla Categoria.");
                        }

                        int categoriaId = Convert.ToInt32(dtCategoria.Rows[0]["Id"]);

                        var tablaSub = new DataTable("SubCategoria");
                        tablaSub.Columns.Add("Id", typeof(int));
                        tablaSub.Columns.Add("CategoriaId", typeof(int));
                        tablaSub.Columns.Add("Nombre", typeof(string));

                        var rowSub = tablaSub.NewRow();
                        rowSub["Id"] = nuevoNodo.Id; 
                        rowSub["CategoriaId"] = categoriaId;
                        rowSub["Nombre"] = nuevoNodo.Nombre;
                        tablaSub.Rows.Add(rowSub);

                        await ServicioUsuario.InsertarTablaAsync(tablaSub, "SubCategoria", 18);
                        Console.WriteLine($"📂 Subcategoría '{nuevoNodo.Nombre}' creada bajo Categoría ID {categoriaId}");
                    }
                    else
                    {
                        Console.WriteLine("⚠️ El nodo padre no es una categoría válida. No se creó subcategoría.");
                    }
                }
            }

            int? padreIdAnterior = nuevoNodo.PadreId;

            nuevoNodo = new();
            editando = false;

            await CargarNodos(); 
            ExpandirNodoPadre(padreIdAnterior);
            ExpandirRutaHastaNodo(padreIdAnterior);
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al guardar nodo: {ex.Message}";
            Console.WriteLine($"❌ EXCEPCIÓN: {ex}");
        }
    }

