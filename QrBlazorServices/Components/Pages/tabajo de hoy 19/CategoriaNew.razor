    private List<DocumentoExtendido> documentosFiltrados = new();
    private string filtroNombre = "";
    private string _filtroNombre = "";

private string FiltroNombre
{
    get => _filtroNombre;
    set
    {
        if (_filtroNombre != value)
        {
            _filtroNombre = value;
            AplicarFiltroNombre();
        }
    }
}

  private void AplicarFiltroNombre()
{
    if (string.IsNullOrWhiteSpace(_filtroNombre))
        documentosFiltrados = documentos;
    else
        documentosFiltrados = documentos
            .Where(d => d.Nombre?.Contains(_filtroNombre, StringComparison.OrdinalIgnoreCase) == true)
            .ToList();
}
    

