        {
            mensaje = string.Empty;

            // 🔎 Validaciones
            if (string.IsNullOrWhiteSpace(documento.Nombre))
                mensaje += "❌ El nombre del documento es obligatorio.\n";

            if (!string.IsNullOrEmpty(mensaje))
