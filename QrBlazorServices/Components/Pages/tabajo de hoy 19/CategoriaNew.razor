@page "/Documentos"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject AccesoDatos.AccesoDatosSoapClient ServicioSoap
@inject DialogService dialogService
@rendermode InteractiveServer
@using System.Data
@using Radzen
@using Radzen.Blazor
@using QrBlazorServices.Clases

@inject NavigationManager Navigation
@inject NotificationService notificationService


    @page "/rdocumento/{Id:int}"
@inject NavigationManager Navigation


<h3 class="mb-3">Gestión de Arbol Documental</h3>

<RadzenRow>
    <!-- Columna izquierda -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Visualizador De Arbol Documental">

            <RadzenFieldset Text="@tituloSubnodos" RadzenColumn Style="height: 775px; overflow-y: auto;">

             <RadzenTextBox @bind-Value="textoBusqueda" Placeholder="🔍 Buscar categoría..." Style="width: 100%" Change="BuscarNodo" />

            

            <RadzenTree Data="@nodosRaiz"
                        Change="@(args => SeleccionarNodoDesdeArbol(args.Value as NodoCategoria))">
                <RadzenTreeLevel TextProperty="Nombre"
                                 ChildrenProperty="Hijos"
                                 Expanded="@((context) => ((NodoCategoria)context).Expanded)" />
            </RadzenTree>


         </RadzenFieldset>
                @if (!string.IsNullOrEmpty(mensaje2))
                {
                    <div class="alert @(mensaje2.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                        @mensaje2
                    </div>
                }
         </RadzenFieldset>
        
</RadzenColumn>

    <!-- Columna derecha -->
    <RadzenColumn Width="6">

         <!--/////////////////////////////////////////aqui//////////////////////////////////////////////////-->
        <RadzenFieldset>

                    <RadzenFieldset Text="@((editando ? "Editar Rama" : "Nuevo Rama"))">
                
@if (!DocumentoId.HasValue)
{
    <RadzenFormField Text="Nombre de la Rama / Documento" Class="w-100 mb-2">
        <RadzenTextBox @bind-Value="nombreComun" Style="width: 100%" />
    </RadzenFormField>
}


                <RadzenDropDown @bind-Value="documento.PlantillaId"
                                Data="@plantillas"
                                TextProperty="NombreArchivo"
                                ValueProperty="Id"
                                Placeholder="Seleccione plantilla"
                                Class="w-100 mb-2" />

                @if (!DocumentoId.HasValue)
                {
                if (editando == false)
                {
                <RadzenCheckBox @bind-Value="nuevoNodo.EsCategoria" /> <label class="ms-2">¿Es Rama principal?</label>
                }
                }

                <div class="d-flex flex-wrap gap-2 mt-2">

                @if (!DocumentoId.HasValue)
                {

                    <RadzenButton Text="Guardar"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="@GuardarDocumentoYRama"
                                  Icon=""
                                  Style="font-size: 0.85rem; padding: 6px 12px;" />
                }

                                <!--@if (!DocumentoId.HasValue)-->
               <!-- {

                    <RadzenButton Text="Guardar"
                                  ButtonStyle="ButtonStyle.Success"
                                  Click="@GuardarDocumento"
                                  Icon=""
                                  Style="font-size: 0.85rem; padding: 6px 12px;" />
                }-->


                @if (editando)
                {
                    <RadzenButton Text="Cancelar"
                                  ButtonStyle="ButtonStyle.Secondary"
                                  Click="@CancelarEdicion"
                                  Style="font-size: 0.85rem; padding: 6px 12px;" />
                }
                else if (nodoSeleccionado != null)
                {
                    <RadzenButton Text="Editar nodo"
                                  ButtonStyle="ButtonStyle.Warning"
                                  Icon=""
                                  Click="@(() => CargarNodoParaEditar(nodoSeleccionado))"
                                  Style="font-size: 0.85rem; padding: 6px 12px;" />

                    <RadzenButton Text="Eliminar nodo"
                                  ButtonStyle="ButtonStyle.Danger"
                                  Icon=""
                                  Click="@(() => EliminarNodo(nodoSeleccionado))"
                                  Style="font-size: 0.85rem; padding: 6px 12px;" />
                }

                

                @if (DocumentoId.HasValue)
                {
                    <RadzenButton 
                        Text="Actualizar Documento"
                        Icon="refresh"
                        ButtonStyle="ButtonStyle.Warning"
                        Click="@GuardarDocumento"
                        Class="me-2" />
                    }


                    @if (DocumentoId.HasValue)
                    {
                        <RadzenButton Text="Cancelar edición"
                                      Icon="arrow_back"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@(() => Cancelar())"
                                      Style="margin-left: 10px;" />
                    }

                </div>

        </RadzenFieldset>
        
        <!--////////////////////////////////////////aqui///////////////////////////////////////////////////-->
        <!--///////////////////////////////////////////////////////////////////////////////////////////-->

            <RadzenFieldset Text="Documentos Arbol Documental">
            <RadzenDataGrid Data="@documentos" TItem="DocumentoExtendido" AllowPaging="true" PageSize="10"
                            AllowSorting="true"
                            FilterMode="FilterMode.Simple"
                            ShowPagingSummary="true"
                            >
                <Columns>
                        <!--<RadzenDataGridColumn TItem="DocumentoExtendido" Property="Id" Title="ID" />-->
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nombre" Title="Nombre" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Referencia" Title="Referencia" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="NombrePlantilla" Title="Plantilla" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Categoria" Title="Categoría" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="SubCategoria" Title="Subcategoría" />
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nodo" Title="Nodo Final" />
                        <!--<RadzenDataGridColumn TItem="DocumentoExtendido" Property="FechaCreacion" Title="Creación" FormatString="{0:yyyy-MM-dd}" />-->
                    <RadzenDataGridColumn TItem="DocumentoExtendido" Title="Acciones">
                        <Template Context="doc">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" Style="margin-right: 5px;" ButtonStyle="ButtonStyle.Info"
                                          Click="() => EditarDocumento(doc.Id)" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                          Click="() => EliminarDocumento(doc.Id)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
			</RadzenFieldset>

            
            <RadzenFieldset Text="Ramificacion Arbol">
                            @if (jerarquiaSeleccionada != null && jerarquiaSeleccionada.Any())
            {
                <p><strong>📂 Ruta:</strong> @string.Join(" / ", jerarquiaSeleccionada.Select(j => j.Nombre))</p>
            }
            </RadzenFieldset>

            <!--///////////////////////////////////////////////////////////////////////////////////////////-->
            <!--///////////////////////////////////////////////////////////////////////////////////////////-->       
	</RadzenFieldset>
</RadzenColumn>
</RadzenRow>

@if (showModal)
{
    <div style="
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background-color: rgba(0, 0, 0, 0.5);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 9999;">

        <div style="
                    background: white;
                    padding: 20px;
                    border-radius: 10px;
                    width: 90%;
                    max-width: 1000px;
                    max-height: 90vh;
                    overflow-y: auto;
                    box-shadow: 0 0 10px rgba(0,0,0,0.5);">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="m-0">📄 Vista previa del documento</h5>
                <button class="btn btn-sm btn-danger" @onclick="() => showModal = false">X</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(rutaSeleccionada) &&
                    rutaSeleccionada.StartsWith("data:application/pdf", StringComparison.OrdinalIgnoreCase))
            {
                <iframe src="@rutaSeleccionada"
                        width="100%" height="600px"
                        style="border: 1px solid #ccc; border-radius: 8px;" />
            }
            else
            {
                <p class="text-danger">⚠️ El archivo seleccionado no es un PDF válido.</p>
            }
        </div>
    </div>
}


@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <RadzenAlert Severity="AlertSeverity.Info" Style="margin-top: 15px;">@mensaje</RadzenAlert>
}


@if (!string.IsNullOrEmpty(nombreSeleccionado))
{
    <RadzenAlert Style="margin-bottom: 10px;" Severity="Info">
        <b>@tipoSeleccionado</b>: <i>@nombreSeleccionado</i>
    </RadzenAlert>
}


@if (!string.IsNullOrEmpty(mensajes2))
{
    <div class="alert @(mensajes2.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
        @mensajes2
    </div>
}


@code {

    string mensajes;
    string mensajes2;
    bool esNuevo = true;
    int IdAplicacion = 18;
    private string mensaje;
    private string? mensaje2;
    Plantilla plantilla = new();
    Documento documento = new();
    string tipoSeleccionado = "";
    private bool editando = false;
    private bool showModal = false;
    string nombreSeleccionado = "";
    private string? rutaSeleccionada;
    List<Plantilla> plantillas = new();
    List<Categoria> categorias = new();
    private int? plantillaSeleccionadaId;
    [Parameter] public int Id { get; set;}
    List<NodoCategoria> ListaNodos = new(); // debe contener TODA la estructura
    List<NodoCategoria> todosNodos = new();
    private NodoCategoria nuevoNodo = new();
    List<Plantilla> listaPlantillas = new();
    private NodoCategoria? nodoSeleccionado;
    List<NodoCategoria> nodosFiltrados = new();
    List<DocumentoExtendido> documentos = new();
    [Parameter] public int? NodoId { get; set; }
    List<NodoSeleccion> nivelesDinamicos = new();
    List<SubCategoria> todasSubcategorias = new();
    private List<NodoCategoria> nodosRaiz = new();
    [Parameter] public int? DocumentoId { get; set; }
    List<SubCategoria> subcategoriasFiltradas = new();
    List<NodoCategoria> jerarquiaSeleccionada = new();
    private List<NodoCategoria> nodosExistentes = new();

   

    public List<NodoCategoria> Hijos { get; set; } = new();

    List<string> estadosDisponibles = new() { "Activa", "Inactiva", "Obsoleta", "En revisión" };
    private string tituloSubnodos => $"Rama del Arbol Seleccionada: {nodoSeleccionado?.Nombre ?? "..."}";

    int? nodoJerarquicoSeleccionadoId,
    categoriaSeleccionadaId,
    subCategoriaSeleccionadaId,
    nodoSeleccionadoId,
    nodoNivel1Id,
    nodoNivel2Id,
    nodoNivel3Id,
    nodoSeleccionadoFinalId;

    private string nombreComun = string.Empty;




    protected override async Task OnInitializedAsync()
    {
        nuevoNodo = new NodoCategoria(); // <-- esto es clave para que EditForm y validadores no fallen
        await CargarNodos();
        await CargarPlantillas();
        await CargarCategorias();
        await CargarSubcategorias();
        await CargarNodos2();
        await CargarDocumentos();
        await CargarDocumento();

        if (NodoId.HasValue)
        {
            nodoSeleccionadoFinalId = NodoId.Value;
            await CargarJerarquiaDesdeNodo(nodoSeleccionadoFinalId.Value);
        }

        if (DocumentoId.HasValue)
        {
            await CargarDocumentoParaEditar(DocumentoId.Value);
        }
    }

    //////////////////////////////////PROCESOS NODO///////////////////////////////////////////////////
    //////////////////////////////////////////////////////////////////////////////////////////////////
    private async Task CargarNodos()
    {
        nodosExistentes.Clear();
        nodosRaiz.Clear();

        var dt = await ServicioUsuario.TraerConsultaAsync("SELECT Id, Nombre, PadreId, EsCategoria FROM NodoCategoria", 18);

        nodosExistentes = dt.Rows.Cast<DataRow>().Select(row => new NodoCategoria
        {
            Id = Convert.ToInt32(row["Id"]),
            Nombre = row["Nombre"].ToString() ?? "",
            NombreOriginal = row["Nombre"].ToString() ?? "", // 👈 guardar nombre original
            PadreId = row["PadreId"] != DBNull.Value ? Convert.ToInt32(row["PadreId"]) : (int?)null,
            EsCategoria = Convert.ToBoolean(row["EsCategoria"])
        }).ToList();


        var nodosPadres = nodosExistentes.Where(n => n.PadreId == null).ToList();

        foreach (var raiz in nodosPadres)
        {
            nodosRaiz.Add(ConstruirJerarquia(raiz));
        }
    }

    private NodoCategoria ConstruirJerarquia(NodoCategoria nodo)
    {
        nodo.Hijos = nodosExistentes.Where(n => n.PadreId == nodo.Id).Select(ConstruirJerarquia).ToList();
        return nodo;
    }

  
    private async Task<bool> ExisteCategoria(int idCategoria)
    {
        var dt = await ServicioUsuario.TraerConsultaAsync($"SELECT COUNT(*) AS Total FROM Categoria WHERE Id = {idCategoria}", 18);
        return Convert.ToInt32(dt.Rows[0]["Total"]) > 0;
    }

    private async Task EliminarNodo(NodoCategoria nodo)
    {
        try
        {
            if (nodosExistentes.Any(n => n.PadreId == nodo.Id))
            {
                mensaje = "❌ No se puede eliminar un nodo que tiene hijos.";
                return;
            }

            var tabla = new DataTable("NodoCategoria");
            tabla.Columns.Add("Id", typeof(int));
            var row = tabla.NewRow();
            row["Id"] = nodo.Id;
            tabla.Rows.Add(row);

            await ServicioUsuario.EliminarFilaAsync(tabla, 18);
            mensaje = "✅ Nodo eliminado correctamente.";
            await CargarNodos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al eliminar nodo: {ex.Message}";
        }
    }

    private void CargarNodoParaEditar(NodoCategoria nodo)
    {
        nuevoNodo = new NodoCategoria
        {
            Id = nodo.Id,
            Nombre = nodo.Nombre,
            PadreId = nodo.PadreId,
            EsCategoria = nodo.EsCategoria
        };
        editando = true;
    }

    private void CancelarEdicion()
    {
        nuevoNodo = new();
        editando = false;
    }

    private async Task SeleccionarNodo(NodoCategoria nodo)
    {
        nodoSeleccionado = nodo;
    }

    private void PrepararNuevaCategoria()
    {
        nuevoNodo = new NodoCategoria
        {
            Id = 0,
            Nombre = "",
            PadreId = null,
            EsCategoria = true
        };

        editando = false;
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////
    ////////////////////////////////////////////////////////////////////////////////////////////////

    async Task CargarPlantillas()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);
        plantillas = ds.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString()
        }).ToList();
    }

    async Task CargarCategorias()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("Categoria", IdAplicacion);
        categorias = ds.AsEnumerable().Select(r => new Categoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();
    }

    async Task CargarSubcategorias()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("SubCategoria", IdAplicacion);



        todasSubcategorias = ds.AsEnumerable().Select(r => new SubCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            CategoriaId = Convert.ToInt32(r["CategoriaId"])
        }).ToList();
    }

    async Task CargarNodos2()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("NodoCategoria", IdAplicacion);
        todosNodos = ds.AsEnumerable().Select(r => new NodoCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            PadreId = r["PadreId"] == DBNull.Value ? 0 : Convert.ToInt32(r["PadreId"]) // Manejo seguro de NULL
        }).ToList();
    }

    void FiltrarSubcategorias(int categoriaId)
    {
        subcategoriasFiltradas = todasSubcategorias.Where(x => x.CategoriaId == categoriaId).ToList();
        subCategoriaSeleccionadaId = null;
        nodoSeleccionadoId = null;
        nodosFiltrados.Clear();
    }

    void FiltrarNodos(int subcategoriaId)
    {
        // Buscar el nodo padre relacionado al nombre de la subcategoría
        var subcategoria = todasSubcategorias.FirstOrDefault(x => x.Id == subcategoriaId);
        if (subcategoria == null)
        {
            nodosFiltrados.Clear();
            return;
        }

        // Buscar nodo cuyo nombre coincida con el de la subcategoría
        var nodoPadre = todosNodos.FirstOrDefault(n =>
            n.Nombre != null &&
            subcategoria.Nombre != null &&
            n.Nombre.Trim().Equals(subcategoria.Nombre.Trim(), StringComparison.OrdinalIgnoreCase));

        if (nodoPadre != null)
        {
            nodosFiltrados = todosNodos.Where(n => n.PadreId == nodoPadre.Id).ToList();
        }
        else
        {
            nodosFiltrados.Clear();
        }

        nodoSeleccionadoId = null;
    }

    void InicializarJerarquiaDesdeNodo(int? nodoRaizId)
    {
        nivelesDinamicos.Clear();

        if (!nodoRaizId.HasValue)
            return;

        var hijos = todosNodos.Where(n => n.PadreId == nodoRaizId).ToList();

        if (hijos.Any())
        {
            nivelesDinamicos.Add(new NodoSeleccion
            {
                NodoSeleccionadoId = null,
                Hijos = hijos
            });
        }
    }

    void ManejarCambioNodo(int nivel, int? nodoId)
    {
        if (nivel >= nivelesDinamicos.Count)
            return; // Evita index out of range

        // ✅ Actualiza el valor seleccionado del nivel actual
        nivelesDinamicos[nivel].NodoSeleccionadoId = nodoId;

        // ✅ Elimina niveles posteriores
        if (nivelesDinamicos.Count > nivel + 1)
            nivelesDinamicos.RemoveRange(nivel + 1, nivelesDinamicos.Count - (nivel + 1));

        if (nodoId == null)
            return;

        // ✅ Busca hijos del nodo seleccionado
        var hijos = todosNodos.Where(n => n.PadreId == nodoId).ToList();

        if (hijos.Any())
        {
            nivelesDinamicos.Add(new NodoSeleccion
            {
                NodoSeleccionadoId = null,
                Hijos = hijos
            });
        }

        StateHasChanged(); // 🔄 fuerza actualización segura
    }

    async Task CargarDocumentoParaEditar(int id)
    {
        var consulta = await ServicioUsuario.TraerConsultaAsync(
            $"SELECT d.Id, d.Nombre, d.PlantillaId, dc.SubCategoriaId, dc.NodoCategoriaId " +
            $"FROM Documento d LEFT JOIN DocumentoCategoria dc ON d.Id = dc.DocumentoId WHERE d.Id = {id}", IdAplicacion);

        if (consulta.Rows.Count > 0)
        {
            var row = consulta.Rows[0];

            documento = new Documento
            {
                Nombre = row["Nombre"].ToString(),

                PlantillaId = row["PlantillaId"] == DBNull.Value ? null : Convert.ToInt32(row["PlantillaId"])
            };

            subCategoriaSeleccionadaId = row["SubCategoriaId"] == DBNull.Value ? null : Convert.ToInt32(row["SubCategoriaId"]);
            nodoSeleccionadoId = row["NodoCategoriaId"] == DBNull.Value ? null : Convert.ToInt32(row["NodoCategoriaId"]);

            // Filtrar subcategorías y nodos de forma segura
            if (subCategoriaSeleccionadaId is int subCatId)
            {
                var sub = todasSubcategorias.FirstOrDefault(x => x.Id == subCatId);
                if (sub != null)
                {
                    categoriaSeleccionadaId = sub.CategoriaId;
                    FiltrarSubcategorias(sub.CategoriaId);
                    FiltrarNodos(subCatId);
                }
            }

            // Cargar jerarquía dinámica
            if (nodoSeleccionadoId is int nodoId)
            {
                InicializarJerarquiaDesdeNodo(nodoId);
            }
        }
    }

    private void IrAInicio() => Navigation.NavigateTo("/ver");

    private async Task CargarJerarquiaDesdeNodo(int nodoId)
    {
        var nodo = todosNodos.FirstOrDefault(n => n.Id == nodoId);
        if (nodo == null) return;

        // Buscar recursivamente hasta llegar a un nodo cuyo nombre esté en SubCategoria
        var subCategoria = todasSubcategorias.FirstOrDefault(s => s.Nombre.Trim() == nodo.Nombre.Trim());
        if (subCategoria != null)
        {
            subCategoriaSeleccionadaId = subCategoria.Id;
            categoriaSeleccionadaId = subCategoria.CategoriaId;
        }
        else
        {
            // Nodo puede ser subnodo, buscamos hacia arriba
            var padre = todosNodos.FirstOrDefault(p => p.Id == nodo.PadreId);
            if (padre != null)
            {
                await CargarJerarquiaDesdeNodo(padre.Id);
            }
        }
    }

    ////////////////////////////////////////////////////////////////////////////////////////////////

    private List<NodoCategoria> ObtenerRutaJerarquica(NodoCategoria nodoFinal)
    {
        var ruta = new List<NodoCategoria>();

        var actual = nodoFinal;
        while (actual != null)
        {
            ruta.Insert(0, actual); // Insertar al inicio para que quede ordenado desde raíz hasta el nodo final
            actual = nodosExistentes.FirstOrDefault(n => n.Id == actual.PadreId);
        }

        return ruta;
    }

    private string ObtenerRutaJerarquica()
    {
        if (jerarquiaSeleccionada == null || !jerarquiaSeleccionada.Any())
            return string.Empty;

        var partes = new List<string>();

        for (int i = 0; i < jerarquiaSeleccionada.Count; i++)
        {
            var nodo = jerarquiaSeleccionada[i];
            string etiqueta = i switch
            {
                0 => "Categoría",
                1 => "Subcategoría",
                _ => $"Nodo {i - 1}"
            };

            partes.Add($"{etiqueta}: {nodo.Nombre}");
        }

        return string.Join(" ➝ ", partes);
    }

    void MostrarVisor(Plantilla data)
    {
        rutaSeleccionada = data?.RutaBase64 ?? "";
        showModal = !string.IsNullOrWhiteSpace(rutaSeleccionada);
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    async Task CargarDocumentos()
    {
        documentos.Clear();

        var dtDocumentos = await ServicioUsuario.TraerTablaAsync("Documento", IdAplicacion);
        var dtRelacion = await ServicioUsuario.TraerTablaAsync("DocumentoCategoria", IdAplicacion);
        var dtSubcategorias = await ServicioUsuario.TraerTablaAsync("SubCategoria", IdAplicacion);
        var dtCategorias = await ServicioUsuario.TraerTablaAsync("Categoria", IdAplicacion);
        var dtNodos = await ServicioUsuario.TraerTablaAsync("NodoCategoria", IdAplicacion);
        var dtPlantillas = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);

        var subcategorias = dtSubcategorias.AsEnumerable().Select(r => new SubCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            CategoriaId = Convert.ToInt32(r["CategoriaId"])
        }).ToList();

        var categorias = dtCategorias.AsEnumerable().Select(r => new Categoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var nodos = dtNodos.AsEnumerable().Select(r => new NodoCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var plantillas = dtPlantillas.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString(),
            Referencia = r.Table.Columns.Contains("Referencia") ? r["Referencia"]?.ToString() : null
        }).ToList();

        var relaciones = dtRelacion.AsEnumerable().ToList();

        documentos = dtDocumentos.AsEnumerable().Select(doc =>
        {
            int id = Convert.ToInt32(doc["Id"]);

            var relacion = relaciones.FirstOrDefault(r => Convert.ToInt32(r["DocumentoId"]) == id);
            
            var subCatId = (relacion != null && relacion["SubCategoriaId"] != DBNull.Value)
               ? Convert.ToInt32(relacion["SubCategoriaId"])
               : 0;


            var nodoId = relacion != null && relacion["NodoCategoriaId"] != DBNull.Value
                            ? Convert.ToInt32(relacion["NodoCategoriaId"]) : 0;

            var subcategoria = subcategorias.FirstOrDefault(s => s.Id == subCatId);
            var categoria = categorias.FirstOrDefault(c => c.Id == subcategoria?.CategoriaId);
            var nodo = nodos.FirstOrDefault(n => n.Id == nodoId);

            Plantilla plantilla = null;
            if (doc.Table.Columns.Contains("PlantillaId") && doc["PlantillaId"] != DBNull.Value)
            {
                int idPlantilla = Convert.ToInt32(doc["PlantillaId"]);
                plantilla = plantillas.FirstOrDefault(p => p.Id == idPlantilla);
            }

            return new DocumentoExtendido
            {
                Id = id,
                Nombre = doc["Nombre"].ToString(),
                Referencia = plantilla?.Referencia ?? "",
                NombrePlantilla = plantilla?.NombreArchivo ?? "",
                FechaCreacion = doc["FechaCreacion"] == DBNull.Value ? DateTime.MinValue : Convert.ToDateTime(doc["FechaCreacion"]),
                Categoria = categoria?.Nombre ?? "",
                SubCategoria = subcategoria?.Nombre ?? "",
                Nodo = nodo?.Nombre ?? ""
            };
        }).ToList();
    }

