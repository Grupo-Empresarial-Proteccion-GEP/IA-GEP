    private void SeleccionarNodoDesdeArbol(NodoCategoria nodo)
    {
        if (nodo == null)
            return;

        nodoSeleccionado = nodo;
        jerarquiaSeleccionada = ObtenerRutaJerarquica(nodo);

        var categoria = jerarquiaSeleccionada.FirstOrDefault(j => j.EsCategoria);
        var subcategoria = jerarquiaSeleccionada.Skip(1).FirstOrDefault(j => !j.EsCategoria);

        if (categoria != null)
        {
            categoriaSeleccionadaId = categoria.Id;
            FiltrarSubcategorias(categoria.Id);
        }

        if (subcategoria != null)
        {
            var sub = todasSubcategorias.FirstOrDefault(s => s.Nombre.Trim() == subcategoria.Nombre.Trim());
            if (sub != null)
            {
                subCategoriaSeleccionadaId = sub.Id;
                FiltrarNodos(sub.Id);
            }
        }

        var nodoFinal = jerarquiaSeleccionada.LastOrDefault();
        if (nodoFinal != null)
        {
            nodoSeleccionadoId = nodoFinal.Id;
            InicializarJerarquiaDesdeNodo(nodoFinal.Id);

            if (editando)
            {

                nuevoNodo = new NodoCategoria
            {
                Id = nodoFinal.Id,
                Nombre = nodoFinal.Nombre,
                PadreId = nodoFinal.PadreId,
                EsCategoria = nodoFinal.EsCategoria
            };
            }
            else
            {

                nuevoNodo = new NodoCategoria
            {
                PadreId = nodoFinal.Id,
                EsCategoria = false, 
                Nombre = ""
            };
            }

            Console.WriteLine($"🔍 Nodo seleccionado final: {nodoFinal.Nombre} (ID: {nodoFinal.Id})");
        }
        else
        {
            Console.WriteLine("⚠️ No se pudo determinar el nodo final desde la jerarquía.");
        }

        StateHasChanged();
    }

    async Task GuardarDocumento()
    {
        try
        {
            mensaje = string.Empty;

            if (string.IsNullOrWhiteSpace(documento.Nombre))
                mensaje += "❌ El nombre del documento es obligatorio.\n";

            if (!documento.PlantillaId.HasValue || documento.PlantillaId.Value == 0)
                mensaje += "❌ Debes seleccionar una plantilla para el documento.\n";

            if (!string.IsNullOrEmpty(mensaje))
                return;

            var nodoCategoriaIdFinal = ObtenerNodoCategoriaIdFinal();

            if (nodoCategoriaIdFinal.HasValue)
            {
                Console.WriteLine($"✅ NodoCategoriaId a guardar: {nodoCategoriaIdFinal.Value}");
            }
            else
            {
                Console.WriteLine("⚠️ No se encontró NodoCategoriaId válido en nivelesDinamicos ni en nodoSeleccionadoId.");
            }


            if (DocumentoId.HasValue)
            {
                var dtDocumento = await ServicioUsuario.TraerEsquemaTablaAsync("Documento", IdAplicacion);
                var fila = dtDocumento.NewRow();

                fila["Id"] = DocumentoId.Value;
                fila["Nombre"] = documento.Nombre.Trim();
                fila["PlantillaId"] = documento.PlantillaId ?? 0;

                dtDocumento.Rows.Add(fila);
