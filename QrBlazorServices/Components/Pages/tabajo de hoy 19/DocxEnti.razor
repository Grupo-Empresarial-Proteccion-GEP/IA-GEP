    private async void SeleccionarNodoDesdeArbol(NodoCategoria nodo)
    {
        if (nodo == null)
            return;

        nombreComun = nodo.Nombre;
        nodoSeleccionado = nodo;
        jerarquiaSeleccionada = ObtenerRutaJerarquica(nodo);

        var categoria = jerarquiaSeleccionada.FirstOrDefault(j => j.EsCategoria);
        var subcategoria = jerarquiaSeleccionada.Skip(1).FirstOrDefault(j => !j.EsCategoria);

        if (categoria != null)
        {
            categoriaSeleccionadaId = categoria.Id;
            FiltrarSubcategorias(categoria.Id);
        }

        if (subcategoria != null)
        {
            var sub = todasSubcategorias.FirstOrDefault(s => s.Nombre.Trim() == subcategoria.Nombre.Trim());
            if (sub != null)
            {
                subCategoriaSeleccionadaId = sub.Id;
                FiltrarNodos(sub.Id);
            }
        }

        var nodoFinal = jerarquiaSeleccionada.LastOrDefault();
        if (nodoFinal != null)
        {
            nodoSeleccionadoId = nodoFinal.Id;
            InicializarJerarquiaDesdeNodo(nodoFinal.Id);

            if (editando)
            {
                nuevoNodo = new NodoCategoria
                {
                    Id = nodoFinal.Id,
                    Nombre = nodoFinal.Nombre,
                    PadreId = nodoFinal.PadreId,
                    EsCategoria = nodoFinal.EsCategoria
                };
            }
            else
            {
                nuevoNodo = new NodoCategoria
                {
                    PadreId = nodoFinal.Id,
                    EsCategoria = false,
                    Nombre = ""
                };
            }

            // 🔍 Cargar documento asociado al nodo
            var sql = $@"
            SELECT TOP 1
                d.Id AS DocumentoId,
                d.Nombre,
                d.PlantillaId,
                p.RutaArchivo,
                p.Referencia,
                p.Version,
                p.Estado
            FROM Documento d
            JOIN DocumentoCategoria dc ON dc.DocumentoId = d.Id
            JOIN Plantilla p ON p.Id = d.PlantillaId
            WHERE dc.NodoCategoriaId = {nodoFinal.Id}
            ";


            var dt = await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);

            if (dt.Rows.Count > 0)
            {
                DocumentoId = Convert.ToInt32(dt.Rows[0]["DocumentoId"]);
                documento = new Documento
                {
                    Nombre = dt.Rows[0]["Nombre"]?.ToString(),
                    PlantillaId = dt.Rows[0]["PlantillaId"] != DBNull.Value
                     ? Convert.ToInt32(dt.Rows[0]["PlantillaId"])
                     : (int?)null,
                    NodoCategoriaId = nodoFinal.Id,
                    Referencia = dt.Rows[0]["Referencia"]?.ToString(),
                    Version = dt.Rows[0]["Version"]?.ToString(),
                    Estado = dt.Rows[0]["Estado"]?.ToString()
                };

                var rutaArchivo = dt.Rows[0]["RutaArchivo"]?.ToString();
                if (!string.IsNullOrWhiteSpace(rutaArchivo))
                {
                    rutaSeleccionada = rutaArchivo; // esto lo renderiza el visor PDF
                }
                else
                {
                    rutaSeleccionada = null;
                }
            }
            else
            {
                DocumentoId = null;
                documento = new Documento();
                rutaSeleccionada = null;
            }




            // Esto alimentará el DropDown si está bindeado con documento.PlantillaId
            Console.WriteLine($"Nodo seleccionado final: {nodoFinal.Nombre} (ID: {nodoFinal.Id})");
        }
        else
        {
            Console.WriteLine("No se pudo determinar el nodo final desde la jerarquía.");
        }

        StateHasChanged();
    }


