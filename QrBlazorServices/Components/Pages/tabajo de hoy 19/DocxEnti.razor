    private void ExpandirNodoPadre(int? padreId)
    {
        if (!padreId.HasValue)
            return;

        void Expandir(NodoCategoria nodo)
        {
            if (nodo.Id == padreId)
            {
                nodo.Expanded = true;
                return;
            }

            foreach (var hijo in nodo.Hijos)
            {
                Expandir(hijo);
            }
        }

        foreach (var raiz in nodosRaiz)
        {
            Expandir(raiz);
        }
    }

    private void ExpandirRutaHastaNodo(int? nodoIdFinal)
    {
        if (!nodoIdFinal.HasValue)
            return;

        void Expandir(NodoCategoria nodo, List<int> ruta)
        {
            if (ruta.Contains(nodo.Id))
                nodo.Expanded = true;

            foreach (var hijo in nodo.Hijos)
            {
                Expandir(hijo, ruta);
            }
        }

        // 🧠 Obtener la ruta desde raíz hasta el nodo con ese ID
        List<int> rutaIds = ObtenerRutaIds(nodoIdFinal.Value);
        foreach (var raiz in nodosRaiz)
        {
            Expandir(raiz, rutaIds);
        }
    }

    private List<int> ObtenerRutaIds(int nodoIdDestino)
    {
        List<int> ruta = new();

        bool BuscarRuta(NodoCategoria nodo)
        {
            if (nodo.Id == nodoIdDestino)
            {
                ruta.Add(nodo.Id);
                return true;
            }

            foreach (var hijo in nodo.Hijos)
            {
                if (BuscarRuta(hijo))
                {
                    ruta.Add(nodo.Id); // Agrega al subir
                    return true;
                }
            }

            return false;
        }

        foreach (var raiz in nodosRaiz)
        {
            if (BuscarRuta(raiz))
                break;
        }

        ruta.Reverse(); // De raíz a destino
        return ruta;
    }

