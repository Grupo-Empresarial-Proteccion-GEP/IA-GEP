    private async Task CargarDocumentosParaSeleccion()
    {
        var sql = @"
        SELECT
            d.Id AS DocumentoId,
            d.Nombre AS NombreDocumento,
            c.Nombre AS Categoria,
            sc.Nombre AS SubCategoria,
            nc.Nombre AS Nodo
        FROM Documento d
        LEFT JOIN DocumentoCategoria dc ON d.Id = dc.DocumentoId
        LEFT JOIN SubCategoria sc ON dc.SubCategoriaId = sc.Id
        LEFT JOIN Categoria c ON sc.CategoriaId = c.Id
        LEFT JOIN NodoCategoria nc ON dc.NodoCategoriaId = nc.Id";

        var dt = await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);

        documentosDisponibles = dt.AsEnumerable().Select(r => new DocumentoSeleccion
        {
            DocumentoId = Convert.ToInt32(r["DocumentoId"]),
            Nombre = r["NombreDocumento"]?.ToString() ?? "",
            Categoria = r["Categoria"]?.ToString() ?? "-",
            SubCategoria = r["SubCategoria"]?.ToString() ?? "-",
            Nodo = r["Nodo"]?.ToString() ?? "-"
        }).ToList();

        Console.WriteLine($"📄 Total documentos disponibles cargados: {documentosDisponibles.Count}");
    }

    private async Task GuardarRelacion(int documentoId, int entidadId, int? servicioId, int? subdivisionId)
    {
        try
        {
            // Verificar si ya existe la asignación en DocumentoAsignacion
            var verificarSql = $@"
            SELECT COUNT(*) FROM DocumentoAsignacion
            WHERE DocumentoId = {documentoId}
            AND EntidadId = {entidadId}
            AND ISNULL(ServicioId, 0) = {servicioId ?? 0}
            AND ISNULL(SubdivisionId, 0) = {subdivisionId ?? 0}";

            var existeDt = await ServicioUsuario.TraerConsultaAsync(verificarSql, IdAplicacion);
            int existe = Convert.ToInt32(existeDt.Rows[0][0]);

            if (existe > 0)
            {
                Console.WriteLine($"⚠️ Ya existe la relación DocumentoId={documentoId}, EntidadId={entidadId}... No se insertará.");
                return;
            }

            // Verificar si ya existe en DocumentoEntidad (relación simple entre documento y entidad)
            var existeEntidadSql = $@"
            SELECT COUNT(*) FROM DocumentoEntidad
            WHERE DocumentoId = {documentoId} AND EntidadId = {entidadId}";

            var existeEntidadDt = await ServicioUsuario.TraerConsultaAsync(existeEntidadSql, IdAplicacion);
            int existeEntidad = Convert.ToInt32(existeEntidadDt.Rows[0][0]);

            if (existeEntidad == 0)
            {
                var dtEntidad = await ServicioUsuario.TraerEsquemaTablaAsync("DocumentoEntidad", IdAplicacion);
                var fila1 = dtEntidad.NewRow();
                fila1["DocumentoId"] = documentoId;
                fila1["EntidadId"] = entidadId;
                fila1["FechaAsociacion"] = DateTime.Now;
                dtEntidad.Rows.Add(fila1);
                await ServicioUsuario.InsertarTablaAsync(dtEntidad, "DocumentoEntidad", IdAplicacion);
            }

            // Insertar nueva relación en DocumentoAsignacion
            var dtAsig = await ServicioUsuario.TraerEsquemaTablaAsync("DocumentoAsignacion", IdAplicacion);
            var fila2 = dtAsig.NewRow();
            fila2["DocumentoId"] = documentoId;
            fila2["EntidadId"] = entidadId;
            fila2["ServicioId"] = servicioId ?? (object)DBNull.Value;
            fila2["SubdivisionId"] = subdivisionId ?? (object)DBNull.Value;
            fila2["FechaAsignacion"] = DateTime.Now;
            // fila2["UsuarioAsignacion"] = usuarioActual; // Puedes incluir esto si lo tienes
            dtAsig.Rows.Add(fila2);
            await ServicioUsuario.InsertarTablaAsync(dtAsig, "DocumentoAsignacion", IdAplicacion);

            Console.WriteLine($"✅ Documento {documentoId} asociado correctamente.");
            mensaje = $"✅ Documento {documentoId} asociado correctamente.";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al asociar el documento {documentoId}: {ex.Message}");
            mensaje = $"❌ Error al asociar el documento {documentoId}: {ex.Message}";
        }
    }

    private async Task GuardarAsignaciones()
    {
        if (!entidadSeleccionadaId.HasValue)
        {
            notificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Entidad requerida",
                Detail = "Debes seleccionar una entidad.",
                Duration = 4000
            });
            return;
        }

        var asignadosBD = await ObtenerDocumentosAsignadosDesdeBD(entidadSeleccionadaId.Value, servicioSeleccionadoId, subdivisionSeleccionadaId);
        var seleccionadosActuales = documentosSeleccionados.ToHashSet();

        Console.WriteLine($"🧾 Asignados en BD: {string.Join(", ", asignadosBD)}");
        Console.WriteLine($"📌 Seleccionados ahora: {string.Join(", ", seleccionadosActuales)}");

        var aEliminar = asignadosBD.Except(seleccionadosActuales).ToList();
        var aInsertar = seleccionadosActuales.Except(asignadosBD).ToList();

        Console.WriteLine($"❌ A eliminar: {string.Join(", ", aEliminar)}");
        Console.WriteLine($"➕ A insertar: {string.Join(", ", aInsertar)}");

        if (aEliminar.Any())
            await EliminarDocumentos(entidadSeleccionadaId.Value, servicioSeleccionadoId, subdivisionSeleccionadaId, aEliminar);
            await EliminarDocumentoEntidad(entidadSeleccionadaId.Value, aEliminar);

        foreach (var documentoId in aInsertar)
            await GuardarRelacion(documentoId, entidadSeleccionadaId.Value, servicioSeleccionadoId, subdivisionSeleccionadaId);

        notificationService.Notify(new NotificationMessage
        {
            Severity = NotificationSeverity.Success,
            Summary = "Actualización exitosa",
            Detail = "Las asignaciones de documentos se han sincronizado correctamente.",
            Duration = 4000
        });
    }

    private async Task CargarDocumentosAsignados()
    {
        if (entidadSeleccionadaId is null)
        {
            documentosSeleccionados = new List<int>();
            Console.WriteLine("⚠️ No hay entidad seleccionada.");
            return;
        }

        string where = $"WHERE EntidadId = {entidadSeleccionadaId}";

        if (servicioSeleccionadoId != null)
            where += $" AND ServicioId = {servicioSeleccionadoId}";

        if (subdivisionSeleccionadaId != null)
            where += $" AND SubdivisionId = {subdivisionSeleccionadaId}";

        string sql = $@"
        SELECT DISTINCT DocumentoId
        FROM DocumentoAsignacion
        {where}
    ";

        var dt = await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);

        documentosSeleccionados = dt.AsEnumerable()
            .Select(r => Convert.ToInt32(r["DocumentoId"]))
            .ToList();

        // 🔍 Depuración
        Console.WriteLine($"🧪 Total documentos seleccionados desde BD: {documentosSeleccionados.Count}");
        foreach (var docId in documentosSeleccionados)
        {
            Console.WriteLine($"✔ Documento asignado: {docId}");
        }

        // Comprobamos si alguno de los IDs asignados no existe en documentosDisponibles
        var idsDisponibles = documentosDisponibles.Select(d => d.DocumentoId).ToHashSet();
        var noEncontrados = documentosSeleccionados.Where(id => !idsDisponibles.Contains(id)).ToList();

        if (noEncontrados.Any())
        {
            Console.WriteLine("❌ Documentos seleccionados que no están en la lista de disponibles:");
            foreach (var id in noEncontrados)
            {
                Console.WriteLine($" - DocumentoId: {id}");
            }
        }
    }

    private async Task ActualizarDocumentosParaAsignacion()
    {
        await CargarDocumentosParaSeleccion();
        await CargarDocumentosAsignados();
    }

    private async Task<HashSet<int>> ObtenerDocumentosAsignadosDesdeBD(int entidadId, int? servicioId, int? subdivisionId)
    {
        string where = $"WHERE EntidadId = {entidadId}";
        if (servicioId != null) where += $" AND ServicioId = {servicioId}";
        if (subdivisionId != null) where += $" AND SubdivisionId = {subdivisionId}";

        string sql = $@"SELECT DocumentoId FROM DocumentoAsignacion {where}";

        var dt = await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);

        return dt.AsEnumerable()
            .Select(r => Convert.ToInt32(r["DocumentoId"]))
            .ToHashSet();
    }

    private async Task EliminarDocumentos(int entidadId, int? servicioId, int? subdivisionId, List<int> documentosAEliminar)
    {
        if (!documentosAEliminar.Any()) return;

        foreach (var documentoId in documentosAEliminar)
        {
            var condiciones = new List<string>
        {
            $"EntidadId = {entidadId}",
            $"DocumentoId = {documentoId}",
            $"ISNULL(ServicioId, 0) = {servicioId ?? 0}",
            $"ISNULL(SubdivisionId, 0) = {subdivisionId ?? 0}"
        };

            var where = string.Join(" AND ", condiciones);
            var sql = $"DELETE FROM DocumentoAsignacion WHERE {where}";

            Console.WriteLine($"🗑 Ejecutando: {sql}");
            await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion); // <-- Usa tu método para ejecutar SQL sin retorno
        }
    }

    private async Task EliminarDocumentoEntidad(int entidadId, List<int> documentosAEliminar)
    {
        if (!documentosAEliminar.Any()) return;

        foreach (var documentoId in documentosAEliminar)
        {
            string sql = $@"
            DELETE FROM DocumentoEntidad
            WHERE DocumentoId = {documentoId}
            AND EntidadId = {entidadId}";

            Console.WriteLine($"🗑 Eliminando DocumentoEntidad -> DocumentoId: {documentoId}, EntidadId: {entidadId}");
            await ServicioUsuario.TraerConsultaAsync(sql, IdAplicacion);
        }
    }


