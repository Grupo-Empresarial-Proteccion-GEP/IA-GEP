@page "/plantilla"
@inject AccesoDatos.AccesoDatosSoapClient ServicioSoap
@inject DialogService dialogService
@inject NavigationManager Navigation
@rendermode InteractiveServer

@using QrBlazorServices.Clases
@using Radzen
@using System.Data
@using System.IO
@using Microsoft.AspNetCore.Components.Forms

<h3 class="mb-4">Gestión de Plantillas</h3>

<RadzenRow>
    <!-- Columna izquierda: Formulario -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Cargar / Editar Plantilla" Style="max-width: 100%;">
            <RadzenTextBox @bind-Value="plantilla.NombreArchivo"
                           Placeholder="Nombre de la plantilla"
                           Class="w-100 mb-3" />

            <RadzenTextBox @bind-Value="plantilla.Version"
                           Placeholder="Versión"
                           Class="w-100 mb-3" />

            <RadzenDropDown @bind-Value="plantilla.Estado"
                            Data="@estadosDisponibles"
                            Placeholder="Seleccione el estado"
                            AllowCustom="true"
                            Class="w-100 mb-3" />

            <InputFile OnChange="OnFileUpload"
                       accept=".docx,.pdf,.txt"
                       class="form-control mb-3" />

            <RadzenDropDown Data="@listaPlantillas"
                            TextProperty="NombreArchivo"
                            ValueProperty="Id"
                            @bind-Value="plantillaSeleccionadaId"
                            Change="OnSeleccionPlantilla"
                            Placeholder="Seleccione una plantilla"
                            Style="width: 100%; margin-bottom: 10px;" />


            <div class="mb-3">
                <RadzenButton Text="Registrar Nueva"
                              Icon="save"
                              ButtonStyle="ButtonStyle.Success"
                              Click="AgregarPlantilla"
                              Class="me-2" />

                <RadzenButton Text="Actualizar"
                              Icon="edit"
                              ButtonStyle="ButtonStyle.Warning"
                              Click="ActualizarPlantilla"
                              Disabled="@string.IsNullOrWhiteSpace(rutaSeleccionada)"
                              Class="me-2" />

                <RadzenButton Text="Eliminar"
                              Icon="delete"
                              ButtonStyle="ButtonStyle.Danger"
                              Click="EliminarPlantilla"
                              Disabled="@string.IsNullOrWhiteSpace(rutaSeleccionada)" />
            </div>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="alert @(mensaje.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                    @mensaje
                </div>
            }
        </RadzenFieldset>
    </RadzenColumn>

    <!-- Columna derecha: Visor -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Vista previa del documento" Style="max-width: 100%;">
            @if (!string.IsNullOrWhiteSpace(rutaSeleccionada))
            {
                <div class="d-flex justify-content-center">
                    @if (rutaSeleccionada.StartsWith("data:application/pdf", StringComparison.OrdinalIgnoreCase))
                    {
                        <iframe src="@rutaSeleccionada" width="90%" height="500px" style="border: 1px solid #ccc; border-radius: 8px;" />
                    }
                    else
                    {
                        <p>⚠️ Solo se pueden visualizar documentos PDF. El archivo actual no es válido.</p>
                    }

                </div>
            }
        </RadzenFieldset>

    </RadzenColumn>
</RadzenRow>

@code {
    private int? plantillaSeleccionadaId;

    Plantilla plantilla = new();
    List<Plantilla> listaPlantillas = new();
    List<string> estadosDisponibles = new() { "Activa", "Inactiva", "Obsoleta", "En revisión" };
    private string? mensaje;
    private string? rutaSeleccionada;

private async Task OnFileUpload(InputFileChangeEventArgs e)
{
    try
    {
        var file = e.File;

        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 20_000_000); // hasta 20MB
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();

            var mime = file.ContentType; // Ej: application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document
            var base64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:{mime};base64,{base64}";

            plantilla.NombreArchivo = file.Name;
            plantilla.RutaArchivo = dataUrl;

            mensaje = $"✅ Archivo '{file.Name}' cargado correctamente.";
        }
    }
    catch (Exception ex)
    {
        mensaje = $"❌ Error al leer archivo: {ex.Message}";
    }
}


    private async Task AgregarPlantilla()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(plantilla.NombreArchivo) || string.IsNullOrWhiteSpace(plantilla.RutaArchivo))
            {
                await dialogService.Alert("⚠️ Debes seleccionar un archivo válido.");
                return;
            }

            var dt = await ServicioSoap.TraerEsquemaTablaAsync("Plantilla", 18);
            var row = dt.NewRow();
            row["NombreArchivo"] = plantilla.NombreArchivo;
            row["RutaArchivo"] = plantilla.RutaArchivo;
            row["Version"] = plantilla.Version ?? (object)DBNull.Value;
            row["Estado"] = plantilla.Estado ?? (object)DBNull.Value;
            dt.Rows.Add(row);

            await ServicioSoap.InsertarTablaAsync(dt, "Plantilla", 18);

            mensaje = "✅ Plantilla registrada exitosamente.";
            plantilla = new();
            await CargarPlantillas();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al registrar plantilla: {ex.Message}";
        }
    }

    private async Task CargarPlantillas()
    {
        try
        {
            var dt = await ServicioSoap.TraerConsultaAsync("SELECT Id, NombreArchivo, RutaArchivo, Version, Estado FROM Plantilla", 18);
            listaPlantillas = dt.Rows.Cast<DataRow>().Select(row => new Plantilla
            {
                Id = Convert.ToInt32(row["Id"]),
                NombreArchivo = row["NombreArchivo"].ToString(),
                RutaArchivo = EnsureDataUrl(row["RutaArchivo"].ToString(), row["NombreArchivo"].ToString()),
                Version = row["Version"].ToString(),
                Estado = row["Estado"].ToString(),
            }).ToList();

        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al cargar plantillas: {ex.Message}";
        }
    }

    private void OnSeleccionPlantilla(object value)
    {
        if (value is int id)
        {
            var seleccionada = listaPlantillas.FirstOrDefault(p => p.Id == id);
            if (seleccionada != null)
            {
                plantilla.NombreArchivo = seleccionada.NombreArchivo;
                plantilla.RutaArchivo = seleccionada.RutaArchivo;
                plantilla.Version = seleccionada.Version;
                plantilla.Estado = estadosDisponibles.Contains(seleccionada.Estado) ? seleccionada.Estado : null;
                rutaSeleccionada = seleccionada.RutaArchivo;
            }
        }
    }


    private async Task EliminarPlantilla()
    {
        if (string.IsNullOrWhiteSpace(rutaSeleccionada))
        {
            await dialogService.Alert("⚠️ Selecciona una plantilla para eliminar.");
            return;
        }

        try
        {
            await ServicioSoap.TraerConsultaAsync($"DELETE FROM Plantilla WHERE RutaArchivo = '{rutaSeleccionada}'", 18);

            var pathAbsoluto = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", rutaSeleccionada.TrimStart('/'));
            if (File.Exists(pathAbsoluto))
            {
                File.Delete(pathAbsoluto);
            }

            mensaje = "✅ Plantilla eliminada correctamente.";
            plantilla = new();
            rutaSeleccionada = null;
            await CargarPlantillas();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al eliminar plantilla: {ex.Message}";
        }
    }

    private async Task ActualizarPlantilla()
    {
        if (string.IsNullOrWhiteSpace(rutaSeleccionada))
        {
            await dialogService.Alert("⚠️ Selecciona una plantilla para actualizar.");
            return;
        }

        try
        {
            var rutaEscapada = rutaSeleccionada.Replace("'", "''");
            string condicion = $"RutaArchivo = '{rutaEscapada}'";

            string nombreArchivo = plantilla.NombreArchivo?.Replace("'", "''") ?? "";
            string version = plantilla.Version?.Replace("'", "''") ?? "";
            string estado = plantilla.Estado?.Replace("'", "''") ?? "";

            // Guardar valores normales
            await ServicioSoap.ActualizarCampoAsync("Plantilla", "NombreArchivo", $"'{nombreArchivo}'", condicion, 18);
            await ServicioSoap.ActualizarCampoAsync("Plantilla", "Version", $"'{version}'", condicion, 18);
            await ServicioSoap.ActualizarCampoAsync("Plantilla", "Estado", $"'{estado}'", condicion, 18);

            // Guardar contenido PDF base64
            if (!string.IsNullOrWhiteSpace(plantilla.RutaArchivo))
            {
                string rutaBase64 = plantilla.RutaArchivo.Replace("'", "''");
                await ServicioSoap.ActualizarCampoAsync("Plantilla", "RutaArchivo", $"'{rutaBase64}'", condicion, 18);
            }


            mensaje = "✅ Plantilla actualizada correctamente.";
            await CargarPlantillas();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al actualizar plantilla: {ex.Message}";
        }
    }


    private string EnsureDataUrl(string base64, string nombreArchivo)
    {
        if (string.IsNullOrWhiteSpace(base64)) return "";

        if (base64.StartsWith("data:")) return base64;

        var ext = Path.GetExtension(nombreArchivo)?.ToLowerInvariant();
        var mime = ext switch
        {
            ".png" => "image/png",
            ".jpg" or ".jpeg" => "image/jpeg",
            ".pdf" => "application/pdf",
            ".txt" => "text/plain",
            _ => "application/octet-stream"
        };

        return $"data:{mime};base64,{base64}";
    }


    protected override async Task OnInitializedAsync()
    {
        await CargarPlantillas();
    }


}
