@page "/ver"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject NavigationManager Navigation

@using System.Data
@using QrBlazorServices.Clases
@using Radzen
@using Radzen.Blazor

@rendermode InteractiveServer

<h3 class="mb-3">📚 Documentos Registrados</h3>

<RadzenDataGrid Data="@documentos" TItem="DocumentoExtendido" AllowPaging="true" PageSize="10"
                AllowSorting="true"
                FilterMode="FilterMode.Simple"
                ShowPagingSummary="true"
                class="mb-4">
    

    <Columns>
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Id" Title="ID" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nombre" Title="Nombre" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Referencia" Title="Referencia" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="NombrePlantilla" Title="Plantilla" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Categoria" Title="Categoría" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="SubCategoria" Title="Subcategoría" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="Nodo" Title="Nodo Final" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Property="FechaCreacion" Title="Creación" FormatString="{0:yyyy-MM-dd}" />
        <RadzenDataGridColumn TItem="DocumentoExtendido" Title="Acciones">
            <Template Context="doc">
                <RadzenButton Icon="edit"
                              Size="ButtonSize.Small"
                              Style="margin-right: 5px;"
                              ButtonStyle="ButtonStyle.Info"
                              Click="() => EditarDocumento(doc.Id)" />
                <RadzenButton Icon="delete"
                              Size="ButtonSize.Small"
                              ButtonStyle="ButtonStyle.Danger"
                              Click="() => EliminarDocumento(doc.Id)" />
            </Template>

        </RadzenDataGridColumn>


    </Columns>
</RadzenDataGrid>
      
<RadzenButton Text="Nueva Documento" ButtonStyle="ButtonStyle.Primary" Click="@IrARegistro" Icon="add_circle" Style="margin-bottom: 10px; margin-right: 10px;" />

@if (!string.IsNullOrEmpty(mensaje))
{
    <div class="alert @(mensaje.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
        @mensaje
    </div>
}

@code {
    int IdAplicacion = 18;
    List<DocumentoExtendido> documentos = new();
    string mensaje;



    protected override async Task OnInitializedAsync()
    {
        await CargarDocumentos();
    }

    async Task CargarDocumentos()
    {
        documentos.Clear();

        var dtDocumentos = await ServicioUsuario.TraerTablaAsync("Documento", IdAplicacion);
        var dtRelacion = await ServicioUsuario.TraerTablaAsync("DocumentoCategoria", IdAplicacion);
        var dtSubcategorias = await ServicioUsuario.TraerTablaAsync("SubCategoria", IdAplicacion);
        var dtCategorias = await ServicioUsuario.TraerTablaAsync("Categoria", IdAplicacion);
        var dtNodos = await ServicioUsuario.TraerTablaAsync("NodoCategoria", IdAplicacion);
        var dtPlantillas = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);

        var subcategorias = dtSubcategorias.AsEnumerable().Select(r => new SubCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            CategoriaId = Convert.ToInt32(r["CategoriaId"])
        }).ToList();

        var categorias = dtCategorias.AsEnumerable().Select(r => new Categoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var nodos = dtNodos.AsEnumerable().Select(r => new NodoCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();

        var plantillas = dtPlantillas.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString()
        }).ToList();

        var relaciones = dtRelacion.AsEnumerable().ToList();

        documentos = dtDocumentos.AsEnumerable().Select(doc =>
        {
            int id = Convert.ToInt32(doc["Id"]);
            var relacion = relaciones.FirstOrDefault(r => Convert.ToInt32(r["DocumentoId"]) == id);

            var subCatId = relacion != null ? Convert.ToInt32(relacion["SubCategoriaId"]) : 0;
            var nodoId = relacion != null && relacion["NodoCategoriaId"] != DBNull.Value ? Convert.ToInt32(relacion["NodoCategoriaId"]) : 0;

            var subcategoria = subcategorias.FirstOrDefault(s => s.Id == subCatId);
            var categoria = categorias.FirstOrDefault(c => c.Id == subcategoria?.CategoriaId);
            var nodo = nodos.FirstOrDefault(n => n.Id == nodoId);
            var plantilla = plantillas.FirstOrDefault(p => p.Id == Convert.ToInt32(doc["PlantillaId"]));

            return new DocumentoExtendido
            {
                Id = id,
                Nombre = doc["Nombre"].ToString(),
                Referencia = doc["Referencia"].ToString(),

                FechaCreacion = doc["FechaCreacion"] == DBNull.Value
                ? DateTime.MinValue
                : Convert.ToDateTime(doc["FechaCreacion"]),


                Categoria = categoria?.Nombre ?? "",
                SubCategoria = subcategoria?.Nombre ?? "",
                Nodo = nodo?.Nombre ?? "",
                NombrePlantilla = plantilla?.NombreArchivo ?? ""
            };
        }).ToList();
    }


    void EditarDocumento(int id)
    {
        Navigation.NavigateTo($"/rdocumento/{id}");
    }

    async Task EliminarDocumento(int id)
    {
        try
        {
            // Primero eliminar la relación en DocumentoCategoria
            await ServicioUsuario.EliminarListadeLlavesAsync("DocumentoCategoria", "DocumentoId", id.ToString(), IdAplicacion);

            // Luego eliminar el documento
            await ServicioUsuario.EliminarListadeLlavesAsync("Documento", "Id", id.ToString(), IdAplicacion);

            mensaje = "✅ Documento eliminado correctamente.";
            await CargarDocumentos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al eliminar documento: {ex.Message}";
        }
    }

    private void IrARegistro()
    {
        Navigation.NavigateTo("/rdocumento");
    }


}
<!--Version Funcional 18/08-->