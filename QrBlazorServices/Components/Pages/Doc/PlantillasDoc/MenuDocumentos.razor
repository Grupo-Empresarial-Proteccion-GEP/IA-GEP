@page "/menuDoc"
@using AccesoDatos
@using System.Data
@inject NavigationManager Navigation
@inject AccesoDatosSoapClient ServicioUsuario
@rendermode InteractiveServer
@using QrBlazorServices.Components.Pages
@using Radzen
@using Radzen.Blazor
@using QrBlazorServices.Components.Pages.Doc.Categoria
@using QrBlazorServices.Components.Pages.IA
@using QrBlazorServices.Components.Pages.tabajo_de_hoy_19
<div class="d-flex flex-column align-items-center w-100">

    <!-- Barra de navegación con estilo Radzen -->
    <div class="d-flex mb-3 gap-2 justify-content-center">
        <RadzenButton Text="Plantillas Documentos"
                      Click="@(args => CambiarFormulario("PlantillasDoc"))" Shade="Shade.Lighter"
                      ButtonStyle="@(formActivo == "PlantillasDoc" ? ButtonStyle.Primary : ButtonStyle.Light)" />
        <RadzenButton Text="Cantegoria Documentos"
                      Click="@(args => CambiarFormulario("DocxEnti"))" Shade="Shade.Lighter"
                      ButtonStyle="@(formActivo == "DocxEnti" ? ButtonStyle.Primary : ButtonStyle.Light)" />
        <RadzenButton Text="IA Documental"
                      Click="@(args => CambiarFormulario("DestroyerGeminixd"))" Shade="Shade.Lighter"
                      ButtonStyle="@(formActivo == "DestroyerGeminixd" ? ButtonStyle.Primary : ButtonStyle.Light)" />
    </div>

    <!-- Contenedor escalado -->
    <div class="w-100 d-flex justify-content-center">
        <div style="transform: scale(0.96); transform-origin: top center; width: 100%;">

            @switch (formActivo)
            {
                case "PlantillasDoc":
                    <PlantillasDoc />
                    break;
                case "DocxEnti":
                    <DocxEnti />
                    break;
                case "DestroyerGeminixd":
                    <DestroyerGeminixd />
                    break;
            }

        </div>
    </div>
</div>

@code {
    private string formActivo = "PlantillasDoc";

    void CambiarFormulario(string nombre)
    {
        formActivo = nombre;
    }
}
<!--Version Funcional 18/08-->