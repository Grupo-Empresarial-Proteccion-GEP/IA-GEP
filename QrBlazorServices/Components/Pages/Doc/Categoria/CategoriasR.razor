@page "/Documentos"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject NavigationManager Navigation
@rendermode InteractiveServer
@using System.Data
@using Radzen
@using Radzen.Blazor
@using QrBlazorServices.Clases

<h3 class="mb-3">🗂️ Gestión de Nodos de Categoría/Subcategoría</h3>

<RadzenRow>
    <!-- Columna izquierda -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Nodos existentes">
            <RadzenDataGrid Data="@nodosExistentes" TItem="NodoCategoria" RowSelect="SeleccionarNodo" AllowPaging="false">
                <Columns>
                    <RadzenDataGridColumn TItem="NodoCategoria" Property="Id" Title="#" Width="50px" />
                    <RadzenDataGridColumn TItem="NodoCategoria" Property="Nombre" Title="Nombre" />
                    <RadzenDataGridColumn TItem="NodoCategoria" Title="Tipo">
                        <Template Context="n">
                            @if (n.EsCategoria)
                            {
                                <span class="badge bg-primary">Categoría</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Subcategoría</span>
                            }
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="NodoCategoria" Title="Acciones" Width="160px">
                        <Template Context="n">
                            <RadzenButton Icon="edit" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Warning" Style="margin-right: 5px"
                                          Click="() => CargarNodoParaEditar(n)" />
                            <RadzenButton Icon="delete" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Danger"
                                          Click="() => EliminarNodo(n)" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>
        </RadzenFieldset>

        <RadzenFieldset Text="@((editando ? "Editar Nodo" : "Nuevo Nodo"))">
            <RadzenTextBox @bind-Value="nuevoNodo.Nombre" Placeholder="Nombre del nodo" Class="w-100 mb-2" />
            <RadzenDropDown Data="@nodosExistentes.Where(n => n.Id != nuevoNodo.Id).ToList()" @bind-Value="nuevoNodo.PadreId"
                            TextProperty="Nombre" ValueProperty="Id"
                            Placeholder="(Opcional) Nodo padre" Class="w-100 mb-2" />
            <RadzenCheckBox @bind-Value="nuevoNodo.EsCategoria" /> <label class="ms-2">¿Es categoría principal?</label>
            <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Success" Click="@GuardarNodo" Icon="save" Style="margin-top: 10px;" />
            @if (editando)
            {
                <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Secondary" Click="@CancelarEdicion" Style="margin-top: 10px; margin-left:10px;" />
            }
        </RadzenFieldset>
    </RadzenColumn>

    <!-- Columna derecha -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="@tituloSubnodos">
            <RadzenTree Data="@nodosRaiz" Style="max-height: 400px; overflow-y: auto;">
                <RadzenTreeLevel TextProperty="Nombre" ChildrenProperty="Hijos" />
            </RadzenTree>
        </RadzenFieldset>
    </RadzenColumn>
</RadzenRow>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <RadzenAlert Severity="AlertSeverity.Info" Style="margin-top: 15px;">@mensaje</RadzenAlert>
}

@code {
    public class NodoCategoria
    {
        public int Id { get; set; }
        public string Nombre { get; set; } = "";
        public int? PadreId { get; set; }
        public bool EsCategoria { get; set; }
        public List<NodoCategoria> Hijos { get; set; } = new();
    }

    private NodoCategoria nuevoNodo = new();
    private NodoCategoria? nodoSeleccionado;
    private List<NodoCategoria> nodosExistentes = new();
    private List<NodoCategoria> nodosRaiz = new();
    private string mensaje;
    private bool editando = false;

    private string tituloSubnodos => $"Subnodos de {nodoSeleccionado?.Nombre ?? "..."}";

    protected override async Task OnInitializedAsync()
    {
        await CargarNodos();
    }

    private async Task CargarNodos()
    {
        nodosExistentes.Clear();
        nodosRaiz.Clear();

        var dt = await ServicioUsuario.TraerConsultaAsync("SELECT Id, Nombre, PadreId, EsCategoria FROM NodoCategoria", 18);

        nodosExistentes = dt.Rows.Cast<DataRow>().Select(row => new NodoCategoria
        {
            Id = Convert.ToInt32(row["Id"]),
            Nombre = row["Nombre"].ToString() ?? "",
            PadreId = row["PadreId"] != DBNull.Value ? Convert.ToInt32(row["PadreId"]) : (int?)null,
            EsCategoria = Convert.ToBoolean(row["EsCategoria"])
        }).ToList();

        var nodosPadres = nodosExistentes.Where(n => n.PadreId == null).ToList();

        foreach (var raiz in nodosPadres)
        {
            nodosRaiz.Add(ConstruirJerarquia(raiz));
        }
    }

    private NodoCategoria ConstruirJerarquia(NodoCategoria nodo)
    {
        nodo.Hijos = nodosExistentes.Where(n => n.PadreId == nodo.Id).Select(ConstruirJerarquia).ToList();
        return nodo;
    }

    private async Task GuardarNodo()
    {
        try
        {
            // Paso 1: Insertar en NodoCategoria (siempre)
            var tablaNodo = new DataTable("NodoCategoria");
            tablaNodo.Columns.Add("Id", typeof(int));
            tablaNodo.Columns.Add("Nombre", typeof(string));
            tablaNodo.Columns.Add("PadreId", typeof(int));
            tablaNodo.Columns.Add("EsCategoria", typeof(bool));

            var rowNodo = tablaNodo.NewRow();
            rowNodo["Id"] = 0;
            rowNodo["Nombre"] = nuevoNodo.Nombre;
            rowNodo["PadreId"] = nuevoNodo.PadreId.HasValue ? nuevoNodo.PadreId : DBNull.Value;
            rowNodo["EsCategoria"] = nuevoNodo.EsCategoria;
            tablaNodo.Rows.Add(rowNodo);

            await ServicioUsuario.InsertarTablaAsync(tablaNodo, "NodoCategoria", 18);

            // Paso 2: Si es categoría raíz, guardar también en Categoria
            if (nuevoNodo.EsCategoria)
            {
                var tablaCat = new DataTable("Categoria");
                tablaCat.Columns.Add("Id", typeof(int));
                tablaCat.Columns.Add("Nombre", typeof(string));
                tablaCat.Columns.Add("PadreId", typeof(int));

                var rowCat = tablaCat.NewRow();
                rowCat["Id"] = 0;
                rowCat["Nombre"] = nuevoNodo.Nombre;
                rowCat["PadreId"] = DBNull.Value;

                tablaCat.Rows.Add(rowCat);
                await ServicioUsuario.InsertarTablaAsync(tablaCat, "Categoria", 18);
            }
            else if (nuevoNodo.PadreId.HasValue)
            {
                // Paso 3: Si es subcategoría, intenta insertarla solo si el Padre está en Categoria
                var existeCategoria = await ExisteCategoria(nuevoNodo.PadreId.Value);
                if (existeCategoria)
                {
                    var tablaSub = new DataTable("SubCategoria");
                    tablaSub.Columns.Add("Id", typeof(int));
                    tablaSub.Columns.Add("CategoriaId", typeof(int));
                    tablaSub.Columns.Add("Nombre", typeof(string));

                    var rowSub = tablaSub.NewRow();
                    rowSub["Id"] = 0;
                    rowSub["CategoriaId"] = nuevoNodo.PadreId;
                    rowSub["Nombre"] = nuevoNodo.Nombre;

                    tablaSub.Rows.Add(rowSub);
                    await ServicioUsuario.InsertarTablaAsync(tablaSub, "SubCategoria", 18);
                }
                // Si no existe en Categoria, se omite el insert en SubCategoria, permitiendo jerarquía libre
            }

            mensaje = "✅ Nodo guardado correctamente.";
            nuevoNodo = new();
            await CargarNodos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al guardar nodo: {ex.Message}";
        }
    }

    // Verifica si un ID existe en la tabla Categoria
    private async Task<bool> ExisteCategoria(int idCategoria)
    {
        var dt = await ServicioUsuario.TraerConsultaAsync($"SELECT COUNT(*) AS Total FROM Categoria WHERE Id = {idCategoria}", 18);
        return Convert.ToInt32(dt.Rows[0]["Total"]) > 0;
    }


    private async Task EliminarNodo(NodoCategoria nodo)
    {
        try
        {
            if (nodosExistentes.Any(n => n.PadreId == nodo.Id))
            {
                mensaje = "❌ No se puede eliminar un nodo que tiene hijos.";
                return;
            }

            var tabla = new DataTable("NodoCategoria");
            tabla.Columns.Add("Id", typeof(int));
            var row = tabla.NewRow();
            row["Id"] = nodo.Id;
            tabla.Rows.Add(row);

            await ServicioUsuario.EliminarFilaAsync(tabla, 18);
            mensaje = "✅ Nodo eliminado correctamente.";
            await CargarNodos();
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al eliminar nodo: {ex.Message}";
        }
    }

    private void CargarNodoParaEditar(NodoCategoria nodo)
    {
        nuevoNodo = new NodoCategoria
        {
            Id = nodo.Id,
            Nombre = nodo.Nombre,
            PadreId = nodo.PadreId,
            EsCategoria = nodo.EsCategoria
        };
        editando = true;
    }

    private void CancelarEdicion()
    {
        nuevoNodo = new();
        editando = false;
    }

    private async Task SeleccionarNodo(NodoCategoria nodo)
    {
        nodoSeleccionado = nodo;
    }
}
