@page "/categorias"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject Radzen.DialogService dialogService
@inject NavigationManager Navigation
@using System.Data
@using Radzen
@using Radzen.Blazor
@using QrBlazorServices.Clases
@rendermode InteractiveServer

<h3 class="mb-3">Gestión de Categorías y Subcategorías</h3>

<!-- Dropdown para seleccionar categoría -->
<RadzenDropDown TValue="int"
                Data="@categorias"
                TextProperty="Nombre"
                ValueProperty="Id"
                @bind-Value="categoriaSeleccionadaId"
                Placeholder="Seleccione una categoría"
                Style="width: 300px; margin-bottom: 15px;"
                Change="@(args => CargarSubcategorias())" />

<!-- Mostrar subcategorías -->
@if (categoriaSeleccionadaId > 0)
{
    <RadzenDataGrid Data="@subcategoriasFiltradas" TItem="SubCategoria" ShowPagingSummary="false" ShowPagination="false">
        <Columns>
            <RadzenDataGridColumn TItem="SubCategoria" Property="Nombre" Title="Subcategoría" />
            <RadzenDataGridColumn TItem="SubCategoria" Title="Acciones">
                <Template Context="sub">
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Click="@(args => EliminarSubcategoria(sub.Id))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>

    <!-- Agregar nueva subcategoría -->
    <div class="mt-3">
        <RadzenTextBox @bind-Value="nuevaSubcategoria" Placeholder="Nueva subcategoría" Style="width: 300px;" />
        <RadzenButton Text="Agregar" Icon="add_circle"
                      ButtonStyle="ButtonStyle.Primary"
                      Click="@(() => AgregarSubcategoria())"
                      Style="margin-left: 10px;" />

        <RadzenButton Text="Nueva Entidad" ButtonStyle="ButtonStyle.Secondary" Click="@IrAInicio" Icon="add_circle" Style="margin-bottom: 10px; margin-right: 10px;" />

    </div>


}


else
{
    <RadzenAlert Severity="AlertSeverity.Info">Seleccione una categoría para ver sus subcategorías.</RadzenAlert>
}

@code {


    // Datos
    private List<Categoria> categorias = new();
    private List<SubCategoria> todasSubcategorias = new();
    private List<SubCategoria> subcategoriasFiltradas = new();

    private int categoriaSeleccionadaId = 0;
    private string nuevaSubcategoria;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategorias();
    }

    private async Task CargarCategorias()
    {
        try
        {
            var dt = await ServicioUsuario.TraerConsultaAsync("SELECT * FROM Categoria", 18);
            categorias = dt.Rows.Cast<DataRow>().Select(row => new Categoria
            {
                Id = Convert.ToInt32(row["Id"]),
                Nombre = row["Nombre"].ToString()
            }).ToList();
        }
        catch (Exception ex)
        {
            await dialogService.Alert($"❌ Error al cargar categorías: {ex.Message}");
        }
    }

    private async Task CargarSubcategorias()
    {
        if (categoriaSeleccionadaId <= 0)
        {
            subcategoriasFiltradas = new();
            return;
        }

        try
        {
            var dt = await ServicioUsuario.TraerConsultaAsync("SELECT * FROM SubCategoria", 18);

            subcategoriasFiltradas = dt.Rows.Cast<DataRow>()
                .Where(row => Convert.ToInt32(row["CategoriaId"]) == categoriaSeleccionadaId)
                .Select(row => new SubCategoria
                {
                    Id = Convert.ToInt32(row["Id"]),
                    CategoriaId = Convert.ToInt32(row["CategoriaId"]),
                    Nombre = row["Nombre"].ToString()
                }).ToList();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await dialogService.Alert($"❌ Error al cargar subcategorías: {ex.Message}");
        }
    }

    private async Task AgregarSubcategoria()
    {
        Console.WriteLine($"➡ Intentando agregar subcategoría: {nuevaSubcategoria}, categoría ID: {categoriaSeleccionadaId}");

        if (string.IsNullOrWhiteSpace(nuevaSubcategoria))
        {
            await dialogService.Alert("⚠️ Debe ingresar un nombre para la subcategoría.");
            return;
        }

        if (categoriaSeleccionadaId <= 0)
        {
            await dialogService.Alert("⚠️ Debe seleccionar una categoría válida.");
            return;
        }

        try
        {
            // Traer esquema real desde la BD
            var esquema = await ServicioUsuario.TraerEsquemaTablaAsync("SubCategoria", 18);

            // Crear nueva fila desde el esquema
            var row = esquema.NewRow();
            row["CategoriaId"] = categoriaSeleccionadaId;
            row["Nombre"] = nuevaSubcategoria.Trim();
            esquema.Rows.Add(row);

            await ServicioUsuario.InsertarTablaAsync(esquema, "SubCategoria", 18);

            Console.WriteLine("✅ Subcategoría agregada correctamente.");

            nuevaSubcategoria = "";
            await CargarSubcategorias();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error al agregar subcategoría: {ex}");
            await dialogService.Alert($"❌ Error al agregar subcategoría: {ex.Message}");
        }
    }



    private async Task EliminarSubcategoria(int id)
    {
        try
        {
            await ServicioUsuario.TraerConsultaAsync($"DELETE FROM SubCategoria WHERE Id = {id}", 18);
            await CargarSubcategorias();
        }
        catch (Exception ex)
        {
            await dialogService.Alert($"❌ Error al eliminar subcategoría: {ex.Message}");
        }
    }
    private void IrAInicio() => Navigation.NavigateTo("/Documentos");
}
