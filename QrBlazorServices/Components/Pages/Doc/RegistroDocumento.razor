@page "/rdocumento"
@inject AccesoDatos.AccesoDatosSoapClient ServicioUsuario
@inject NavigationManager Navigation

@using QrBlazorServices.Clases
@using System.Data
@using Radzen
@using Radzen.Blazor

@rendermode InteractiveServer

<h3>📄 Registro de Documento</h3>

<RadzenRow>
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Datos del Documento" Style="max-width: 100%;">

            <RadzenTextBox @bind-Value="documento.Nombre"
                           Placeholder="Nombre del documento"
                           Name="Nombre"
                           Class="w-100 mb-3" />
            <RadzenRequiredValidator Component="Nombre" Text="El nombre es obligatorio" Style="color:red;" />

            <RadzenTextBox @bind-Value="documento.Referencia"
                           Placeholder="Referencia"
                           Class="w-100 mb-3" />

            <RadzenDropDown @bind-Value="documento.PlantillaId"
                            Data="@plantillas"
                            TextProperty="NombreArchivo"
                            ValueProperty="Id"
                            Placeholder="Seleccione plantilla"
                            Class="w-100 mb-3" />

            <RadzenDropDown @bind-Value="categoriaSeleccionadaId"
                            Data="@categorias"
                            TextProperty="Nombre"
                            ValueProperty="Id"
                            Placeholder="Seleccione categoría"
                            Change="@(args => FiltrarSubcategorias((int)args))"
                            Class="w-100 mb-3" />

            <RadzenDropDown @bind-Value="subCategoriaSeleccionadaId"
                            Data="@subcategoriasFiltradas"
                            TextProperty="Nombre"
                            ValueProperty="Id"
                            Placeholder="Seleccione subcategoría"
                            Change="@(args => FiltrarNodos((int)args))"
                            Class="w-100 mb-3" />

            <RadzenDropDown @bind-Value="nodoSeleccionadoId"
                            Data="@nodosFiltrados"
                            TextProperty="Nombre"
                            ValueProperty="Id"
                            Placeholder="Seleccione nodo hijo"
                            AllowClear="true"
                            Class="w-100 mb-3" />

            <div class="mb-3">
                <RadzenButton Text="Registrar Documento"
                              Icon="save"
                              ButtonStyle="ButtonStyle.Success"
                              Click="GuardarDocumento"
                              Class="me-2" />
            </div>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="alert @(mensaje.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
                    @mensaje
                </div>
            }

        </RadzenFieldset>
    </RadzenColumn>
</RadzenRow>

@code {
    Documento documento = new();
    List<Plantilla> plantillas = new();
    List<Categoria> categorias = new();
    List<SubCategoria> todasSubcategorias = new();
    List<SubCategoria> subcategoriasFiltradas = new();
    List<NodoCategoria> todosNodos = new();
    List<NodoCategoria> nodosFiltrados = new();

    int? categoriaSeleccionadaId;
    int? subCategoriaSeleccionadaId;
    int? nodoSeleccionadoId;

    int IdAplicacion = 18;
    string mensaje;

    protected override async Task OnInitializedAsync()
    {
        await CargarPlantillas();
        await CargarCategorias();
        await CargarSubcategorias();
        await CargarNodos();
    }

    async Task CargarPlantillas()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("Plantilla", IdAplicacion);
        plantillas = ds.AsEnumerable().Select(r => new Plantilla
        {
            Id = Convert.ToInt32(r["Id"]),
            NombreArchivo = r["NombreArchivo"].ToString()
        }).ToList();
    }

    async Task CargarCategorias()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("Categoria", IdAplicacion);
        categorias = ds.AsEnumerable().Select(r => new Categoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString()
        }).ToList();
    }

    async Task CargarSubcategorias()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("SubCategoria", IdAplicacion);
        todasSubcategorias = ds.AsEnumerable().Select(r => new SubCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            CategoriaId = Convert.ToInt32(r["CategoriaId"])
        }).ToList();
    }

    async Task CargarNodos()
    {
        var ds = await ServicioUsuario.TraerTablaAsync("NodoCategoria", IdAplicacion);
        todosNodos = ds.AsEnumerable().Select(r => new NodoCategoria
        {
            Id = Convert.ToInt32(r["Id"]),
            Nombre = r["Nombre"].ToString(),
            PadreId = Convert.ToInt32(r["PadreId"])
        }).ToList();
    }

    void FiltrarSubcategorias(int categoriaId)
    {
        subcategoriasFiltradas = todasSubcategorias.Where(x => x.CategoriaId == categoriaId).ToList();
        subCategoriaSeleccionadaId = null;
        nodoSeleccionadoId = null;
        nodosFiltrados.Clear();
    }

    void FiltrarNodos(int subcategoriaId)
    {
        nodosFiltrados = todosNodos.Where(x => x.PadreId == subcategoriaId).ToList();
        nodoSeleccionadoId = null;
    }

    async Task GuardarDocumento()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(documento.Nombre))
            {
                mensaje = "❌ El nombre del documento es obligatorio.";
                return;
            }

            var dtDocumento = new DataTable("Documento");
            dtDocumento.Columns.Add("Nombre", typeof(string));
            dtDocumento.Columns.Add("Referencia", typeof(string));
            dtDocumento.Columns.Add("PlantillaId", typeof(int));
            dtDocumento.Columns.Add("FechaCreacion", typeof(DateTime));

            var fila = dtDocumento.NewRow();
            fila["Nombre"] = documento.Nombre.Trim();
            fila["Referencia"] = documento.Referencia ?? string.Empty;
            fila["PlantillaId"] = documento.PlantillaId ?? 0;
            fila["FechaCreacion"] = DateTime.Now;
            dtDocumento.Rows.Add(fila);

            var idGenerado = await ServicioUsuario.InsertarFilaDevuelveConsecutivoAsync(dtDocumento, "Documento", IdAplicacion);
            int documentoId = Convert.ToInt32(idGenerado);

            // Relación con SubCategoría y NodoCategoria
            if (subCategoriaSeleccionadaId.HasValue)
            {
                var dtRelacion = new DataTable("DocumentoCategoria");
                dtRelacion.Columns.Add("DocumentoId", typeof(int));
                dtRelacion.Columns.Add("SubCategoriaId", typeof(int));
                dtRelacion.Columns.Add("NodoCategoriaId", typeof(int)); // NUEVO CAMPO

                var filaRelacion = dtRelacion.NewRow();
                filaRelacion["DocumentoId"] = documentoId;
                filaRelacion["SubCategoriaId"] = subCategoriaSeleccionadaId.Value;
                filaRelacion["NodoCategoriaId"] = nodoSeleccionadoId ?? (object)DBNull.Value;
                dtRelacion.Rows.Add(filaRelacion);

                await ServicioUsuario.InsertarTablaAsync(dtRelacion, "DocumentoCategoria", IdAplicacion);
            }

            mensaje = "✅ Documento registrado correctamente.";
            documento = new(); // limpiar campos
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al guardar documento: {ex.Message}";
        }
    }

    public class Documento
    {
        public string? Nombre { get; set; }
        public string? Referencia { get; set; }
        public int? PlantillaId { get; set; }
    }

    public class Plantilla
    {
        public int Id { get; set; }
        public string? NombreArchivo { get; set; }
    }

    public class Categoria
    {
        public int Id { get; set; }
        public string? Nombre { get; set; }
    }

    public class SubCategoria
    {
        public int Id { get; set; }
        public string? Nombre { get; set; }
        public int CategoriaId { get; set; }
    }

    public class NodoCategoria
    {
        public int Id { get; set; }
        public string? Nombre { get; set; }
        public int PadreId { get; set; }
    }
}
