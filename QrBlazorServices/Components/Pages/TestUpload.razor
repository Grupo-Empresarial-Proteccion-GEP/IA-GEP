@page "/testupload"
@using Microsoft.AspNetCore.Components.Forms
@using Radzen
@rendermode InteractiveServer

<h3>🧪 Prueba de Carga de Imagen Base64</h3>

<RadzenFileInput TValue="IBrowserFile"
                 Accept="image/*"
                 ChooseText="Seleccionar imagen"
                 Change="@OnImageSelected"
                 Style="width: 100%; max-width: 400px;" />

@if (!string.IsNullOrEmpty(imagenBase64))
{
    <p>✅ Imagen cargada correctamente:</p>
    <img src="@imagenBase64" style="max-width: 100%; max-height: 300px;" />
}

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(mensaje.Contains("✅") ? "alert-success" : "alert-danger") mt-3">@mensaje</div>
}

@code {
    private string imagenBase64;
    private string mensaje;

    private async Task OnImageSelected(object value)
    {
        try
        {
            if (value is not IBrowserFile file)
            {
                mensaje = "❌ No se seleccionó ningún archivo válido.";
                return;
            }

            if (!file.ContentType.StartsWith("image/"))
            {
                mensaje = "❌ Solo se permiten archivos de imagen.";
                return;
            }

            const long maxSize = 1024 * 1024; // 1 MB

            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var bytes = ms.ToArray();
            imagenBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            mensaje = "✅ Imagen cargada correctamente.";
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error: {ex.Message}";
        }
    }
}
