@page "/testupload"
@using Microsoft.AspNetCore.Components.Forms
@rendermode InteractiveServer

<h3>🧪 Prueba de Carga de Imagen Base64 y Guardado en Servidor</h3>

<InputFile OnChange="OnInputFileChange" accept="image/*" />

@if (!string.IsNullOrEmpty(imagenBase64))
{
    <p>✅ Imagen convertida a Base64:</p>
    <img src="@imagenBase64" style="max-width: 100%; max-height: 300px;" />
}

@if (!string.IsNullOrEmpty(rutaGuardada))
{
    <p>🖼️ Imagen cargada desde el servidor:</p>
    <img src="@rutaGuardada" style="max-width: 100%; max-height: 300px;" />
}

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert @(mensaje.Contains("✅") ? "alert-success" : "alert-danger") mt-3">
        @mensaje.Replace("\n", "<br />")
    </div>
}

@code {
    private string imagenBase64;
    private string rutaGuardada;
    private string mensaje;

    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            mensaje = $"🔍 Archivo seleccionado: {file?.Name ?? "null"}";

            if (file == null)
            {
                mensaje += "\n❌ No se recibió ningún archivo.";
                return;
            }

            if (!file.ContentType.StartsWith("image/"))
            {
                mensaje += $"\n❌ Tipo no permitido: {file.ContentType}";
                return;
            }

            const long maxSize = 1024 * 1024; // 1 MB
            using var stream = file.OpenReadStream(maxSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);

            var bytes = ms.ToArray();
            imagenBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";

            // Guardar archivo en disco
            var nombreUnico = $"{Guid.NewGuid()}_{file.Name}";
            var rutaFisica = Path.Combine("wwwroot", "uploads", nombreUnico);
            var rutaWeb = $"uploads/{nombreUnico}";

            Directory.CreateDirectory("wwwroot/uploads"); // Asegura que exista la carpeta

            await using var fs = new FileStream(rutaFisica, FileMode.Create);
            await fs.WriteAsync(bytes, 0, bytes.Length);

            rutaGuardada = rutaWeb;
            mensaje += $"\n✅ Imagen guardada como: {rutaWeb}";
        }
        catch (Exception ex)
        {
            mensaje += $"\n❌ Error: {ex.Message}";
        }
    }
}
