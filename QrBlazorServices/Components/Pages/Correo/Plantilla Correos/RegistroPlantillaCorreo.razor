@page "/registro"
@page "/registro/{PlantillaId:int?}"

@using Microsoft.AspNetCore.Components.Forms
@inject IPlantillaService Servicio
@inject NavigationManager Navigation

<h3 class="mb-4">📄 Gestión de Plantillas</h3>

<RadzenRow>
    <!-- Columna izquierda: Formulario -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="📤 Cargar / Editar Plantilla" Style="max-width: 100%;">

            <RadzenTextBox @bind-Value="plantilla.Nombre"
                           Placeholder="Nombre de la plantilla"
                           Name="Nombre"
                           Class="w-100 mb-3" />
            <RadzenRequiredValidator Component="Nombre" Text="El nombre es obligatorio" Style="color: red" />

            <RadzenTextBox @bind-Value="plantilla.Referencia"
                           Placeholder="Referencia"
                           Name="Referencia"
                           Class="w-100 mb-3" />
            <RadzenRequiredValidator Component="Referencia" Text="La referencia es obligatoria" Style="color: red" />

            <RadzenTextBox @bind-Value="plantilla.Version"
                           Placeholder="Versión"
                           Name="Version"
                           Class="w-100 mb-3" />

            <InputFile OnChange="OnFileChange" />

            @if (!string.IsNullOrEmpty(plantilla.Imagen))
            {
                <img src="@plantilla.Imagen" style="max-width: 100%; margin-top: 1rem;" />
            }

            <RadzenButton Text="💾 Guardar Plantilla"
                          Icon="save"
                          Style="margin-top: 1rem;"
                          Click="GuardarOActualizarPlantilla"
                          ButtonStyle="ButtonStyle.Primary" />

            @if (!string.IsNullOrWhiteSpace(mensaje))
            {
                <p class="mt-3">@mensaje</p>
            }
        </RadzenFieldset>
    </RadzenColumn>

    <!-- Columna derecha: Vista previa PDF -->
    <RadzenColumn Width="6">
        <RadzenFieldset Text="Vista previa del documento" Style="max-width: 100%;">
            @if (!string.IsNullOrWhiteSpace(rutaSeleccionada))
            {
                <div class="d-flex justify-content-center">
                    <iframe src="@rutaSeleccionada"
                            width="100%"
                            height="600px"
                            style="border: none;"></iframe>
                </div>
            }
            else
            {
                <p>No hay vista previa disponible.</p>
            }
        </RadzenFieldset>
    </RadzenColumn>
</RadzenRow>

@code {
    [Parameter]
    public int? PlantillaId { get; set; }

    private Plantilla plantilla = new();
    private string mensaje;
    private string rutaSeleccionada;

    protected override async Task OnInitializedAsync()
    {
        if (PlantillaId.HasValue)
        {
            await CargarPlantillaExistente(PlantillaId.Value);
        }
    }

    private async Task CargarPlantillaExistente(int id)
    {
        try
        {
            var resultado = await Servicio.ObtenerPlantillaPorIdAsync(id);
            if (resultado != null)
            {
                plantilla = resultado;
                rutaSeleccionada = resultado.Imagen;
                mensaje = $"📄 Editando plantilla: {plantilla.Nombre}";
            }
            else
            {
                mensaje = "❌ No se encontró la plantilla.";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error al cargar plantilla: {ex.Message}";
        }
    }

    private async Task GuardarOActualizarPlantilla()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(plantilla.Nombre) || string.IsNullOrWhiteSpace(plantilla.Referencia))
            {
                mensaje = "❌ El nombre y la referencia son obligatorios.";
                return;
            }

            bool resultado;

            if (PlantillaId.HasValue)
            {
                resultado = await Servicio.ActualizarPlantillaAsync(plantilla);
                mensaje = resultado ? "✅ Plantilla actualizada con éxito." : "❌ Error al actualizar.";
            }
            else
            {
                resultado = await Servicio.InsertarPlantillaAsync(plantilla);
                mensaje = resultado ? "✅ Plantilla registrada con éxito." : "❌ Error al registrar.";
            }

            if (resultado)
            {
                Navigation.NavigateTo("/lista-plantillas", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            mensaje = $"❌ Error: {ex.Message}";
        }
    }

    private async Task OnFileChange(InputFileChangeEventArgs e)
    {
        var archivo = e.File;
        if (archivo != null)
        {
            var nombre = Path.GetFileName(archivo.Name);
            var ruta = Path.Combine("wwwroot", "plantillas", nombre);
            var pathFisico = Path.Combine(Directory.GetCurrentDirectory(), ruta);

            using var stream = archivo.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10MB
            using var fs = File.Create(pathFisico);
            await stream.CopyToAsync(fs);

            plantilla.Imagen = $"/plantillas/{nombre}";
            rutaSeleccionada = plantilla.Imagen;
        }
    }
}
