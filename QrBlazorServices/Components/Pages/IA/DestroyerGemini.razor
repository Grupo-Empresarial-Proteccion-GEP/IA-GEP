    <!-- //////////////////////////////////////////////////////////////////////////////////// -->
    <!-- //////////////////////////////////////////////////////////////////////////////////// -->

    private async Task SendToGemini()
    {
        cargando = true;

        try
        {
            // 1. Obtener la plantilla
            string condicion = "Nombre = 'GenerarDocumentoFormal'";
            string campos = "Plantilla";
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Prompts", campos, condicion, 18);

            if (resultado == null || resultado.Rows.Count == 0)
            {
                ResponseText = "<p><strong>No se encontró el prompt configurado.</strong></p>";
                return;
            }

            string plantillaPrompt = resultado.Rows[0]["Plantilla"].ToString();

            // 2. Construir el prompt
            string promptFinal = plantillaPrompt
                .Replace("{TipoDocumento}", TipoDocumento)
                .Replace("{UserPrompt}", UserPrompt ?? "")
                .Replace("{Ciudad}", Ciudad ?? "")
                .Replace("{Fecha}", DateTime.Now.ToString("dd 'de' MMMM 'del' yyyy"))
                .Replace("{Receptor}", Receptor ?? "")
                .Replace("{Direccion_R}", Direccion_R ?? "")
                .Replace("{Documento_R}", Documento_R ?? "")
                .Replace("{NumeroDoc_R}", NumeroDoc_R ?? "")
                .Replace("{Telefono_R}", Telefono_R ?? "")
                .Replace("{Correo_R}", Correo_R ?? "")
                .Replace("{Emisor}", Emisor ?? "")
                .Replace("{Direccion_E}", Direccion_E ?? "")
                .Replace("{Documento_E}", Documento_E ?? "")
                .Replace("{NumeroDoc_E}", NumeroDoc_E ?? "")
                .Replace("{Telefono_E}", Telefono_E ?? "")
                .Replace("{Correo_E}", Correo_E ?? "")
                .Replace("{Asunto}", Asunto ?? "")
                .Replace("{contenidoAuxiliar}", contenidoAuxiliar ?? "")
                .Replace("{fileContent}", fileContent ?? "");

            // 3. Validación mínima de datos (prompt básico si está vacío)
            if (string.IsNullOrWhiteSpace(Ciudad + Emisor + Receptor + fileContent))
            {
                promptFinal = $"Instrucciones del usuario: {UserPrompt}\n\nPor favor genera la respuesta como HTML usando etiquetas como <strong>, <p>, <ul>, <li>, <br>, <h2>, etc. No uses Markdown.";
            }

            int sesionId = await GuardarSesionConversacionAsync(TipoDocumento, Asunto);

            // Guardar selección de opciones (si existen)
            if (opcionesSeleccionadas?.Any() == true)
            {
                string opcionesTexto = string.Join("\n", opcionesSeleccionadas.Select((op, i) => $"{i + 1}. {op}"));
                await GuardarMensajeConversacionAsync(sesionId, "user", $"Opciones seleccionadas:\n{opcionesTexto}");
            }

            // Guardar mensaje enviado por el usuario
            await GuardarMensajeConversacionAsync(sesionId, "user", promptFinal);


            // 5. Enviar a IA con reintentos
            int intentos = 0;
            int maxIntentos = 5;
            int esperaMs = 2000;

            while (intentos < maxIntentos)
            {
                try
                {
                    ResponseText = await ChatService.SendMessageAsync(promptFinal);
                    await GuardarMensajeConversacionAsync(sesionId, "assistant", ResponseText);
                    break;
                }
                catch (HttpRequestException ex)
                {
                    if (ex.Message.Contains("503"))
                    {
                        intentos++;
                        if (intentos == maxIntentos)
                        {
                            ResponseText = "El servicio de IA está sobrecargado. Intenta nuevamente más tarde.";
                            break;
                        }

                        await Task.Delay(esperaMs);
                        esperaMs *= 2;
                    }
                    else
                    {
                        ResponseText = $"Se produjo un error inesperado: {ex.Message}";
                        break;
                    }
                }
            }

            mostrarHtml = true;
        }
        catch (Exception ex)
        {
            ResponseText = $"<p><strong>Ocurrió un error:</strong> {ex.Message}</p>";
        }
        finally
        {
            cargando = false;
            mostrarSugerencias = false;
        }
    }

