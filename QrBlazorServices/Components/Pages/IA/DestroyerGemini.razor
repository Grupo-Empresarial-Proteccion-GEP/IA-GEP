    private async Task GuardarMensajeConversacionAsync(int sesionId, string rol, string contenido)
    {
        DataTable tablaHistorial = new DataTable("HistorialConversaciones");
        tablaHistorial.Columns.Add("Id", typeof(int));
        tablaHistorial.Columns.Add("SesionId", typeof(int));
        tablaHistorial.Columns.Add("Fecha", typeof(DateTime));
        tablaHistorial.Columns.Add("Rol", typeof(string));
        tablaHistorial.Columns.Add("Contenido", typeof(string));

        DataRow fila = tablaHistorial.NewRow();
        fila["Id"] = 0;
        fila["SesionId"] = sesionId;
        fila["Fecha"] = DateTime.Now;
        fila["Rol"] = rol ?? "";
        fila["Contenido"] = contenido ?? "";

        tablaHistorial.Rows.Add(fila);

        await _servicioUsuario.InsertarTablaAsync(tablaHistorial, "HistorialConversaciones", 18);
    }

