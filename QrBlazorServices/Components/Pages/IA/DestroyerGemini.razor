    private async Task<int> GuardarSesionConversacionAsync(string tipoDocumento, string asunto)
    {
        DataTable tabla = new DataTable("SesionesConversacion");
        tabla.Columns.Add("Id", typeof(int));
        tabla.Columns.Add("Usuario", typeof(string));
        tabla.Columns.Add("FechaInicio", typeof(DateTime));
        tabla.Columns.Add("TipoDocumento", typeof(string));
        tabla.Columns.Add("Asunto", typeof(string));

        var fila = tabla.NewRow();
        fila["Id"] = 0;
        fila["Usuario"] = DBNull.Value; // ← Usuario no necesario
        fila["FechaInicio"] = DateTime.Now;
        fila["TipoDocumento"] = tipoDocumento ?? "";
        fila["Asunto"] = asunto ?? "";

        tabla.Rows.Add(fila);

        string id = await _servicioUsuario.InsertarFilaDevuelveConsecutivoAsync(tabla, "SesionesConversacion", 18);
        return int.TryParse(id, out int sesionId) ? sesionId : 0;
    }

