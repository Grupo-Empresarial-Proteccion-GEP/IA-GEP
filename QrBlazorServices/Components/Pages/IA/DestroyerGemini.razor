            <div class="text-center mb-4">
                <h6 class="fw-bold fs-6">📄 Generador Inteligente de Documentos</h6>
            </div>

            <div class="row gy-4">
                <!-- COLUMNA IZQUIERDA -->
                <div class="col-lg-6">
                    <RadzenFieldset Text="Buscar Usuario">
                        <div class="d-flex gap-2">
                            <RadzenTextBox Placeholder="Buscar por documento" Style="width: 100%; margin-bottom: 10px;" @bind-Value="nombreBuscado" />
                            <RadzenButton Icon="search" Text="Buscar" Click="@BuscarClientePorDocumento" Style="width: 25%; margin-bottom: 10px;" Disabled="@buscandoCliente" />
                        </div>
                    </RadzenFieldset>

                    <div class="row">
                        <!-- Receptor -->
                        <div class="col-md-6">
                            <RadzenFieldset Text="Receptor">
                                <RadzenTextBox Placeholder="Nombre" @bind-Value="Receptor" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenDropDown Placeholder="Tipo de documento" @bind-Value="Documento_R" Data="@tiposDocumento" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Número de documento" @bind-Value="NumeroDoc_R" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Dirección" @bind-Value="Direccion_R" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Teléfono" @bind-Value="Telefono_R" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Correo" @bind-Value="Correo_R" Style="width: 100%; margin-bottom: 10px;" />
                            </RadzenFieldset>
                        </div>

                        <!-- Emisor -->
                        <div class="col-md-6">
                            <RadzenFieldset Text="Emisor">
                                <RadzenTextBox Placeholder="Nombre" @bind-Value="Emisor" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenDropDown Placeholder="Tipo de documento" @bind-Value="Documento_E" Data="@tiposDocumento" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Número de documento" @bind-Value="NumeroDoc_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Dirección" @bind-Value="Direccion_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Teléfono" @bind-Value="Telefono_E" Style="width: 100%; margin-bottom: 10px;" />
                                <RadzenTextBox Placeholder="Correo" @bind-Value="Correo_E" Style="width: 100%; margin-bottom: 10px;" />
                            </RadzenFieldset>
                        </div>
                    </div>

                    <RadzenFieldset Text="Información del Documento">
                        <RadzenDropDown Placeholder="Tipo de documento" @bind-Value="TipoDocumento" Data="@tiposDocumentoDoc" Style="width: 100%; margin-bottom: 10px;" />
                        <RadzenTextBox Placeholder="Ciudad" @bind-Value="Ciudad" Style="width: 100%; margin-bottom: 10px;" />
                        <RadzenTextBox Placeholder="Asunto" @bind-Value="Asunto" Style="width: 100%; margin-bottom: 10px;" />
                    </RadzenFieldset>

                    <RadzenFieldset Text="Descripción para la IA">
                        <RadzenDropDown Placeholder="Seleccionar IA" @bind-Value="IASeleccionada" Data="@iasDisponibles" Style="width: 100%; margin-bottom: 10px;"
                                        Change="@(value => CambiarIA(value?.ToString()))" />
                        <RadzenTextArea @bind-Value="UserPrompt" Placeholder="Describe claramente qué quieres generar o analizar..." Style="width: 100%; min-height: 180px;" />
                    </RadzenFieldset>
                </div>

                <!-- COLUMNA DERECHA -->
                <div class="col-lg-6 d-flex flex-column">
                    <RadzenFieldset Text="Adjuntar archivo">
                        <InputFile OnChange="HandleFileSelected" @key="inputFileKey" class="form-control mb-3" disabled="@cargantwo" />
                        <div class="d-flex gap-2">
                            <RadzenButton Text="Generar Documento IA" Click="@EnviarYLimpiarDespues" Disabled="@cargando" Style="flex: 1;" />
                            <RadzenButton Text="Analizar Documento" Click="@EnviarYLimpiarDespues2" Disabled="@cargantwo" ButtonStyle="ButtonStyle.Secondary" Style="flex: 1;" />
                        </div>
                    </RadzenFieldset>

                    <RadzenFieldset Text="Resultado" Style="margin-top: 1.5rem; flex-grow: 1;">
                        <div style="height:680px; overflow-y: auto; border: 1px solid #ccc; padding: 10px;">
                            @if (opcionesGeneradas?.Any() == true && mostrarSugerencias)
                            {
                                <p><strong>Sugerencias Generadas:</strong></p>
                                @foreach (var opcion in opcionesGeneradas)
                                {
                                    <RadzenCheckBox TValue="bool" ValueChanged="(val => OnCheckboxChanged(opcion, val))" /> @opcion

                                    <br />
                                }
                            }
                            else if (!string.IsNullOrWhiteSpace(ResponseText))
                            {
                                <div contenteditable="true" @ref="editorRef" @onblur="ActualizarTextoEditable">
                                    @((MarkupString)ResponseText)
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">Aún no hay contenido generado.</p>
                            }
                        </div>
                    </RadzenFieldset>

                    <div class="d-flex gap-3 mt-3">
                        <RadzenButton Text="Descargar como Word" Click="@DescargarDocSimple" />
                        <RadzenButton Text="Mostrar Historial" Click="@(() => showModal = true)" ButtonStyle="ButtonStyle.Secondary" />
                    </div>
                </div>
            </div>
        </RadzenCard>
    </div>
</EditForm>

