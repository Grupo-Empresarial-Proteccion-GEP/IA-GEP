@code {
    private string FotoBase64 = ""; // Imagen del usuario codificada en base64
    private async Task OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file != null)
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024); // 10 MB
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var bytes = ms.ToArray();

                FotoBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(bytes)}";
            }
            catch (Exception ex)
            {
                FotoBase64 = "";
                Console.WriteLine($"Error al leer la imagen: {ex.Message}");
            }
        }
    }

}

@code {

    private string nombreBuscado;
    private string mensajeResultado;
    private string mensajeError;
    private string mensaje;

    private UsuarioModel usuarioEncontrado;
    private Usuario usuario = new Usuario();

    public string telefonoFormateado => FormatearTelefono(usuario.Telefono);

    string QRBase64 = "";
    string Empresa = "Grupo Empresarial Proteccion S.A.S.";
    string Direccion = "Calle 72 No. 7-64 Piso 3 Bogota, Colombia";
    string PaginaWeb = "https://www.grupoempresarialproteccion.com/";

    private bool cargando = false;
    private bool nombreInvalido;
    private bool documentoInvalido;
    private bool cargoInvalido;
    private bool telefonoInvalido;
    private bool correoInvalido;

    private AccesoDatos.AccesoDatosSoapClient _servicioUsuario = new AccesoDatos.AccesoDatosSoapClient(AccesoDatos.AccesoDatosSoapClient.EndpointConfiguration.AccesoDatosSoap12);

    [Inject] IJSRuntime JS { get; set; }

    private string FormatearTelefono(string numero)
    {
        if (string.IsNullOrWhiteSpace(numero))
            return string.Empty;

        var soloNumeros = new string(numero.Where(char.IsDigit).ToArray());

        if (soloNumeros.Length == 10)
            return $"{soloNumeros.Substring(0, 3)} {soloNumeros.Substring(3, 3)} {soloNumeros.Substring(6, 4)}";

        return numero;
    }

    private async Task GenerarYGuardar()
    {
        // Validación
        nombreInvalido = string.IsNullOrWhiteSpace(usuario.Nombre);
        documentoInvalido = string.IsNullOrWhiteSpace(usuario.Documento);
        cargoInvalido = string.IsNullOrWhiteSpace(usuario.Cargo);
        telefonoInvalido = string.IsNullOrWhiteSpace(usuario.Telefono);
        correoInvalido = string.IsNullOrWhiteSpace(usuario.Correo);

        if (nombreInvalido || documentoInvalido || cargoInvalido || telefonoInvalido || correoInvalido)
        {
            mensajeError = "❌ TODOS LOS CAMPOS SON OBLIGATORIOS.";
            return;
        }

        mensajeError = null;
        cargando = true;


        // Formateo y actualización del DOM

        await InvokeAsync(StateHasChanged);
        await Task.Delay(150); // Deja tiempo para que el DOM se actualice

        try
        {
            await GenerarQR(); // Aquí el texto ya estará visible en pantalla
            await GuardarUsuario();
        }
        finally
        {
            cargando = false;
            await InvokeAsync(StateHasChanged);
        }

    }

    async Task GenerarQR()
    {

        cargando = true;

        var telefono = usuario?.Telefono ?? string.Empty;
        var telefonoLimpio = new string(telefono.Where(char.IsDigit).ToArray());
        var telefonoFormateado = FormatearTelefono(telefono);

        var vcard =
            "BEGIN:VCARD\n" +
            "VERSION:3.0\n" +
            $"N:{usuario.Nombre}\n" +
            $"FN:{usuario.Nombre}\n" +
            $"ORG:{Empresa}\n" +
            $"TITLE:{usuario.Cargo}\n" +
            $"TEL;TYPE=CELL:{telefonoLimpio}\n" +
            $"EMAIL:{usuario.Correo}\n" +
            $"URL:{PaginaWeb}\n" +
            $"ADR:;;{Direccion};;;;\n" +
            "END:VCARD";




        using var generator = new QRCodeGenerator();
        var data = generator.CreateQrCode(vcard, QRCodeGenerator.ECCLevel.Q);
        using var qrCode = new PngByteQRCode(data);



        // Cambiar tamaño y colores
        var bytes = qrCode.GetGraphic(
            pixelsPerModule: 175,
            darkColor: Color.Black,
            lightColor: Color.WhiteSmoke,

            drawQuietZones: false);

        QRBase64 = Convert.ToBase64String(bytes);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("loadCarnetScripts");
        }
    }

    async Task DescargarCarnet()
    {
        await JS.InvokeVoidAsync("descargarCarnet", "carnetContainer", $"{usuario.Nombre.Replace(" ", "_")}_carnet");
     //   await JS.InvokeVoidAsync("descargarCarnet", "carnetContainer2", $"{usuario.Nombre.Replace(" ", "_")}_carnet");
    }

    async Task DescargarCarnetPDF2()
    {
        await JS.InvokeVoidAsync("descargarCarnetComoPDF2");
    }

    private async Task BuscarUsuarioPorNombre()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(nombreBuscado))
            {
                mensaje = "Por favor ingrese un documento para buscar.";
                return;
            }

            string documento = nombreBuscado.Replace("'", "''");
            string condicion = $"Documento = '{documento}'";

            string campos = "Id, Documento, Nombre, Cargo, Correo, Telefono";
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Carnet2", campos, condicion, 18);

            if (resultado != null && resultado.Rows.Count > 0)
            {
                var fila = resultado.Rows[0];

                
                usuario.Documento = fila["Documento"].ToString();
                usuario.Nombre = fila["Nombre"].ToString();
                usuario.Cargo = fila["Cargo"].ToString();
                usuario.Correo = fila["Correo"].ToString();
                usuario.Telefono = fila["Telefono"].ToString();

                mensaje = "Usuario encontrado.";
            }
            else
            {
                mensaje = "No se encontró ningún usuario con ese documento.";
                usuario = new Usuario(); // Limpiar usuario
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error al buscar usuario: {ex.Message}";
        }
    }

    private async Task GuardarUsuario()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(usuario.Documento))
            {
                mensaje = "El documento no puede estar vacío.";
                return;
            }

            string documento = usuario.Documento.Replace("'", "''");
            string condicion = $"Documento = '{documento}'";

            string campos = "Id, Documento, Nombre, Cargo, Correo, Telefono";

            // Traemos la fila existente para actualizar
            var resultado = await _servicioUsuario.TraerTablaParametrosAsync("Carnet2", campos, condicion, 18);

            if (resultado != null && resultado.Rows.Count > 0)
            {
                resultado.TableName = "Carnet2";  // Muy importante asignar el nombre correcto

                var fila = resultado.Rows[0];

                fila.BeginEdit();
                fila["Nombre"] = usuario.Nombre ?? "";
                fila["Cargo"] = usuario.Cargo ?? "";
                fila["Correo"] = usuario.Correo ?? "";
                fila["Telefono"] = usuario.Telefono ?? "";
                fila.EndEdit();

                Console.WriteLine($"Estado de la fila antes de actualizar: {fila.RowState}");

                string respuesta = await _servicioUsuario.ActualizarFilasAsync(resultado, 18);

                Console.WriteLine($"Respuesta del servidor al actualizar: {respuesta}");

                mensaje = "Usuario actualizado correctamente.";
            }


            else
            {
                // El usuario no existe, insertamos
                DataTable tablaUsuario = new DataTable("Usuarios");
                tablaUsuario.Columns.Add("Id", typeof(int));
                tablaUsuario.Columns.Add("Nombre", typeof(string));
                tablaUsuario.Columns.Add("Documento", typeof(string));
                tablaUsuario.Columns.Add("Cargo", typeof(string));
                tablaUsuario.Columns.Add("Correo", typeof(string));
                tablaUsuario.Columns.Add("Telefono", typeof(string));

                DataRow nuevaFila = tablaUsuario.NewRow();
                nuevaFila["Id"] = 0;
                nuevaFila["Nombre"] = usuario.Nombre ?? "";
                nuevaFila["Documento"] = usuario.Documento ?? "";
                nuevaFila["Cargo"] = usuario.Cargo ?? "";
                nuevaFila["Correo"] = usuario.Correo ?? "";
                nuevaFila["Telefono"] = usuario.Telefono ?? "";

                tablaUsuario.Rows.Add(nuevaFila);
                await _servicioUsuario.InsertarTablaAsync(tablaUsuario, "Carnet2", 18);
                mensaje = "Usuario guardado correctamente.";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
        }
    }

    private string DataTableToXml(DataTable dt)
    {
        using var sw = new StringWriter();
        dt.WriteXml(sw, XmlWriteMode.WriteSchema);
        return sw.ToString();
    }

    public class Usuario
        {
            public string Nombre { get; set; } = string.Empty;
            public string Documento { get; set; } = string.Empty;
            public string Cargo { get; set; } = string.Empty;
            public string Correo { get; set; } = string.Empty;
            public string Telefono { get; set; } = string.Empty;
        }

    }







