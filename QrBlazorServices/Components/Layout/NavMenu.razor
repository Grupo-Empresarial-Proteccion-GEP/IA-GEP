@inject IJSRuntime JS

<HeadContent>
    <link href="css/navmenu.css" rel="stylesheet" />
    <script src="js/carnet.js"></script> <!-- si lo necesitas -->
</HeadContent>


<div class="">
    <input type="checkbox" id="nav-toggle" title="Navigation menu" class="navbar-toggler" hidden />

    <div class="sidebar" @onclick="ToggleMenu">
        <nav class="nav flex-column">
            <NavLink href="/login" class="nav-link">Inicio de sesión</NavLink>
            <NavLink href="/agregar" class="nav-link">Agregar Usuario</NavLink>
            <NavLink href="/gr" class="nav-link">Chat Gemini</NavLink>
            <NavLink href="/correo" class="nav-link">Correos</NavLink>
            <NavLink href="/Banco" class="nav-link">Banco De Documentos</NavLink>
            <NavLink href="/menu" class="nav-link">Tabs Menu</NavLink>
        </nav>
    </div>
</div>

@code {

        private void ToggleMenu()
    {
        // Ejecuta JavaScript para hacer "click" en el checkbox del menú
        JS.InvokeVoidAsync("document.querySelector('.navbar-toggler').click");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("loadCarnetScripts");
        }
    }
}
